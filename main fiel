// Helper: syntax-highlight a Java/JS code line (called outside JSX to avoid </g parser issue)
function highlightJava(line) {
  const lt = '\x3c', gt = '\x3e';
  return line
    .replace(/&/g,"&amp;").replace(/\x3c/g,"&lt;").replace(/\x3e/g,"&gt;")
    .replace(/(\/\/[^\n]*)/g,'<span style="color:#64748b">$1</span>')
    .replace(/\b(if|else|while|for|return|void|int|double|boolean|String|new|class|public|private|static)\b/g,'<span style="color:#c084fc">$1</span>')
    .replace(/\b(true|false|null)\b/g,'<span style="color:#fb923c">$1</span>')
    .replace(/"([^"]*)"/g,'<span style="color:#86efac">&quot;$1&quot;</span>')
    .replace(/\b(\d+\.?\d*)\b/g,'<span style="color:#f9a8d4">$1</span>');
}

function BlocksLesson({ lesson }) {
