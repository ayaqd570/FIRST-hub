  function updateSponsorStatus(id, newStatus) {
    const updated = sponsors.map(s => s.id===id ? {...s, status:newStatus} : s);
    setSponsors(updated);
    localStorage.setItem("hub-sponsors", JSON.stringify(updated));
  }

  // ── Incident Log state ──
  const [incidents, setIncidents] = useState(() => {
    try { return JSON.parse(localStorage.getItem("hub-incidents")||"[]"); } catch(e){ return []; }
  });
  const [incType, setIncType] = useState("near_miss");
  const [incDesc, setIncDesc] = useState("");
