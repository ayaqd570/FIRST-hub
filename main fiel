// ─── MATCHING LESSON ──────────────────────────────────────
function MatchingLesson({ lesson }) {
  const [leftSel, setLeftSel] = useState(null);
  const [rightSel, setRightSel] = useState(null);
  const [matched, setMatched] = useState({});
  const [wrong, setWrong] = useState(null);
  const [done, setDone] = useState(false);
  const pairs = lesson.pairs || [];
  const shuffled = useRef(shuffleArr(pairs.map(p=>p.right))).current;

  function selectLeft(i) {
    if (matched[i]) return;
    setLeftSel(i); setWrong(null);
  }
  function selectRight(val) {
    if (Object.values(matched).includes(val)) return;
    if (leftSel === null) return;
    const correct = pairs[leftSel].right;
    if (val === correct) {
      const nm = {...matched, [leftSel]: val};
      setMatched(nm);
      setLeftSel(null); setRightSel(null); setWrong(null);
      if (Object.keys(nm).length === pairs.length) setDone(true);
    } else {
      setWrong(val);
      setTimeout(()=>{ setWrong(null); setLeftSel(null); }, 900);
    }
  }
  function reset() { setLeftSel(null); setRightSel(null); setMatched({}); setWrong(null); setDone(false); }

  return (
    <div style={{fontFamily:"inherit"}}>
      <div style={{fontSize:13,color:"#64748b",marginBottom:16}}>{lesson.intro||"Match each item on the left to its corresponding term on the right."}</div>
      {done ? (
        <div style={{background:"linear-gradient(135deg,#10b981,#059669)",borderRadius:16,padding:"28px 24px",textAlign:"center",color:"#fff"}}>
          <div style={{fontSize:36,marginBottom:8}}>🎉</div>
          <div style={{fontSize:20,fontWeight:800,marginBottom:6}}>Perfect Match!</div>
          <div style={{opacity:0.85,marginBottom:16}}>You matched all {pairs.length} pairs correctly.</div>
          <button onClick={reset} style={{background:"rgba(255,255,255,0.2)",color:"#fff",border:"2px solid rgba(255,255,255,0.4)",borderRadius:8,padding:"10px 22px",cursor:"pointer",fontWeight:700}}>Try Again</button>
        </div>
      ) : (
        <div>
          <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:12}}>
            <div style={{display:"flex",flexDirection:"column",gap:8}}>
              <div style={{fontSize:11,fontWeight:700,color:"#94a3b8",textTransform:"uppercase",letterSpacing:1,marginBottom:4}}>Concepts</div>
              {pairs.map((p,i)=>{
                const isMatched = matched[i]!==undefined;
                const isSel = leftSel===i;
                return (
                  <div key={i} onClick={()=>selectLeft(i)}
                    style={{padding:"12px 16px",borderRadius:10,border:`2px solid ${isMatched?"#10b981":isSel?"#1d4ed8":"#e2e8f0"}`,
                      background:isMatched?"#f0fdf4":isSel?"#eff6ff":"#fff",cursor:isMatched?"default":"pointer",
                      fontWeight:600,fontSize:14,color:isMatched?"#065f46":isSel?"#1e40af":"#1e293b",
                      transition:"all 0.15s",opacity:isMatched?0.7:1}}>
                    {isMatched ? <span style={{fontSize:12,color:"#10b981",marginRight:6}}>✓</span> : null}
                    {p.left}
                  </div>
                );
              })}
            </div>
            <div style={{display:"flex",flexDirection:"column",gap:8}}>
              <div style={{fontSize:11,fontWeight:700,color:"#94a3b8",textTransform:"uppercase",letterSpacing:1,marginBottom:4}}>Definitions</div>
              {shuffled.map((val,i)=>{
                const isMatched = Object.values(matched).includes(val);
                const isWrong = wrong===val;
                return (
                  <div key={i} onClick={()=>selectRight(val)}
                    style={{padding:"12px 16px",borderRadius:10,border:`2px solid ${isMatched?"#10b981":isWrong?"#ef4444":leftSel!==null&&!isMatched?"#e2e8f0":"#e2e8f0"}`,
                      background:isMatched?"#f0fdf4":isWrong?"#fef2f2":leftSel!==null&&!isMatched?"#f8fafc":"#fff",
                      cursor:isMatched?"default":"pointer",fontSize:13,color:isMatched?"#065f46":"#334155",
                      transition:"all 0.15s",animation:isWrong?"shake 0.3s":"none",opacity:isMatched?0.7:1,lineHeight:1.4}}>
                    {isMatched ? <span style={{fontSize:12,color:"#10b981",marginRight:6}}>✓</span> : null}
                    {val}
                  </div>
                );
              })}
            </div>
          </div>
          <div style={{marginTop:14,display:"flex",alignItems:"center",gap:12}}>
            <div style={{flex:1,background:"#e2e8f0",borderRadius:999,height:6}}>
              <div style={{width:`${(Object.keys(matched).length/pairs.length)*100}%`,background:"#10b981",height:"100%",borderRadius:999,transition:"width 0.3s"}}></div>
            </div>
            <span style={{fontSize:12,color:"#64748b"}}>{Object.keys(matched).length}/{pairs.length} matched</span>
            <button onClick={reset} style={{background:"none",border:"1px solid #e2e8f0",borderRadius:7,padding:"6px 12px",cursor:"pointer",fontSize:12,color:"#64748b"}}>Reset</button>
          </div>
          {leftSel!==null && <div style={{marginTop:10,fontSize:13,color:"#1d4ed8",fontStyle:"italic"}}>👆 Now click a definition on the right to match with "{pairs[leftSel].left}"</div>}
        </div>
      )}
    </div>
  );
}

// ─── FILL-IN-THE-BLANK LESSON ─────────────────────────────
function FillBlankLesson({ lesson }) {
  const blanks = lesson.blanks || [];
  const [answers, setAnswers] = useState(blanks.map(()=>""));
  const [checked, setChecked] = useState(false);
  const [showAll, setShowAll] = useState(false);
  const score = blanks.filter((b,i)=>answers[i].trim().toLowerCase()===b.answer.toLowerCase()).length;

  function check() { setChecked(true); }
  function reset() { setAnswers(blanks.map(()=>"")); setChecked(false); setShowAll(false); }

  return (
    <div style={{fontFamily:"inherit"}}>
      <div style={{fontSize:13,color:"#64748b",marginBottom:16}}>{lesson.intro||"Fill in the blanks to complete the code or definition."}</div>
      {blanks.map((b,i)=>{
        const isCorrect = checked && answers[i].trim().toLowerCase()===b.answer.toLowerCase();
        const isWrong = checked && answers[i].trim()!=="" && !isCorrect;
        const isEmpty = checked && answers[i].trim()==="";
        return (
          <div key={i} style={{marginBottom:18,background:"#f8fafc",borderRadius:12,padding:"16px 18px",border:"1px solid #e2e8f0"}}>
            <div style={{fontSize:13,color:"#475569",marginBottom:10,lineHeight:1.6}} dangerouslySetInnerHTML={{__html:b.prompt.replace("___","<span style='display:inline-block;background:#e0e7ff;padding:1px 18px;border-radius:5px;margin:0 4px;font-style:italic;color:#3730a3'>___</span>")}}/>
            {b.code && <pre style={{background:"#1e293b",color:"#e2e8f0",padding:"12px 16px",borderRadius:8,fontSize:12,marginBottom:10,overflowX:"auto",lineHeight:1.6}}>{b.code}</pre>}
            <div style={{display:"flex",alignItems:"center",gap:10}}>
              <input
                value={showAll?b.answer:answers[i]}
                onChange={e=>{ if(!checked&&!showAll){const a=[...answers];a[i]=e.target.value;setAnswers(a);}}}
                placeholder="Type your answer…"
                style={{flex:1,padding:"10px 14px",borderRadius:8,border:`2px solid ${isCorrect?"#10b981":isWrong?"#ef4444":isEmpty?"#f59e0b":"#e2e8f0"}`,
                  fontSize:14,fontFamily:"'Consolas','Courier New',monospace",background:isCorrect?"#f0fdf4":isWrong?"#fef2f2":"#fff",
                  color:"#1e293b",outline:"none"}}
              />
              {checked && (
                <span style={{fontSize:18}}>{isCorrect?"✅":isEmpty?"⚠️":"❌"}</span>
              )}
            </div>
            {checked && !isCorrect && <div style={{marginTop:6,fontSize:12,color:"#64748b"}}>Answer: <code style={{background:"#e0e7ff",padding:"2px 8px",borderRadius:4,color:"#3730a3"}}>{b.answer}</code> — {b.explanation}</div>}
          </div>
        );
      })}
      <div style={{display:"flex",gap:10,marginTop:4,flexWrap:"wrap",alignItems:"center"}}>
        {!checked ? (
          <button onClick={check} style={{background:"#1d4ed8",color:"#fff",border:"none",borderRadius:8,padding:"11px 24px",cursor:"pointer",fontWeight:700,fontSize:14}}>Check Answers</button>
        ) : (
          <>
            <div style={{background:score===blanks.length?"#10b981":score>=blanks.length/2?"#f59e0b":"#ef4444",color:"#fff",borderRadius:8,padding:"10px 18px",fontWeight:700,fontSize:15}}>
              {score}/{blanks.length} correct
            </div>
            <button onClick={reset} style={{background:"#f1f5f9",color:"#475569",border:"1px solid #e2e8f0",borderRadius:8,padding:"10px 18px",cursor:"pointer",fontWeight:600}}>Try Again</button>
            {!showAll && <button onClick={()=>setShowAll(true)} style={{background:"none",color:"#6366f1",border:"none",cursor:"pointer",fontWeight:600,fontSize:13,textDecoration:"underline"}}>Show All Answers</button>}
          </>
        )}
      </div>
    </div>
  );
}

