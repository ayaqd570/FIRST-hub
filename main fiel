// ─── GOALS & PROGRESS TRACKER ─────────────────────────────
function GoalsPage({ user, done, totalLessons }) {
  const [goals, setGoals] = useState([]);
  const [newGoalText, setNewGoalText] = useState("");
  const [newGoalType, setNewGoalType] = useState("lessons");
  const [newGoalTarget, setNewGoalTarget] = useState(10);
  const [loading, setLoading] = useState(true);

  useEffect(()=>{
    storeGet("hub-goals-"+user.username, false).then(g=>{ setGoals(g||[]); setLoading(false); });
  },[user]);

  async function saveGoals(updated) {
    setGoals(updated);
    await storeSet("hub-goals-"+user.username, updated, false);
  }

  async function addGoal() {
    if (!newGoalText.trim()) return;
    const newGoal = {
      id: Date.now().toString(),
      text: newGoalText.trim(),
      type: newGoalType,
      target: newGoalTarget,
      created: Date.now(),
      completed: false,
      completedAt: null,
    };
    await saveGoals([...goals, newGoal]);
    setNewGoalText(""); setNewGoalTarget(10);
  }

  async function toggleGoal(id) {
    await saveGoals(goals.map(g=>g.id===id?{...g,completed:!g.completed,completedAt:!g.completed?Date.now():null}:g));
  }

  async function deleteGoal(id) {
    await saveGoals(goals.filter(g=>g.id!==id));
  }

  function getProgress(goal) {
    if (goal.type==="lessons") return {current:Object.keys(done).length, label:"lessons completed"};
    if (goal.type==="percent") return {current:Math.round(Object.keys(done).length/totalLessons*100), label:"% overall"};
    if (goal.type==="subject") return {current:0, label:"subject lessons"};
    return {current:0,label:""};
  }

  const GOAL_TYPES = [
    {id:"lessons",label:"📚 Complete N lessons"},
    {id:"percent",label:"📈 Reach X% overall"},
    {id:"custom",label:"✏️ Custom goal"},
  ];

  const active = goals.filter(g=>!g.completed);
  const completed = goals.filter(g=>g.completed);

  if (loading) return <div style={{padding:40,textAlign:"center",color:"#64748b"}}>Loading goals…</div>;

  return (
    <div style={{maxWidth:700,margin:"0 auto",padding:"24px 16px"}}>
      <div style={{fontWeight:900,fontSize:24,marginBottom:6}}>🎯 My Goals</div>
      <div style={{color:"#64748b",marginBottom:24,fontSize:14}}>Set personal learning goals and track your progress toward them.</div>

      {/* Add goal */}
      <div style={{background:"#fff",borderRadius:16,padding:20,border:"1px solid #e2e8f0",marginBottom:20}}>
        <div style={{fontWeight:700,fontSize:15,marginBottom:14}}>➕ Add a New Goal</div>
        <div style={{display:"flex",gap:8,marginBottom:10,flexWrap:"wrap"}}>
          {GOAL_TYPES.map(t=>(
            <button key={t.id} onClick={()=>setNewGoalType(t.id)}
              style={{background:newGoalType===t.id?"#1d4ed8":"#f1f5f9",color:newGoalType===t.id?"#fff":"#475569",border:"none",borderRadius:8,padding:"8px 14px",cursor:"pointer",fontWeight:newGoalType===t.id?700:500,fontSize:13}}>
              {t.label}
            </button>
          ))}
        </div>
        <input value={newGoalText} onChange={e=>setNewGoalText(e.target.value)}
          placeholder={newGoalType==="custom"?"Describe your goal…":newGoalType==="lessons"?"e.g. Complete all Java Beginner lessons":"e.g. Reach 50% overall"}
          style={{width:"100%",padding:"10px 14px",borderRadius:8,border:"1px solid #e2e8f0",fontSize:14,marginBottom:10,boxSizing:"border-box"}}
          onKeyDown={e=>e.key==="Enter"&&addGoal()}
        />
        {newGoalType!=="custom" && (
          <div style={{display:"flex",alignItems:"center",gap:12,marginBottom:10}}>
            <span style={{fontSize:13,color:"#64748b"}}>Target:</span>
            <input type="number" value={newGoalTarget} onChange={e=>setNewGoalTarget(+e.target.value)} min={1} max={newGoalType==="percent"?100:totalLessons}
              style={{width:80,padding:"8px 12px",borderRadius:8,border:"1px solid #e2e8f0",fontSize:14}}/>
            <span style={{fontSize:13,color:"#64748b"}}>{newGoalType==="lessons"?"lessons":"%"}</span>
          </div>
        )}
        <button onClick={addGoal} style={{background:"#1d4ed8",color:"#fff",border:"none",borderRadius:8,padding:"10px 20px",cursor:"pointer",fontWeight:700}}>
          Add Goal
        </button>
      </div>

      {/* Active goals */}
      {active.length > 0 && (
        <div style={{marginBottom:20}}>
          <div style={{fontWeight:700,fontSize:15,marginBottom:10,color:"#1e293b"}}>🔥 Active Goals ({active.length})</div>
          <div style={{display:"flex",flexDirection:"column",gap:10}}>
            {active.map(goal=>{
              const {current,label} = getProgress(goal);
              const pct = goal.type!=="custom" ? Math.min(100,Math.round(current/goal.target*100)) : 0;
              return (
                <div key={goal.id} style={{background:"#fff",borderRadius:14,padding:"16px 18px",border:"1px solid #e2e8f0"}}>
                  <div style={{display:"flex",alignItems:"flex-start",gap:10}}>
                    <div style={{flex:1}}>
                      <div style={{fontWeight:700,fontSize:14,color:"#1e293b",marginBottom:4}}>{goal.text}</div>
                      {goal.type!=="custom"&&(
                        <>
                          <div style={{display:"flex",justifyContent:"space-between",marginBottom:5}}>
                            <span style={{fontSize:12,color:"#64748b"}}>{current} / {goal.target} {label}</span>
                            <span style={{fontSize:12,fontWeight:700,color:pct>=100?"#10b981":"#1d4ed8"}}>{pct}%</span>
                          </div>
                          <div style={{background:"#f1f5f9",borderRadius:999,height:6}}>
                            <div style={{width:`${pct}%`,background:pct>=100?"#10b981":"#1d4ed8",height:"100%",borderRadius:999,transition:"width 0.4s"}}></div>
                          </div>
                        </>
                      )}
                    </div>
                    <div style={{display:"flex",gap:6}}>
                      <button onClick={()=>toggleGoal(goal.id)}
                        style={{background:"#f0fdf4",color:"#16a34a",border:"1px solid #bbf7d0",borderRadius:8,padding:"6px 12px",cursor:"pointer",fontSize:12,fontWeight:700}}>
                        ✓ Done
                      </button>
                      <button onClick={()=>deleteGoal(goal.id)}
                        style={{background:"none",color:"#9ca3af",border:"none",cursor:"pointer",fontSize:16,padding:"4px"}}>✕</button>
                    </div>
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      )}

      {active.length===0&&goals.length===0&&(
        <div style={{textAlign:"center",padding:"40px 20px",color:"#94a3b8",background:"#fff",borderRadius:16,border:"1px dashed #e2e8f0"}}>
          <div style={{fontSize:40,marginBottom:12}}>🎯</div>
          <div style={{fontWeight:700,marginBottom:4}}>No goals yet</div>
          <div style={{fontSize:13}}>Set your first learning goal above to start tracking progress.</div>
        </div>
      )}

      {/* Completed goals */}
      {completed.length > 0 && (
        <div>
          <div style={{fontWeight:700,fontSize:15,marginBottom:10,color:"#64748b"}}>✅ Completed ({completed.length})</div>
          <div style={{display:"flex",flexDirection:"column",gap:8}}>
            {completed.map(goal=>(
              <div key={goal.id} style={{background:"#f0fdf4",borderRadius:12,padding:"12px 16px",border:"1px solid #bbf7d0",display:"flex",alignItems:"center",gap:10,opacity:0.7}}>
                <span style={{fontSize:18}}>✅</span>
                <span style={{flex:1,fontSize:13,color:"#065f46",fontWeight:600,textDecoration:"line-through"}}>{goal.text}</span>
                <button onClick={()=>toggleGoal(goal.id)} style={{background:"none",border:"none",color:"#9ca3af",cursor:"pointer",fontSize:12}}>Unmark</button>
                <button onClick={()=>deleteGoal(goal.id)} style={{background:"none",border:"none",color:"#9ca3af",cursor:"pointer",fontSize:16}}>✕</button>
              </div>
            ))}
          </div>
        </div>
      )}
    </div>
  );
}

// ─── SKILL TREE PAGE ──────────────────────────────────────
function SkillTreePage({ user, done, setTab, setSelSub, setSelLevel, setSelLesson }) {
  const [selSubject, setSelSubject] = useState("java");
  const sub = SUBJECTS.find(s=>s.id===selSubject);

  const levelData = LEVELS.map(level => {
    const lessons = LESSONS[selSubject]?.[level] || [];
    const doneCount = lessons.filter(l=>done[l.id]).length;
    return { level, lessons, doneCount, total:lessons.length, pct: lessons.length?Math.round(doneCount/lessons.length*100):0 };
  });

  // A level is "unlocked" if the previous level is >= 50% complete
  function isUnlocked(i) {
    if (i===0) return true;
    return levelData[i-1].pct >= 50;
  }

  function openLesson(lesson, level) {
    setSelSub(selSubject);
    setSelLevel(level);
    setSelLesson(lesson);
    setTab("learn");
  }

  const levelColors = {Beginner:"#10b981",Intermediate:"#f59e0b",Advanced:"#ef4444"};
  const levelIcons = {Beginner:"🌱",Intermediate:"⚡",Advanced:"🔥"};

  return (
    <div style={{maxWidth:900,margin:"0 auto",padding:"24px 16px"}}>
      <div style={{fontWeight:900,fontSize:24,marginBottom:6}}>🌳 Skill Tree</div>
      <div style={{color:"#64748b",marginBottom:20,fontSize:14}}>Visualize your mastery. Complete 50% of each level to unlock the next.</div>

      {/* Subject selector */}
      <div style={{display:"flex",gap:8,flexWrap:"wrap",marginBottom:24}}>
        {SUBJECTS.map(s=>(
          <button key={s.id} onClick={()=>setSelSubject(s.id)}
            style={{background:selSubject===s.id?s.color:"#f1f5f9",color:selSubject===s.id?"#fff":"#475569",
              border:`2px solid ${selSubject===s.id?s.color:"#e2e8f0"}`,borderRadius:10,padding:"10px 16px",cursor:"pointer",fontWeight:selSubject===s.id?700:500,fontSize:13,transition:"all 0.15s"}}>
            {s.icon} {s.name}
          </button>
        ))}
      </div>

      {/* Tree visualization */}
      <div style={{position:"relative"}}>
        {/* Vertical connector line */}
        <div style={{position:"absolute",left:35,top:40,bottom:40,width:4,background:"linear-gradient(to bottom, #10b981, #f59e0b, #ef4444)",borderRadius:999,zIndex:0,opacity:0.3}}></div>

        {levelData.map((ld,i)=>{
          const unlocked = isUnlocked(i);
          const col = levelColors[ld.level];
          return (
            <div key={ld.level} style={{marginBottom:24,position:"relative",zIndex:1}}>
              {/* Level header */}
              <div style={{display:"flex",alignItems:"center",gap:16,marginBottom:12}}>
                <div style={{width:72,height:72,borderRadius:999,background:unlocked?col:"#e2e8f0",
                  display:"flex",flexDirection:"column",alignItems:"center",justifyContent:"center",
                  boxShadow:unlocked?`0 0 0 4px ${col}30`:"none",transition:"all 0.3s",flexShrink:0}}>
                  <div style={{fontSize:unlocked?28:22}}>{unlocked?levelIcons[ld.level]:"🔒"}</div>
                  <div style={{fontSize:10,fontWeight:700,color:unlocked?"#fff":"#9ca3af",marginTop:2}}>
                    {ld.doneCount}/{ld.total}
                  </div>
                </div>
                <div>
                  <div style={{fontWeight:800,fontSize:18,color:unlocked?col:"#9ca3af"}}>{ld.level}</div>
                  <div style={{fontSize:13,color:"#64748b"}}>{ld.total} lessons · {ld.pct}% complete</div>
                  {!unlocked&&<div style={{fontSize:12,color:"#f59e0b",marginTop:2}}>⚠️ Complete 50% of {LEVELS[i-1]} to unlock</div>}
                </div>
                {/* Level progress bar */}
                <div style={{flex:1,marginLeft:8}}>
                  <div style={{background:"#f1f5f9",borderRadius:999,height:10,overflow:"hidden"}}>
                    <div style={{width:`${ld.pct}%`,background:col,height:"100%",borderRadius:999,transition:"width 0.5s"}}></div>
                  </div>
                  <div style={{fontSize:11,color:"#94a3b8",marginTop:3}}>{ld.pct}%</div>
                </div>
              </div>

              {/* Lesson nodes */}
              {unlocked && (
                <div style={{marginLeft:88,display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(220px,1fr))",gap:10}}>
                  {ld.lessons.map(lesson=>{
                    const isDone = !!done[lesson.id];
                    return (
                      <div key={lesson.id} onClick={()=>openLesson(lesson,ld.level)}
                        style={{background:isDone?`${col}15`:"#fff",borderRadius:12,padding:"12px 14px",
                          border:`2px solid ${isDone?col:"#e2e8f0"}`,cursor:"pointer",transition:"all 0.15s"}}
                        onMouseEnter={e=>{e.currentTarget.style.transform="translateY(-2px)";e.currentTarget.style.boxShadow="0 4px 14px rgba(0,0,0,0.1)";}}
                        onMouseLeave={e=>{e.currentTarget.style.transform="none";e.currentTarget.style.boxShadow="none";}}>
                        <div style={{display:"flex",alignItems:"center",gap:8,marginBottom:4}}>
                          <span style={{fontSize:18}}>{isDone?"✅":"⬜"}</span>
                          <span style={{fontWeight:700,fontSize:13,color:isDone?col:"#1e293b",lineHeight:1.3,flex:1}}>{lesson.title}</span>
                        </div>
                        <div style={{display:"flex",gap:6,marginTop:4}}>
                          <span style={{fontSize:10,color:"#94a3b8"}}>{lesson.id}</span>
                          {lesson.type&&<span style={{fontSize:10,background:"#eff6ff",color:"#1d4ed8",padding:"1px 6px",borderRadius:4,fontWeight:700}}>
                            {lesson.type==="scenario"?"🎯":lesson.type==="checklist"?"✅":lesson.type==="challenge"?"🐛":lesson.type==="matching"?"🔗":lesson.type==="fillblank"?"✏️":"📖"} {lesson.type}
                          </span>}
                        </div>
                      </div>
                    );
                  })}
                </div>
              )}
            </div>
          );
        })}
      </div>

      {/* Subject completion badge */}
      {(() => {
        const totalDone = levelData.reduce((s,l)=>s+l.doneCount,0);
        const totalAll = levelData.reduce((s,l)=>s+l.total,0);
        if (totalDone===totalAll&&totalAll>0) return (
          <div style={{background:`linear-gradient(135deg,${sub.color},#1d4ed8)`,borderRadius:16,padding:"20px 24px",textAlign:"center",color:"#fff",marginTop:20}}>
            <div style={{fontSize:40,marginBottom:8}}>🏅</div>
            <div style={{fontWeight:900,fontSize:18}}>Subject Mastered!</div>
            <div style={{opacity:0.8,marginTop:4}}>You've completed all lessons in {sub.name}.</div>
          </div>
        );
        return null;
      })()}
    </div>
  );
}

// ─── PRACTICE TEST PAGE ───────────────────────────────────
function PracticeTestPage({ user }) {
  const [config, setConfig] = useState({subjects:[], numQ:20, level:"all", timed:true, timeLimit:15});
  const [phase, setPhase] = useState("config"); // config | test | results
  const [questions, setQuestions] = useState([]);
  const [current, setCurrent] = useState(0);
  const [selected, setSelected] = useState(null);
  const [confirmed, setConfirmed] = useState(false);
  const [answers, setAnswers] = useState([]);
  const [score, setScore] = useState(0);
  const [timeLeft, setTimeLeft] = useState(0);
  const timerRef = useRef(null);

  function toggleSubject(id) {
    setConfig(c=>({...c, subjects: c.subjects.includes(id) ? c.subjects.filter(s=>s!==id) : [...c.subjects, id]}));
  }

  function buildQuestions() {
    const subs = config.subjects.length ? config.subjects : SUBJECTS.map(s=>s.id);
    let pool = [];
    subs.forEach(sid => {
      const levelsToUse = config.level==="all" ? LEVELS : [config.level==="beginner"?"Beginner":config.level==="intermediate"?"Intermediate":"Advanced"];
      levelsToUse.forEach(lv => {
        const lessons = LESSONS[sid]?.[lv] || [];
        lessons.forEach(l => {
          if (l.quiz) pool.push(...l.quiz.map(q=>({...q, subId:sid, level:lv, lessonTitle:l.title})));
        });
      });
    });
    pool = shuffleArr(pool).slice(0, config.numQ);
    setQuestions(pool);
    setPhase("test");
    setCurrent(0); setSelected(null); setConfirmed(false); setAnswers([]); setScore(0);
    if (config.timed) {
      setTimeLeft(config.timeLimit * 60);
    }
  }

  useEffect(()=>{
    if (phase==="test" && config.timed) {
      timerRef.current = setInterval(()=>{
        setTimeLeft(t=>{
          if (t<=1) { clearInterval(timerRef.current); finishTest(); return 0; }
          return t-1;
        });
      },1000);
    }
    return ()=>clearInterval(timerRef.current);
  },[phase]);

  function confirm() {
    if (selected===null) return;
    setConfirmed(true);
    if (selected===questions[current].ans) setScore(s=>s+1);
    setAnswers(prev=>[...prev,{q:questions[current],sel:selected}]);
  }

  function next() {
    if (current+1>=questions.length) { clearInterval(timerRef.current); finishTest(); return; }
    setCurrent(c=>c+1); setSelected(null); setConfirmed(false);
  }

  function finishTest() {
    clearInterval(timerRef.current);
    setPhase("results");
  }

  if (phase==="config") return (
    <div style={{maxWidth:640,margin:"0 auto",padding:"24px 16px"}}>
      <div style={{fontWeight:900,fontSize:24,marginBottom:6}}>📝 Practice Test</div>
      <div style={{color:"#64748b",marginBottom:24,fontSize:14}}>Build a custom test from any subjects and difficulty levels.</div>

      <div style={{background:"#fff",borderRadius:16,padding:20,border:"1px solid #e2e8f0",marginBottom:16}}>
        <div style={{fontWeight:700,marginBottom:10}}>📚 Subjects (leave blank for all)</div>
        <div style={{display:"flex",flexWrap:"wrap",gap:8}}>
          {SUBJECTS.map(s=>(
            <button key={s.id} onClick={()=>toggleSubject(s.id)}
              style={{background:config.subjects.includes(s.id)?s.color:"#f1f5f9",color:config.subjects.includes(s.id)?"#fff":"#475569",
                border:"none",borderRadius:8,padding:"8px 14px",cursor:"pointer",fontWeight:600,fontSize:13}}>
              {s.icon} {s.name}
            </button>
          ))}
        </div>
      </div>

      <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:12,marginBottom:16}}>
        <div style={{background:"#fff",borderRadius:16,padding:16,border:"1px solid #e2e8f0"}}>
          <div style={{fontWeight:700,marginBottom:8,fontSize:14}}>📊 Difficulty</div>
          {[["all","All Levels"],["beginner","Beginner Only"],["intermediate","Intermediate Only"],["advanced","Advanced Only"]].map(([v,l])=>(
            <label key={v} style={{display:"flex",alignItems:"center",gap:8,marginBottom:6,cursor:"pointer",fontSize:13}}>
              <input type="radio" checked={config.level===v} onChange={()=>setConfig(c=>({...c,level:v}))} />
              {l}
            </label>
          ))}
        </div>
        <div style={{background:"#fff",borderRadius:16,padding:16,border:"1px solid #e2e8f0"}}>
          <div style={{fontWeight:700,marginBottom:8,fontSize:14}}>❓ Questions: <span style={{color:"#1d4ed8"}}>{config.numQ}</span></div>
          <input type="range" min={5} max={50} step={5} value={config.numQ} onChange={e=>setConfig(c=>({...c,numQ:+e.target.value}))} style={{width:"100%",accentColor:"#1d4ed8",marginBottom:12}} />
          <div style={{fontWeight:700,marginBottom:8,fontSize:14}}>
            ⏱ Timer: <label style={{cursor:"pointer"}}>
              <input type="checkbox" checked={config.timed} onChange={e=>setConfig(c=>({...c,timed:e.target.checked}))} /> {config.timed?"ON":"OFF"}
            </label>
          </div>
          {config.timed && (
            <>
              <input type="range" min={5} max={60} step={5} value={config.timeLimit} onChange={e=>setConfig(c=>({...c,timeLimit:+e.target.value}))} style={{width:"100%",accentColor:"#1d4ed8"}} />
              <div style={{fontSize:12,color:"#64748b"}}>{config.timeLimit} minutes</div>
            </>
          )}
        </div>
      </div>

      <button onClick={buildQuestions}
        style={{width:"100%",background:"linear-gradient(135deg,#1e3a8a,#b91c1c)",color:"#fff",border:"none",borderRadius:12,padding:"16px",cursor:"pointer",fontWeight:800,fontSize:16}}>
        🚀 Start Practice Test
      </button>
    </div>
  );

  if (phase==="test" && questions.length===0) return (
    <div style={{padding:60,textAlign:"center",color:"#64748b"}}>
      <div style={{fontSize:40,marginBottom:12}}>😕</div>
      <div style={{fontWeight:700,marginBottom:8}}>No questions found</div>
      <div style={{fontSize:14}}>The selected subjects/levels don't have quiz questions yet. Try different settings.</div>
      <button onClick={()=>setPhase("config")} style={{marginTop:20,background:"#1d4ed8",color:"#fff",border:"none",borderRadius:8,padding:"10px 22px",cursor:"pointer",fontWeight:700}}>← Back to Config</button>
    </div>
  );

  if (phase==="test") {
    const q = questions[current];
    const mins = Math.floor(timeLeft/60).toString().padStart(2,"0");
    const secs = (timeLeft%60).toString().padStart(2,"0");
    const progressPct = Math.round((current/questions.length)*100);

    return (
      <div style={{maxWidth:620,margin:"0 auto",padding:"24px 16px"}}>
        {/* Header */}
        <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:16}}>
          <div style={{fontSize:13,color:"#64748b"}}>{current+1} / {questions.length}</div>
          {config.timed&&<div style={{background:timeLeft<60?"#fef2f2":"#eff6ff",color:timeLeft<60?"#ef4444":"#1d4ed8",fontWeight:800,padding:"6px 14px",borderRadius:8,fontSize:15}}>⏱ {mins}:{secs}</div>}
          <button onClick={finishTest} style={{background:"none",border:"1px solid #e2e8f0",borderRadius:7,padding:"6px 12px",cursor:"pointer",fontSize:12,color:"#64748b"}}>End Test</button>
        </div>

        {/* Progress */}
        <div style={{background:"#f1f5f9",borderRadius:999,height:6,marginBottom:20}}>
          <div style={{width:`${progressPct}%`,background:"#1d4ed8",height:"100%",borderRadius:999,transition:"width 0.3s"}}></div>
        </div>

        {/* Context */}
        <div style={{fontSize:11,color:"#94a3b8",marginBottom:12}}>
          {SUBJECTS.find(s=>s.id===q.subId)?.icon} {q.lessonTitle} · {q.level}
        </div>

        {/* Question */}
        <div style={{background:"#fff",borderRadius:16,padding:"22px 20px",border:"1px solid #e2e8f0",marginBottom:16}}>
          <div style={{fontWeight:700,fontSize:16,lineHeight:1.5,color:"#1e293b"}}>{q.q}</div>
        </div>

        {/* Options */}
        <div style={{display:"flex",flexDirection:"column",gap:8,marginBottom:16}}>
          {q.opts.map((opt,i)=>{
            const isSelected=selected===i;
            const isCorrect=confirmed&&i===q.ans;
            const isWrong=confirmed&&isSelected&&i!==q.ans;
            return (
              <div key={i} onClick={()=>{if(!confirmed)setSelected(i);}}
                style={{padding:"14px 18px",borderRadius:12,border:`2px solid ${isCorrect?"#10b981":isWrong?"#ef4444":isSelected?"#1d4ed8":"#e2e8f0"}`,
                  background:isCorrect?"#f0fdf4":isWrong?"#fef2f2":isSelected?"#eff6ff":"#fff",
                  cursor:confirmed?"default":"pointer",fontSize:14,fontWeight:isSelected||isCorrect?600:400,
                  color:isCorrect?"#065f46":isWrong?"#991b1b":isSelected?"#1e40af":"#334155",transition:"all 0.15s"}}>
                {isCorrect?"✅ ":isWrong?"❌ ":""}{opt}
              </div>
            );
          })}
        </div>

        {!confirmed ? (
          <button onClick={confirm} disabled={selected===null}
            style={{width:"100%",background:selected!==null?"#1d4ed8":"#e2e8f0",color:selected!==null?"#fff":"#94a3b8",border:"none",borderRadius:10,padding:"13px",cursor:selected!==null?"pointer":"default",fontWeight:700,fontSize:15}}>
            Submit Answer
          </button>
        ) : (
          <button onClick={next}
            style={{width:"100%",background:"#10b981",color:"#fff",border:"none",borderRadius:10,padding:"13px",cursor:"pointer",fontWeight:700,fontSize:15}}>
            {current+1>=questions.length?"🏁 See Results":"Next Question →"}
          </button>
        )}
      </div>
    );
  }

  if (phase==="results") {
    const pct = Math.round(score/questions.length*100);
    const grade = pct>=90?"A":pct>=80?"B":pct>=70?"C":pct>=60?"D":"F";
    const gradeColor = pct>=80?"#10b981":pct>=60?"#f59e0b":"#ef4444";
    const wrong = answers.filter(a=>a.sel!==a.q.ans);

    return (
      <div style={{maxWidth:620,margin:"0 auto",padding:"24px 16px"}}>
        <div style={{background:"#fff",borderRadius:20,padding:"32px 28px",border:"1px solid #e2e8f0",textAlign:"center",marginBottom:20}}>
          <div style={{fontSize:56,marginBottom:8}}>
            {pct>=90?"🏆":pct>=70?"🎉":pct>=50?"👍":"💪"}
          </div>
          <div style={{fontSize:60,fontWeight:900,color:gradeColor,lineHeight:1}}>{grade}</div>
          <div style={{fontWeight:700,fontSize:22,marginBottom:4,marginTop:8}}>{score} / {questions.length} correct</div>
          <div style={{color:"#64748b",marginBottom:20}}>{pct}% accuracy</div>
          <div style={{background:"#f1f5f9",borderRadius:999,height:12,marginBottom:20}}>
            <div style={{width:`${pct}%`,background:gradeColor,height:"100%",borderRadius:999,transition:"width 0.8s"}}></div>
          </div>
          <button onClick={()=>setPhase("config")} style={{background:"#1d4ed8",color:"#fff",border:"none",borderRadius:10,padding:"12px 28px",cursor:"pointer",fontWeight:700,fontSize:15}}>
            📝 Take Another Test
          </button>
        </div>

        {wrong.length>0&&(
          <div style={{background:"#fff",borderRadius:16,padding:20,border:"1px solid #e2e8f0"}}>
            <div style={{fontWeight:800,fontSize:15,marginBottom:14,color:"#ef4444"}}>❌ Review Missed Questions ({wrong.length})</div>
            {wrong.map((a,i)=>(
              <div key={i} style={{marginBottom:16,padding:"14px 16px",background:"#fef2f2",borderRadius:12,border:"1px solid #fecaca"}}>
                <div style={{fontWeight:600,fontSize:14,marginBottom:8,color:"#1e293b"}}>{a.q.q}</div>
                <div style={{fontSize:13,color:"#ef4444",marginBottom:4}}>Your answer: <strong>{a.q.opts[a.sel]}</strong></div>
                <div style={{fontSize:13,color:"#10b981"}}>Correct answer: <strong>{a.q.opts[a.q.ans]}</strong></div>
                <div style={{fontSize:11,color:"#94a3b8",marginTop:6}}>From: {a.q.lessonTitle}</div>
              </div>
            ))}
          </div>
        )}
      </div>
    );
  }
  return null;
}

// ─── BUILD TRACKER PAGE ───────────────────────────────────
function BuildTrackerPage({ user }) {
  const KEY = "hub-buildtracker";
  const [tasks, setTasks] = useState(() => {
    try { return JSON.parse(localStorage.getItem(KEY)||"[]"); } catch(e) { return []; }
  });
  const [newTask, setNewTask] = useState("");
  const [newCat, setNewCat] = useState("mechanical");
  const [newPriority, setNewPriority] = useState("medium");
  const [newDue, setNewDue] = useState("");
  const [newAssign, setNewAssign] = useState("");
  const [filterCat, setFilterCat] = useState("all");
  const [filterStatus, setFilterStatus] = useState("all");
  const [kickoffDate, setKickoffDate] = useState(() => localStorage.getItem("hub-kickoff") || "");
  const [compDate, setCompDate] = useState(() => localStorage.getItem("hub-compdate") || "");

  const CATS = [
    {id:"mechanical",label:"⚙️ Mechanical",color:"#d97706"},
    {id:"electrical",label:"⚡ Electrical",color:"#7c3aed"},
    {id:"programming",label:"💻 Programming",color:"#2563eb"},
    {id:"strategy",label:"🏆 Strategy",color:"#059669"},
    {id:"outreach",label:"🌍 Outreach",color:"#db2777"},
    {id:"admin",label:"📋 Admin",color:"#64748b"},
  ];
  const PRIORITIES = [{id:"high",label:"🔴 High"},{id:"medium",label:"🟡 Medium"},{id:"low",label:"🟢 Low"}];

  function save(updated) {
    setTasks(updated);
    localStorage.setItem(KEY, JSON.stringify(updated));
  }

  function addTask() {
    if (!newTask.trim()) return;
    const t = {id:Date.now(), title:newTask, cat:newCat, priority:newPriority, due:newDue, assign:newAssign, done:false, created:Date.now()};
    save([...tasks, t]);
    setNewTask(""); setNewDue(""); setNewAssign("");
  }

  function toggleTask(id) {
    save(tasks.map(t => t.id===id ? {...t, done:!t.done, completedAt:Date.now()} : t));
  }

  function deleteTask(id) { save(tasks.filter(t=>t.id!==id)); }

  // Countdown math
  const now = new Date();
  const daysToComp = compDate ? Math.ceil((new Date(compDate)-now)/(1000*60*60*24)) : null;
  const daysFromKickoff = kickoffDate ? Math.ceil((now-new Date(kickoffDate))/(1000*60*60*24)) : null;

  // Stats
  const done = tasks.filter(t=>t.done).length;
  const total = tasks.length;
  const overdue = tasks.filter(t=>!t.done && t.due && new Date(t.due) < now).length;
  const highPending = tasks.filter(t=>!t.done && t.priority==="high").length;

  // Filtered tasks
  const filtered = tasks.filter(t => {
    const catOk = filterCat==="all" || t.cat===filterCat;
    const statOk = filterStatus==="all" || (filterStatus==="done"?t.done:!t.done);
    return catOk && statOk;
  }).sort((a,b) => {
    // High priority first, then by due date
    const pOrder = {high:0,medium:1,low:2};
    if (a.done !== b.done) return a.done ? 1 : -1;
    return (pOrder[a.priority]||1) - (pOrder[b.priority]||1);
  });

  const catInfo = (id) => CATS.find(c=>c.id===id) || {label:id,color:"#64748b"};

  return (
    <div>
      <div style={{display:"flex",alignItems:"flex-start",justifyContent:"space-between",marginBottom:20,flexWrap:"wrap",gap:12}}>
        <div>
          <div style={{fontWeight:900,fontSize:24,marginBottom:3}}>🔨 Build Season Tracker</div>
          <div style={{color:"#64748b",fontSize:13}}>Manage your season tasks, deadlines, and team assignments.</div>
        </div>
      </div>

      {/* Countdown cards */}
      <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(160px,1fr))",gap:10,marginBottom:20}}>
        {[
          ["📅 Build Day",daysFromKickoff!==null?`Day ${daysFromKickoff}`:"Set kickoff →","#1e293b"],
          ["⏱ Days to Comp",daysToComp!==null?(daysToComp>0?`${daysToComp} days`:"🏁 Today!"):"Set date →","#7c3aed"],
          ["✅ Completed",`${done}/${total} tasks`,done===total&&total>0?"#059669":"#2563eb"],
          ["🔴 Overdue",`${overdue} tasks`,overdue>0?"#dc2626":"#64748b"],
          ["⚡ High Priority",`${highPending} pending`,highPending>0?"#d97706":"#64748b"],
        ].map(([label,val,color])=>(
          <div key={label} style={{background:"#fff",borderRadius:12,padding:"14px 16px",border:`2px solid ${color}20`,boxShadow:"0 1px 6px rgba(0,0,0,0.06)"}}>
            <div style={{fontSize:11,color:"#94a3b8",marginBottom:4,fontWeight:600}}>{label}</div>
            <div style={{fontSize:17,fontWeight:900,color}}>{val}</div>
          </div>
        ))}
      </div>

      {/* Season dates */}
      <div style={{background:"#fff",borderRadius:12,padding:"14px 16px",border:"1px solid #e2e8f0",marginBottom:16,display:"flex",gap:16,flexWrap:"wrap",alignItems:"center"}}>
        <div style={{fontWeight:700,fontSize:13,color:"#374151",flexShrink:0}}>📅 Season Dates:</div>
        <div style={{display:"flex",gap:6,alignItems:"center"}}>
          <span style={{fontSize:12,color:"#6b7280"}}>Kickoff:</span>
          <input type="date" value={kickoffDate} onChange={e=>{setKickoffDate(e.target.value);localStorage.setItem("hub-kickoff",e.target.value);}}
            style={{padding:"5px 8px",borderRadius:7,border:"1px solid #e2e8f0",fontSize:12,fontFamily:"inherit"}}/>
        </div>
        <div style={{display:"flex",gap:6,alignItems:"center"}}>
          <span style={{fontSize:12,color:"#6b7280"}}>Competition:</span>
          <input type="date" value={compDate} onChange={e=>{setCompDate(e.target.value);localStorage.setItem("hub-compdate",e.target.value);}}
            style={{padding:"5px 8px",borderRadius:7,border:"1px solid #e2e8f0",fontSize:12,fontFamily:"inherit"}}/>
        </div>
        {total>0 && (
          <div style={{display:"flex",alignItems:"center",gap:8,marginLeft:"auto"}}>
            <div style={{width:120,height:6,background:"#f1f5f9",borderRadius:3,overflow:"hidden"}}>
              <div style={{width:`${Math.round(done/total*100)}%`,height:"100%",background:"linear-gradient(90deg,#2563eb,#059669)",borderRadius:3,transition:"width 0.4s"}}/>
            </div>
            <span style={{fontSize:11,fontWeight:700,color:"#2563eb"}}>{Math.round(done/total*100)}% done</span>
          </div>
        )}
      </div>

      {/* Add task form */}
      <div style={{background:"#fff",borderRadius:14,border:"1px solid #e2e8f0",padding:16,marginBottom:16,boxShadow:"0 1px 6px rgba(0,0,0,0.04)"}}>
        <div style={{fontWeight:700,fontSize:13,marginBottom:12,color:"#374151"}}>+ New Task</div>
        <div style={{display:"flex",gap:8,marginBottom:10}}>
          <input value={newTask} onChange={e=>setNewTask(e.target.value)} onKeyDown={e=>e.key==="Enter"&&addTask()}
            placeholder="Task title (press Enter to add)..."
            style={{flex:1,padding:"9px 12px",borderRadius:9,border:"1.5px solid #e2e8f0",fontSize:13,fontFamily:"inherit",minWidth:0}}/>
          <button onClick={addTask} disabled={!newTask.trim()}
            style={{background:"#2563eb",color:"#fff",border:"none",borderRadius:9,padding:"9px 20px",cursor:"pointer",fontWeight:700,fontSize:13,fontFamily:"inherit",opacity:newTask.trim()?1:0.4,flexShrink:0}}>
            Add
          </button>
        </div>
        <div style={{display:"flex",gap:8,flexWrap:"wrap"}}>
          <select value={newCat} onChange={e=>setNewCat(e.target.value)}
            style={{padding:"7px 10px",borderRadius:8,border:"1px solid #e2e8f0",fontSize:12,fontFamily:"inherit",background:"#fff"}}>
            {CATS.map(c=><option key={c.id} value={c.id}>{c.label}</option>)}
          </select>
          <select value={newPriority} onChange={e=>setNewPriority(e.target.value)}
            style={{padding:"7px 10px",borderRadius:8,border:"1px solid #e2e8f0",fontSize:12,fontFamily:"inherit",background:"#fff"}}>
            {PRIORITIES.map(p=><option key={p.id} value={p.id}>{p.label}</option>)}
          </select>
          <input type="date" value={newDue} onChange={e=>setNewDue(e.target.value)}
            style={{padding:"7px 10px",borderRadius:8,border:"1px solid #e2e8f0",fontSize:12,fontFamily:"inherit"}}/>
          <input value={newAssign} onChange={e=>setNewAssign(e.target.value)} placeholder="Assigned to..."
            style={{flex:1,minWidth:100,padding:"7px 10px",borderRadius:8,border:"1px solid #e2e8f0",fontSize:12,fontFamily:"inherit"}}/>
        </div>
      </div>

      {/* Filters */}
      <div style={{display:"flex",gap:6,flexWrap:"wrap",marginBottom:12,alignItems:"center"}}>
        <span style={{fontSize:12,color:"#94a3b8",fontWeight:600}}>Filter:</span>
        {["all","done","pending"].map(s=>(
          <button key={s} onClick={()=>setFilterStatus(s)}
            style={{background:filterStatus===s?"#1e293b":"#fff",color:filterStatus===s?"#fff":"#6b7280",border:`1px solid ${filterStatus===s?"#1e293b":"#e2e8f0"}`,borderRadius:7,padding:"5px 12px",cursor:"pointer",fontWeight:700,fontSize:12,fontFamily:"inherit"}}>
            {s==="all"?"All":s==="done"?"✅ Done":"📋 Pending"}
          </button>
        ))}
        <div style={{width:1,height:20,background:"#e2e8f0",margin:"0 2px"}}/>
        <button onClick={()=>setFilterCat("all")}
          style={{background:filterCat==="all"?"#1e293b":"#fff",color:filterCat==="all"?"#fff":"#6b7280",border:`1px solid ${filterCat==="all"?"#1e293b":"#e2e8f0"}`,borderRadius:7,padding:"5px 12px",cursor:"pointer",fontWeight:700,fontSize:12,fontFamily:"inherit"}}>
          All
        </button>
        {CATS.map(c=>(
          <button key={c.id} onClick={()=>setFilterCat(c.id)}
            style={{background:filterCat===c.id?c.color:"#fff",color:filterCat===c.id?"#fff":"#6b7280",border:`1px solid ${filterCat===c.id?c.color:"#e2e8f0"}`,borderRadius:7,padding:"5px 10px",cursor:"pointer",fontWeight:700,fontSize:11,fontFamily:"inherit"}}>
            {c.label}
          </button>
        ))}
        {tasks.length>0&&(
          <button onClick={()=>{save(tasks.filter(t=>!t.done));}}
            style={{marginLeft:"auto",background:"#fef2f2",color:"#991b1b",border:"1px solid #fecaca",borderRadius:7,padding:"5px 10px",cursor:"pointer",fontWeight:700,fontSize:11,fontFamily:"inherit"}}>
            🗑 Clear Done
          </button>
        )}
      </div>

      {/* Task list */}
      {filtered.length===0?(
        <div style={{textAlign:"center",padding:40,color:"#94a3b8",background:"#fff",borderRadius:14,border:"1px solid #e2e8f0"}}>
          {total===0?"🎉 No tasks yet — add one above!":"✅ No tasks match the current filter."}
        </div>
      ):(
        <div style={{display:"flex",flexDirection:"column",gap:6}}>
          {filtered.map(t=>{
            const cat = catInfo(t.cat);
            const isOverdue = !t.done && t.due && new Date(t.due) < now;
            const daysLeft = t.due ? Math.ceil((new Date(t.due)-now)/(1000*60*60*24)) : null;
            return (
              <div key={t.id} style={{
                background:"#fff",borderRadius:12,
                border:`1px solid ${t.done?"#f1f5f9":isOverdue?"#fecaca":"#e2e8f0"}`,
                padding:"12px 14px",
                display:"flex",gap:12,alignItems:"center",
                opacity:t.done?0.55:1,
                boxShadow:"0 1px 4px rgba(0,0,0,0.04)",
                transition:"all 0.15s",
              }}>
                <button onClick={()=>toggleTask(t.id)}
                  style={{width:22,height:22,borderRadius:6,border:`2px solid ${t.done?"#10b981":cat.color}`,background:t.done?"#10b981":"transparent",
                    display:"flex",alignItems:"center",justifyContent:"center",cursor:"pointer",flexShrink:0,fontSize:13}}>
                  {t.done?"✓":""}
                </button>
                <div style={{flex:1,minWidth:0}}>
                  <div style={{fontWeight:t.done?400:700,fontSize:14,textDecoration:t.done?"line-through":"none",color:t.done?"#94a3b8":"#1e293b",whiteSpace:"nowrap",overflow:"hidden",textOverflow:"ellipsis"}}>
                    {t.priority==="high"&&!t.done&&<span style={{marginRight:4}}>🔴</span>}
                    {t.title}
                  </div>
                  <div style={{display:"flex",gap:8,marginTop:4,flexWrap:"wrap",alignItems:"center"}}>
                    <span style={{background:`${cat.color}18`,color:cat.color,borderRadius:5,padding:"2px 7px",fontSize:10,fontWeight:700}}>{cat.label}</span>
                    {t.assign&&<span style={{fontSize:11,color:"#6b7280"}}>👤 {t.assign}</span>}
                    {t.due&&(
                      <span style={{fontSize:11,fontWeight:600,color:isOverdue?"#dc2626":daysLeft<=3?"#d97706":"#6b7280"}}>
                        {isOverdue?"🔴 Overdue":daysLeft===0?"📅 Due today":`📅 ${daysLeft}d`}
                      </span>
                    )}
                    {t.done&&t.completedAt&&<span style={{fontSize:10,color:"#10b981"}}>✅ {new Date(t.completedAt).toLocaleDateString()}</span>}
