// ─── QUIZ COMPONENT ───────────────────────────────────────
function QuizView({ subjectId, level, username, onClose, onSaveScore }) {
  const questions = QUIZZES[subjectId]?.[level] || [];
  const [current, setCurrent] = useState(0);
  const [selected, setSelected] = useState(null);
  const [confirmed, setConfirmed] = useState(false);
  const [score, setScore] = useState(0);
  const [finished, setFinished] = useState(false);
  const [answers, setAnswers] = useState([]);
  const sub = SUBJECTS.find(s=>s.id===subjectId);
  const q = questions[current];
  const pct = Math.round(score/questions.length*100);

  function confirm() {
    if (selected===null) return;
    const correct = selected===q.ans;
    setConfirmed(true);
    setAnswers(prev=>[...prev,{correct,selected,q}]);
    if (correct) setScore(s=>s+1);
  }
  function next() {
    if (current+1>=questions.length) { setFinished(true); onSaveScore && onSaveScore(subjectId,level,score+(selected===q.ans?1:0),questions.length); return; }
    setCurrent(c=>c+1); setSelected(null); setConfirmed(false);
  }
  function restart() { setCurrent(0);setSelected(null);setConfirmed(false);setScore(0);setFinished(false);setAnswers([]); }

  if (questions.length===0) return <div style={{textAlign:"center",padding:40,color:"#9ca3af"}}>No quiz available for this level yet.</div>;

  if (finished) return (
    <div>
      <div style={{...S.card,textAlign:"center",padding:36}}>
        <div style={{fontSize:52,marginBottom:12}}>{pct>=80?"🏆":pct>=60?"✅":"📖"}</div>
        <div style={{fontWeight:900,fontSize:26,marginBottom:6}}>{pct>=80?"Excellent!":pct>=60?"Good job!":"Keep studying!"}</div>
        <div style={{fontSize:18,color:"#374151",marginBottom:4}}>{score}/{questions.length} correct</div>
        <div style={{fontSize:28,fontWeight:900,color:pct>=80?"#16a34a":pct>=60?"#d97706":"#dc2626",margin:"8px 0 16px"}}>{pct}%</div>
        <div style={{display:"flex",gap:10,justifyContent:"center",flexWrap:"wrap"}}>
          <button style={S.btn()} onClick={restart}>Retry Quiz</button>
          <button style={S.btnOut()} onClick={onClose}>Back</button>
        </div>
      </div>
      <div style={S.card}>
        <div style={{fontWeight:800,fontSize:16,marginBottom:14}}>Review Answers</div>
        {answers.map((a,i)=>(
          <div key={i} style={{borderRadius:10,padding:"12px 16px",marginBottom:10,background:a.correct?"#f0fdf4":"#fef2f2",border:`1.5px solid ${a.correct?"#bbf7d0":"#fecaca"}`}}>
            <div style={{fontWeight:700,fontSize:14,marginBottom:6}}>{a.correct?"✅":"❌"} {a.q.q}</div>
            <div style={{fontSize:13,color:"#374151"}}>Your answer: <b>{a.q.opts[a.selected]}</b></div>
            {!a.correct && <div style={{fontSize:13,color:"#16a34a",marginTop:2}}>Correct: <b>{a.q.opts[a.q.ans]}</b></div>}
          </div>
        ))}
      </div>
    </div>
  );

  return (
    <div>
      <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:16,flexWrap:"wrap",gap:8}}>
        <button style={S.btnOut()} onClick={onClose}>← Back</button>
        <div style={{display:"flex",gap:8,alignItems:"center"}}>
          <span style={{background:sub.color+"15",color:sub.color,padding:"3px 12px",borderRadius:20,fontSize:12,fontWeight:700}}>{sub.icon} {sub.name}</span>
          <span style={{background:"#f1f5f9",color:"#6b7280",padding:"3px 12px",borderRadius:20,fontSize:12,fontWeight:700}}>{level}</span>
        </div>
      </div>
      <div style={{background:"#e2e8f0",borderRadius:20,height:6,marginBottom:20,overflow:"hidden"}}>
        <div style={{background:`linear-gradient(90deg,${sub.color},${sub.color}cc)`,width:`${(current/questions.length)*100}%`,height:"100%",transition:"width 0.4s",borderRadius:20}}/>
      </div>
      <div style={S.card}>
        <div style={{display:"flex",justifyContent:"space-between",marginBottom:6}}>
          <span style={{color:"#9ca3af",fontSize:13}}>Question {current+1} of {questions.length}</span>
          <span style={{color:"#16a34a",fontWeight:700,fontSize:13}}>Score: {score}</span>
        </div>
        <div style={{fontWeight:800,fontSize:18,lineHeight:1.4,marginBottom:22,color:"#111"}}>{q.q}</div>
        <div style={{display:"flex",flexDirection:"column",gap:10}}>
          {q.opts.map((opt,i)=>{
            let bg="#f8fafc",border="1.5px solid #e2e8f0",color="#374151";
            if (selected===i&&!confirmed){bg=sub.color+"12";border=`1.5px solid ${sub.color}`;color=sub.color;}
            if (confirmed&&i===q.ans){bg="#f0fdf4";border="1.5px solid #86efac";color="#15803d";}
            if (confirmed&&selected===i&&i!==q.ans){bg="#fef2f2";border="1.5px solid #fca5a5";color="#dc2626";}
            return (
              <button key={i} onClick={()=>{if(!confirmed)setSelected(i);}}
                style={{background:bg,border,color,padding:"12px 16px",borderRadius:9,cursor:confirmed?"default":"pointer",textAlign:"left",fontWeight:selected===i?700:500,fontSize:14,transition:"all 0.15s",fontFamily:"inherit"}}>
                <span style={{fontWeight:700,marginRight:10,color:"#9ca3af"}}>{String.fromCharCode(65+i)}.</span>{opt}
              </button>
            );
          })}
        </div>
        <div style={{marginTop:20,display:"flex",gap:10}}>
          {!confirmed
            ? <button style={{...S.btn(sub.color),opacity:selected===null?0.5:1}} onClick={confirm} disabled={selected===null}>Confirm Answer</button>
            : <button style={S.btn()} onClick={next}>{current+1<questions.length?"Next Question →":"See Results"}</button>}
        </div>
      </div>
    </div>
  );
}

// ─── PLACEMENT QUIZ COMPONENT ─────────────────────────────
function PlacementQuiz({ user, onComplete }) {
  const [phase, setPhase] = useState("intro"); // intro | quiz | results
  const [questions, setQuestions] = useState([]);
  const [cur, setCur] = useState(0);
  const [selected, setSelected] = useState(null);
  const [confirmed, setConfirmed] = useState(false);
  const [catScores, setCatScores] = useState({Programming:{c:0,t:0},Mechanics:{c:0,t:0},Strategy:{c:0,t:0},Safety:{c:0,t:0}});
  const [totalScore, setTotalScore] = useState(0);
  const [role, setRole] = useState(null);
  const [answers, setAnswers] = useState([]);

  function startPlacement(){
    const qs=pickPlacementQuestions();
    setQuestions(qs);
    setCur(0);setSelected(null);setConfirmed(false);
    setCatScores({Programming:{c:0,t:0},Mechanics:{c:0,t:0},Strategy:{c:0,t:0},Safety:{c:0,t:0}});
    setTotalScore(0);setAnswers([]);
    setPhase("quiz");
  }

  function confirmAns(){
    if(selected===null) return;
    const q=questions[cur];
    const correct=selected===q.ans;
    setConfirmed(true);
    if(correct) setTotalScore(s=>s+1);
    setCatScores(prev=>{
      const n={...prev};
      n[q.cat]={c:n[q.cat].c+(correct?1:0),t:n[q.cat].t+1};
      return n;
    });
    setAnswers(prev=>[...prev,{q,selected,correct}]);
  }

  function nextQ(){
    if(cur+1>=questions.length){
      // finish
      const cs={...catScores};
      // catScores state may lag, recompute
      const finalCats={Programming:{c:0,t:0},Mechanics:{c:0,t:0},Strategy:{c:0,t:0},Safety:{c:0,t:0}};
      [...answers,{q:questions[cur],selected,correct:selected===questions[cur].ans}].forEach(({q,correct})=>{
        finalCats[q.cat].t++;
        if(correct) finalCats[q.cat].c++;
      });
      const r=calcPlacementRole(finalCats);
      const sc=answers.filter(a=>a.correct).length+(selected===questions[cur].ans?1:0);
      setRole(r);
      setTotalScore(sc);
      setCatScores(finalCats);
      setPhase("results");
      onComplete&&onComplete({role:r,score:sc,total:questions.length,catScores:finalCats,ts:Date.now()});
    } else {
      setCur(c=>c+1);setSelected(null);setConfirmed(false);
    }
  }

  if(phase==="intro") return (
    <div>
      <div style={{fontWeight:900,fontSize:24,marginBottom:8}}>🧪 Team Placement Assessment</div>
      <div style={{...S.card,background:"linear-gradient(135deg,#1e3a8a,#1d4ed8)",color:"#fff",marginBottom:20}}>
        <div style={{fontSize:18,fontWeight:800,marginBottom:8}}>Welcome to the Team Placement Quiz</div>
        <div style={{opacity:0.9,lineHeight:1.7,fontSize:14,marginBottom:16}}>
          This 40-question assessment covers Programming, Mechanics, Strategy, and Safety. Your scores determine which subteam you're best suited for — and are shared with the team admin to help with role assignments.
        </div>
        <div style={{display:"flex",gap:12,flexWrap:"wrap",marginBottom:16}}>
          {[["💻","Programming","16 Qs"],["🔧","Mechanics","16 Qs"],["📋","Strategy","4 Qs"],["🦺","Safety","4 Qs"]].map(([ic,lb,ct])=>(
            <div key={lb} style={{background:"rgba(255,255,255,0.15)",borderRadius:10,padding:"10px 16px",textAlign:"center",minWidth:90}}>
              <div style={{fontSize:22}}>{ic}</div>
              <div style={{fontWeight:700,fontSize:13}}>{lb}</div>
              <div style={{opacity:0.75,fontSize:11}}>{ct}</div>
            </div>
          ))}
        </div>
        <button style={{...S.btn("#fff"),color:"#1d4ed8",fontSize:15,padding:"11px 28px"}} onClick={startPlacement}>Begin Assessment →</button>
      </div>
    </div>
  );

  if(phase==="quiz"){
    const q=questions[cur];
    const catColors={Programming:"#1d4ed8",Mechanics:"#b45309",Strategy:"#15803d",Safety:"#7c3aed"};
    const pct=Math.round((cur/questions.length)*100);
    return (
      <div>
        <div style={{fontWeight:900,fontSize:20,marginBottom:12}}>🧪 Placement Assessment</div>
        <div style={{background:"#e2e8f0",borderRadius:20,height:8,marginBottom:6,overflow:"hidden"}}>
          <div style={{background:"linear-gradient(90deg,#1d4ed8,#7c3aed)",width:`${pct}%`,height:"100%",transition:"width 0.4s",borderRadius:20}}/>
        </div>
        <div style={{color:"#6b7280",fontSize:13,marginBottom:18}}>Question {cur+1} of {questions.length}</div>
        <div style={S.card}>
          <div style={{display:"flex",alignItems:"center",gap:8,marginBottom:14}}>
            <span style={{background:catColors[q.cat]+"15",color:catColors[q.cat],padding:"3px 12px",borderRadius:20,fontSize:12,fontWeight:700,textTransform:"uppercase"}}>
              {q.cat}
            </span>
          </div>
          <div style={{fontWeight:800,fontSize:17,lineHeight:1.5,marginBottom:22,color:"#111"}}>{q.q}</div>
          <div style={{display:"flex",flexDirection:"column",gap:10}}>
            {q.opts.map((opt,i)=>{
              let bg="#f8fafc",border="1.5px solid #e2e8f0",color="#374151";
              if(selected===i&&!confirmed){bg=catColors[q.cat]+"12";border=`1.5px solid ${catColors[q.cat]}`;color=catColors[q.cat];}
              if(confirmed&&i===q.ans){bg="#f0fdf4";border="1.5px solid #86efac";color="#15803d";}
              if(confirmed&&selected===i&&i!==q.ans){bg="#fef2f2";border="1.5px solid #fca5a5";color="#dc2626";}
              return (
                <button key={i} onClick={()=>{if(!confirmed)setSelected(i);}}
                  style={{background:bg,border,color,padding:"12px 16px",borderRadius:9,cursor:confirmed?"default":"pointer",textAlign:"left",fontWeight:selected===i?700:500,fontSize:14,fontFamily:"inherit",transition:"all 0.15s"}}>
                  <span style={{fontWeight:700,marginRight:10,color:"#9ca3af"}}>{String.fromCharCode(65+i)}.</span>{opt}
                </button>
              );
            })}
          </div>
          {confirmed && (
            <div style={{marginTop:14,padding:"10px 14px",borderRadius:8,background:selected===q.ans?"#f0fdf4":"#fff7ed",border:`1px solid ${selected===q.ans?"#86efac":"#fed7aa"}`,fontSize:13,color:selected===q.ans?"#15803d":"#9a3412",lineHeight:1.5}}>
              {selected===q.ans?"✅ Correct! ":"💡 "}{q.exp}
            </div>
          )}
          <div style={{marginTop:20}}>
            {!confirmed
              ? <button style={{...S.btn(catColors[q.cat]),opacity:selected===null?0.5:1}} onClick={confirmAns} disabled={selected===null}>Confirm Answer</button>
              : <button style={S.btn()} onClick={nextQ}>{cur+1<questions.length?"Next Question →":"See My Results"}</button>}
          </div>
        </div>
      </div>
    );
  }

  if(phase==="results"){
    const total=questions.length;
    const pct=Math.round((totalScore/total)*100);
    const passed=pct>=80;
    return (
      <div>
        <div style={{fontWeight:900,fontSize:24,marginBottom:16}}>🧪 Placement Results</div>
        {/* Banner */}
        <div style={{...S.card,background:pct>=80?"linear-gradient(135deg,#166534,#16a34a)":pct>=60?"linear-gradient(135deg,#92400e,#d97706)":"linear-gradient(135deg,#1e3a8a,#1d4ed8)",color:"#fff",textAlign:"center",padding:32,marginBottom:20}}>
          <div style={{fontSize:48,marginBottom:8}}>{pct>=80?"🏆":pct>=60?"✅":"📚"}</div>
          <div style={{fontSize:28,fontWeight:900,marginBottom:4}}>{totalScore} / {total}</div>
          <div style={{fontSize:20,opacity:0.9,marginBottom:8}}>{pct}% Correct</div>
          <div style={{opacity:0.85,fontSize:14}}>{pct>=80?"Excellent performance! Top marks.":pct>=60?"Good job — solid knowledge base.":"Keep studying! Every attempt helps you improve."}</div>
        </div>
        {/* Role recommendation */}
        {role && (
          <div style={{...S.card,borderLeft:`5px solid ${role.color}`,marginBottom:20}}>
            <div style={{fontSize:11,fontWeight:700,textTransform:"uppercase",color:"#9ca3af",letterSpacing:1,marginBottom:6}}>🎯 Recommended Team Role</div>
            <div style={{fontSize:20,fontWeight:900,color:role.color,marginBottom:6}}>{role.name}</div>
            <div style={{fontSize:14,color:"#4b5563",lineHeight:1.6}}>{role.desc}</div>
          </div>
        )}
        {/* Category breakdown */}
        <div style={S.card}>
          <div style={{fontWeight:800,fontSize:16,marginBottom:14}}>📊 Category Breakdown</div>
          <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:10,marginBottom:16}}>
            {Object.entries(catScores).filter(([,v])=>v.t>0).map(([cat,v])=>{
              const cp=Math.round((v.c/v.t)*100);
              const col=cp>=80?"#16a34a":cp>=60?"#d97706":"#dc2626";
              const bg=cp>=80?"#f0fdf4":cp>=60?"#fffbeb":"#fef2f2";
              const label=cp>=80?"Strong ✅":cp>=60?"Developing 🟡":"Needs work 🔴";
              return (
                <div key={cat} style={{background:bg,borderRadius:10,padding:"12px 14px",border:`1.5px solid ${col}30`}}>
                  <div style={{fontSize:11,fontWeight:700,textTransform:"uppercase",color:"#6b7280",marginBottom:4}}>{cat}</div>
                  <div style={{fontSize:18,fontWeight:900,color:col}}>{v.c}/{v.t} <span style={{fontSize:13,fontWeight:600}}>({cp}%)</span></div>
                  <div style={{fontSize:12,color:col,marginTop:2}}>{label}</div>
                </div>
              );
            })}
          </div>
          <div style={{borderTop:"1px solid #e2e8f0",paddingTop:14,display:"flex",gap:10,flexWrap:"wrap"}}>
            <button style={S.btn()} onClick={()=>{setPhase("intro");}}>Retake Assessment</button>
          </div>
        </div>
      </div>
    );
  }
  return null;
}

// ─── REGISTRATION GATE: FULL 40-QUESTION PLACEMENT TEST ──
const FULL_GATE_PASS_SCORE_DEFAULT = 25; // fallback if not set in storage

function FullRegistrationTest({ onPass, onBack, passScore }) {
  const gatePassScore = passScore || FULL_GATE_PASS_SCORE_DEFAULT;
  const [phase, setPhase] = useState("intro"); // intro | test | done
  const [questions] = useState(() => pickPlacementQuestions());
  const [cur, setCur] = useState(0);
  const [selected, setSelected] = useState(null);
  const [confirmed, setConfirmed] = useState(false);
  const [score, setScore] = useState(0);
  const [done, setDone] = useState(false);
  const [catScores, setCatScores] = useState({Programming:{c:0,t:0},Mechanics:{c:0,t:0},Strategy:{c:0,t:0},Safety:{c:0,t:0}});
  const [gateResult, setGateResult] = useState(null);

  // ── PRE-TEST INTRO PAGE ──
  if (phase === "intro") {
    return (
      <div>
        <div style={{textAlign:"center",marginBottom:20}}>
          <div style={{fontSize:48,marginBottom:8}}>🧠</div>
          <div style={{fontWeight:900,fontSize:20,marginBottom:6,color:"#1e293b"}}>Entry Knowledge Test</div>
          <div style={{fontSize:13,color:"#6b7280",lineHeight:1.6,maxWidth:380,margin:"0 auto"}}>
            Before creating your account, take this short placement test. It helps us understand your background and assigns you to the right learning track.
          </div>
        </div>
        <div style={{background:"#f8fafc",borderRadius:10,padding:16,marginBottom:16,border:"1px solid #e2e8f0"}}>
          <div style={{fontWeight:700,fontSize:13,marginBottom:10,color:"#374151"}}>📋 What to Expect</div>
          <div style={{display:"flex",flexDirection:"column",gap:7}}>
            {[
              ["🔢","40 questions across 4 categories"],
              ["⏱","No time limit — take your time"],
              ["📚","Topics: Programming, Mechanics, Strategy, Safety"],
              ["✅","Need "+gatePassScore+"/40 ("+Math.round(gatePassScore/40*100)+"%) to register"],
              ["🎯","Your score determines your learning track"],
            ].map(([ic,txt])=>(
              <div key={txt} style={{display:"flex",alignItems:"center",gap:8,fontSize:13,color:"#475569"}}>
                <span style={{fontSize:16}}>{ic}</span><span>{txt}</span>
              </div>
            ))}
          </div>
        </div>
        <div style={{background:"#fffbeb",border:"1px solid #fde68a",borderRadius:8,padding:"10px 14px",marginBottom:18,fontSize:12,color:"#92400e"}}>
          💡 <b>Tip:</b> Don't worry if you don't know everything! This test places you — it's not pass/fail for advanced knowledge. Study the lessons first if you want.
        </div>
        <div style={{display:"flex",gap:10}}>
          <button style={{flex:1,background:"linear-gradient(135deg,#1d4ed8,#7c3aed)",color:"#fff",border:"none",borderRadius:8,padding:"12px 0",fontWeight:800,fontSize:15,cursor:"pointer",fontFamily:"inherit"}}
            onClick={()=>setPhase("test")}>
            Start Test →
          </button>
          <button style={{background:"#f1f5f9",color:"#475569",border:"1px solid #e2e8f0",borderRadius:8,padding:"12px 18px",fontWeight:600,fontSize:14,cursor:"pointer",fontFamily:"inherit"}}
            onClick={onBack}>
            Cancel
          </button>
        </div>
      </div>
    );
  }

  const q = questions[cur];
  const catColors={Programming:"#1d4ed8",Mechanics:"#b45309",Strategy:"#15803d",Safety:"#7c3aed"};

  function confirm() {
    if (selected === null) return;
    const correct = selected === q.ans;
    setConfirmed(true);
    const newScore = correct ? score + 1 : score;
    if (correct) setScore(s => s + 1);
    setCatScores(prev => {
      const n = {...prev};
      n[q.cat] = {c: n[q.cat].c + (correct?1:0), t: n[q.cat].t + 1};
      return n;
    });
  }

  function next() {
    if (cur + 1 >= questions.length) {
      const finalScore = score + (selected === q.ans ? 1 : 0);
      const passed = finalScore >= gatePassScore;
      const finalCats = {...catScores};
      if (selected === q.ans) finalCats[q.cat] = {...finalCats[q.cat], c: finalCats[q.cat].c + 1, t: finalCats[q.cat].t + 1};
      else finalCats[q.cat] = {...finalCats[q.cat], t: finalCats[q.cat].t + 1};
      setGateResult({ score: finalScore, total: questions.length, passed, catScores: finalCats, role: calcPlacementRole(finalCats) });
      setDone(true);
    } else {
      setCur(c => c + 1); setSelected(null); setConfirmed(false);
    }
  }

  if (done && gateResult) {
    const { score: sc, total, passed, catScores: cs, role } = gateResult;
    const pct = Math.round(sc / total * 100);
    return (
      <div style={{ textAlign: "center" }}>
        <div style={{ fontSize: 48, marginBottom: 8 }}>{passed ? "🎉" : "📚"}</div>
        <div style={{ fontWeight: 900, fontSize: 20, marginBottom: 6, color: passed ? "#16a34a" : "#dc2626" }}>
          {passed ? "Test Passed! Welcome to the team." : "Not quite — keep studying!"}
        </div>
        <div style={{ fontSize: 24, fontWeight: 900, color: passed?"#16a34a":"#dc2626", marginBottom: 8 }}>
          {sc} / {total} ({pct}%)
        </div>
        <div style={{ fontSize: 13, color: "#6b7280", marginBottom: 12 }}>
          {passed ? `You scored ${pct}% — above the ${Math.round(gatePassScore/total*100)}% minimum.` : `You need ${gatePassScore}/${total} (${Math.round(gatePassScore/total*100)}%) to register. Study the learning modules and try again!`}
        </div>
        {passed && role && (
          <div style={{ marginBottom: 14, padding: "10px 14px", borderRadius: 10, background: role.color+"12", border: `1.5px solid ${role.color}`, textAlign: "left" }}>
            <div style={{ fontSize: 11, color: "#9ca3af", fontWeight: 700, textTransform: "uppercase", marginBottom: 3 }}>Your Best Area</div>
            <div style={{ fontWeight: 800, color: role.color, fontSize: 15 }}>{role.name}</div>
            <div style={{ fontSize: 12, color: "#6b7280", marginTop: 2 }}>{role.desc}</div>
          </div>
        )}
        <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 8, marginBottom: 16, textAlign: "left" }}>
          {Object.entries(cs).filter(([,v])=>v.t>0).map(([cat, v]) => {
            const cp = Math.round(v.c/v.t*100);
            const col = cp>=80?"#16a34a":cp>=60?"#d97706":"#dc2626";
            return (
              <div key={cat} style={{ background: col+"12", borderRadius: 8, padding: "8px 10px", border: `1px solid ${col}30` }}>
                <div style={{ fontSize: 10, fontWeight: 700, textTransform: "uppercase", color: "#6b7280" }}>{cat}</div>
                <div style={{ fontWeight: 900, color: col, fontSize: 15 }}>{v.c}/{v.t} ({cp}%)</div>
              </div>
            );
          })}
        </div>
        {passed ? (
          <button style={{ ...S.btn("#16a34a"), width: "100%", padding: "11px", fontSize: 15 }} onClick={() => onPass(gateResult)}>
            Create My Account →
          </button>
        ) : (
          <button style={{ ...S.btn(), width: "100%", padding: "11px", fontSize: 15 }} onClick={() => {
            setCur(0); setSelected(null); setConfirmed(false); setScore(0); setDone(false);
            setCatScores({Programming:{c:0,t:0},Mechanics:{c:0,t:0},Strategy:{c:0,t:0},Safety:{c:0,t:0}});
            setGateResult(null);
          }}>↺ Try Again</button>
        )}
        <button style={{ ...S.btnOut(), width: "100%", marginTop: 10, padding: "9px" }} onClick={onBack}>← Back to Login</button>
      </div>
    );
  }

  const pct = Math.round((cur / questions.length) * 100);
  return (
    <div>
      <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: 8 }}>
        <div style={{ fontWeight: 800, fontSize: 14, color: "#1d4ed8" }}>Entry Test</div>
        <div style={{ fontSize: 12, color: "#9ca3af" }}>{cur+1} / {questions.length} · Score: {score}</div>
      </div>
      <div style={{ background: "#e2e8f0", borderRadius: 20, height: 6, marginBottom: 14, overflow: "hidden" }}>
        <div style={{ background: "linear-gradient(90deg,#1d4ed8,#7c3aed)", width: `${pct}%`, height: "100%", transition: "width 0.4s", borderRadius: 20 }} />
      </div>
      <div style={{ display: "inline-block", background: catColors[q.cat]+"18", color: catColors[q.cat], padding: "2px 10px", borderRadius: 20, fontSize: 11, fontWeight: 700, marginBottom: 10, textTransform: "uppercase" }}>{q.cat}</div>
      <div style={{ fontWeight: 700, fontSize: 14, lineHeight: 1.5, marginBottom: 14, color: "#111" }}>{q.q}</div>
      <div style={{ display: "flex", flexDirection: "column", gap: 7, marginBottom: 14 }}>
        {q.opts.map((opt, i) => {
          let bg="#f8fafc",border="1.5px solid #e2e8f0",color="#374151";
          if(selected===i&&!confirmed){bg=catColors[q.cat]+"12";border=`1.5px solid ${catColors[q.cat]}`;color=catColors[q.cat];}
          if(confirmed&&i===q.ans){bg="#f0fdf4";border="1.5px solid #86efac";color="#15803d";}
          if(confirmed&&selected===i&&i!==q.ans){bg="#fef2f2";border="1.5px solid #fca5a5";color="#dc2626";}
          return (
            <button key={i} onClick={()=>{if(!confirmed)setSelected(i);}}
              style={{background:bg,border,color,padding:"9px 13px",borderRadius:8,cursor:confirmed?"default":"pointer",textAlign:"left",fontWeight:selected===i?700:500,fontSize:13,fontFamily:"inherit",transition:"all 0.15s"}}>
              <span style={{fontWeight:700,marginRight:8,color:"#9ca3af"}}>{String.fromCharCode(65+i)}.</span>{opt}
            </button>
          );
        })}
      </div>
      {confirmed && (
        <div style={{marginBottom:10,padding:"8px 12px",borderRadius:8,background:selected===q.ans?"#f0fdf4":"#fff7ed",border:`1px solid ${selected===q.ans?"#86efac":"#fed7aa"}`,fontSize:12,color:selected===q.ans?"#15803d":"#9a3412",lineHeight:1.5}}>
          {selected===q.ans?"✅ Correct! ":"💡 "}{q.exp}
        </div>
      )}
      {!confirmed
        ? <button style={{...S.btn(),width:"100%",opacity:selected===null?0.5:1}} onClick={confirm} disabled={selected===null}>Confirm Answer</button>
        : <button style={{...S.btn(),width:"100%"}} onClick={next}>{cur+1<questions.length?"Next Question →":"See My Score"}</button>}
      <div style={{marginTop:10,textAlign:"center"}}>
        <button onClick={onBack}
          style={{background:"none",border:"none",color:"#9ca3af",fontSize:12,cursor:"pointer",textDecoration:"underline",fontFamily:"inherit"}}>
          Cancel test
        </button>
      </div>
    </div>
  );
}

// ─── AUTH SCREEN ──────────────────────────────────────────
function AuthScreen({ onLogin }) {
  const [mode, setMode] = useState("login"); // login | gate | register | join-team | create-team
  const [username, setUsername] = useState("");
  const [password, setPassword] = useState("");
  const [name, setName] = useState("");
  const [teamCode, setTeamCode] = useState("");
  const [newTeamName, setNewTeamName] = useState("");
  const [newTeamCode, setNewTeamCode] = useState("");
  const [error, setError] = useState("");
  const [loading, setLoading] = useState(false);
  const [gateResult, setGateResult] = useState(null);
  const [gateThreshold, setGateThreshold] = useState(25);

  useEffect(() => {
    getGateThreshold().then(t => setGateThreshold(t));
  }, []);

  async function handleLogin() {
    if (!username.trim() || !password.trim()) { setError("Please fill in all fields."); return; }
    setLoading(true); setError("");
    if (username.trim() === ADMIN_USER) {
      const adminPass = await getAdminPass();
      if (password === adminPass) { onLogin({ username: "admin", name: "Admin", isAdmin: true }); return; }
      setError("Incorrect admin password."); setLoading(false); return;
    }
    const users = await storeGet("hub-users", true) || {};
    const u = users[username.toLowerCase().trim()];
    if (!u) { setError("Account not found. Please register first."); setLoading(false); return; }
    if (u.password !== password) { setError("Incorrect password."); setLoading(false); return; }
    onLogin({ ...u, username: username.toLowerCase().trim(), isAdmin: false });
    setLoading(false);
  }

  async function handleRegister() {
    if (!username.trim() || !password.trim() || !name.trim()) { setError("Please fill in all fields."); return; }
    if (username.toLowerCase().trim() === ADMIN_USER) { setError("That username is reserved."); return; }
    if (password.length < 4) { setError("Password must be at least 4 characters."); return; }
    setLoading(true); setError("");
    const users = await storeGet("hub-users", true) || {};
    if (users[username.toLowerCase().trim()]) { setError("Username already taken. Choose another."); setLoading(false); return; }
    const newUser = { name: name.trim(), password, joinedAt: Date.now(), done: {}, quizScores: {}, placementResult: gateResult };
    users[username.toLowerCase().trim()] = newUser;
    await storeSet("hub-users", users, true);
    onLogin({ ...newUser, username: username.toLowerCase().trim(), isAdmin: false });
    setLoading(false);
  }

  async function handleJoinTeam() {
    if (!teamCode.trim() || !username.trim() || !password.trim() || !name.trim()) { setError("Fill in all fields."); return; }
    setLoading(true); setError("");
    // Check team exists
    const teams = await storeGet("hub-teams", true) || {};
    const team = Object.values(teams).find(t => t.code === teamCode.trim().toUpperCase());
    if (!team) { setError("Team code not found. Check the code and try again."); setLoading(false); return; }
    const users = await storeGet("hub-users", true) || {};
    if (users[username.toLowerCase().trim()]) { setError("Username already taken."); setLoading(false); return; }
    const newUser = { name: name.trim(), password, joinedAt: Date.now(), done: {}, quizScores: {}, teamId: team.id, teamName: team.name, placementResult: gateResult };
    users[username.toLowerCase().trim()] = newUser;
    // Add user to team
    team.members = [...(team.members||[]), username.toLowerCase().trim()];
    teams[team.id] = team;
    await storeSet("hub-users", users, true);
    await storeSet("hub-teams", teams, true);
    onLogin({ ...newUser, username: username.toLowerCase().trim(), isAdmin: false });
    setLoading(false);
  }

  async function handleCreateTeam() {
    if (!newTeamName.trim() || !newTeamCode.trim() || !username.trim() || !password.trim() || !name.trim()) { setError("Fill in all fields."); return; }
    if (newTeamCode.length < 4) { setError("Team code must be at least 4 characters."); return; }
    setLoading(true); setError("");
    const teams = await storeGet("hub-teams", true) || {};
    const codeExists = Object.values(teams).some(t => t.code === newTeamCode.trim().toUpperCase());
    if (codeExists) { setError("That team code is already taken. Choose another."); setLoading(false); return; }
    const users = await storeGet("hub-users", true) || {};
    if (users[username.toLowerCase().trim()]) { setError("Username already taken."); setLoading(false); return; }
    const teamId = "team_" + Date.now();
    const team = { id: teamId, name: newTeamName.trim(), code: newTeamCode.trim().toUpperCase(), createdBy: username.toLowerCase().trim(), createdAt: Date.now(), members: [username.toLowerCase().trim()] };
    teams[teamId] = team;
    const newUser = { name: name.trim(), password, joinedAt: Date.now(), done: {}, quizScores: {}, teamId, teamName: team.name, isTeamAdmin: true, placementResult: gateResult };
    users[username.toLowerCase().trim()] = newUser;
    await storeSet("hub-teams", teams, true);
    await storeSet("hub-users", users, true);
    onLogin({ ...newUser, username: username.toLowerCase().trim(), isAdmin: false });
    setLoading(false);
  }

  const isGatePassed = !!gateResult;

  return (
    <div style={{ minHeight: "100vh", background: "linear-gradient(135deg,#0f172a 0%,#1e3a8a 50%,#1e1b4b 100%)", display: "flex", alignItems: "center", justifyContent: "center", padding: 20, fontFamily:"'Segoe UI',system-ui,sans-serif" }}>
      <div style={{ width: "100%", maxWidth: mode === "gate" ? 520 : 440 }}>
        <div style={{ textAlign: "center", marginBottom: 28 }}>
          <div style={{ fontSize: 48, marginBottom: 8 }}>⚡</div>
          <div style={{ fontSize: 28, fontWeight: 900, color: "#fff", letterSpacing: 0.5 }}>FIRST Hub</div>
          <div style={{ color: "#94a3b8", fontSize: 14, marginTop: 4 }}>FTC & FRC Learning Platform</div>
          <div style={{ marginTop: 10, padding: "6px 16px", background: "rgba(255,255,255,0.06)", borderRadius: 8, display:"inline-block", fontSize: 11, color: "#64748b" }}>
            Robotics Training Platform
          </div>
        </div>
        <div style={{ background: "#fff", borderRadius: 18, padding: 28, boxShadow: "0 25px 60px rgba(0,0,0,0.4)", maxHeight: "85vh", overflowY: "auto" }}>
          {mode === "gate" ? (
            <FullRegistrationTest
              onPass={(result) => { setGateResult(result); setMode("register"); }}
              onBack={() => { setMode("login"); setError(""); }}
              passScore={gateThreshold}
            />
          ) : mode === "join-team" ? (
            <div>
              <button onClick={() => { setMode("login"); setError(""); }} style={{ background: "none", border: "none", cursor: "pointer", color: "#1d4ed8", fontSize: 13, fontWeight: 600, marginBottom: 14, padding: 0 }}>← Back</button>
              <div style={{ fontWeight: 900, fontSize: 18, marginBottom: 4 }}>👥 Join a Team Account</div>
              <div style={{ fontSize: 13, color: "#6b7280", marginBottom: 16 }}>Enter the team code your team captain gave you, then create your personal login.</div>
              {!isGatePassed ? (
                <div style={{ padding: "12px 14px", background: "#fffbeb", borderRadius: 8, border: "1px solid #fde68a", fontSize: 13, color: "#92400e", marginBottom: 12 }}>
                  🧠 You need to <b>pass the entry test first</b> before joining a team.
                  <button style={{ ...S.btn(), display: "block", width: "100%", marginTop: 10 }} onClick={() => setMode("gate")}>Take Entry Test →</button>
                </div>
              ) : (
                <>
                  <div style={{ marginBottom: 12, padding: "8px 12px", background: "#f0fdf4", borderRadius: 8, border: "1px solid #86efac", fontSize: 12, color: "#15803d", fontWeight: 600 }}>✅ Test passed! Create your account below.</div>
                  <input style={S.inp} placeholder="Team Code (from your captain)" value={teamCode} onChange={e => setTeamCode(e.target.value.toUpperCase())} />
                  <input style={S.inp} placeholder="Your full name" value={name} onChange={e => setName(e.target.value)} />
                  <input style={S.inp} placeholder="Choose a username" value={username} onChange={e => setUsername(e.target.value)} />
                  <input style={S.inp} type="password" placeholder="Choose a password (4+ chars)" value={password} onChange={e => setPassword(e.target.value)} />
                  {error && <div style={{ color: "#dc2626", fontSize: 13, marginBottom: 10, padding: "8px 12px", background: "#fef2f2", borderRadius: 7, border: "1px solid #fecaca" }}>{error}</div>}
                  <button style={{ ...S.btn(), width: "100%", padding: "11px", fontSize: 15, opacity: loading ? 0.7 : 1 }} onClick={handleJoinTeam} disabled={loading}>
                    {loading ? "Joining…" : "Join Team →"}
                  </button>
                </>
              )}
            </div>
          ) : mode === "create-team" ? (
            <div>
              <button onClick={() => { setMode("login"); setError(""); }} style={{ background: "none", border: "none", cursor: "pointer", color: "#1d4ed8", fontSize: 13, fontWeight: 600, marginBottom: 14, padding: 0 }}>← Back</button>
              <div style={{ fontWeight: 900, fontSize: 18, marginBottom: 4 }}>🚀 Create a Team Account</div>
              <div style={{ fontSize: 13, color: "#6b7280", marginBottom: 16 }}>Set up a team space. You'll get a code to share with teammates so they can join your team.</div>
              {!isGatePassed ? (
                <div style={{ padding: "12px 14px", background: "#fffbeb", borderRadius: 8, border: "1px solid #fde68a", fontSize: 13, color: "#92400e", marginBottom: 12 }}>
                  🧠 You need to <b>pass the entry test first</b> before creating a team.
                  <button style={{ ...S.btn(), display: "block", width: "100%", marginTop: 10 }} onClick={() => setMode("gate")}>Take Entry Test →</button>
                </div>
              ) : (
                <>
                  <div style={{ marginBottom: 12, padding: "8px 12px", background: "#f0fdf4", borderRadius: 8, border: "1px solid #86efac", fontSize: 12, color: "#15803d", fontWeight: 600 }}>✅ Test passed! Set up your team below.</div>
                  <input style={S.inp} placeholder="Team name (e.g. 'Team 1234 — Iron Eagles')" value={newTeamName} onChange={e => setNewTeamName(e.target.value)} />
                  <input style={S.inp} placeholder="Team join code (e.g. EAGLE24) — share this with teammates" value={newTeamCode} onChange={e => setNewTeamCode(e.target.value.toUpperCase())} />
                  <div style={{ fontSize: 11, color: "#9ca3af", marginBottom: 10, marginTop: -6 }}>Team code: letters and numbers only, min 4 chars. You'll share this with teammates.</div>
                  <input style={S.inp} placeholder="Your full name" value={name} onChange={e => setName(e.target.value)} />
                  <input style={S.inp} placeholder="Choose a username" value={username} onChange={e => setUsername(e.target.value)} />
                  <input style={S.inp} type="password" placeholder="Choose a password (4+ chars)" value={password} onChange={e => setPassword(e.target.value)} />
                  {error && <div style={{ color: "#dc2626", fontSize: 13, marginBottom: 10, padding: "8px 12px", background: "#fef2f2", borderRadius: 7, border: "1px solid #fecaca" }}>{error}</div>}
                  <button style={{ ...S.btn("#15803d"), width: "100%", padding: "11px", fontSize: 15, opacity: loading ? 0.7 : 1 }} onClick={handleCreateTeam} disabled={loading}>
                    {loading ? "Creating…" : "Create Team →"}
                  </button>
                </>
              )}
            </div>
          ) : (
            <>
              {/* Login / Register tabs */}
              <div style={{ display: "flex", gap: 4, background: "#f1f5f9", borderRadius: 10, padding: 4, marginBottom: 20 }}>
                {[["login", "Sign In"], ["register", "Create Account"]].map(([m, l]) => (
                  <button key={m} onClick={() => { m === "register" ? (!isGatePassed ? setMode("gate") : setMode("register")) : (setMode("login"), setError("")); }}
                    style={{ flex: 1, padding: "8px 0", borderRadius: 8, border: "none", background: mode === m ? "#fff" : "transparent", fontWeight: mode === m ? 800 : 500, fontSize: 14, cursor: "pointer", color: mode === m ? "#1d4ed8" : "#6b7280", boxShadow: mode === m ? "0 2px 8px rgba(0,0,0,0.1)" : "none", fontFamily: "inherit", transition: "all 0.2s" }}>
                    {l}
                  </button>
                ))}
              </div>

              {mode === "register" && isGatePassed && (
                <div style={{ marginBottom: 12, padding: "8px 12px", background: "#f0fdf4", borderRadius: 8, border: "1px solid #86efac", fontSize: 12, color: "#15803d", fontWeight: 600 }}>
                  ✅ Entry test passed! Fill in your details to finish registering.
                </div>
              )}
              {mode === "register" && (
                <input style={S.inp} placeholder="Your full name" value={name} onChange={e => setName(e.target.value)} />
              )}
              <input style={S.inp} placeholder="Username" value={username} onChange={e => setUsername(e.target.value)}
                onKeyDown={e => e.key === "Enter" && (mode === "login" ? handleLogin() : handleRegister())} />
              <input style={S.inp} type="password" placeholder="Password" value={password} onChange={e => setPassword(e.target.value)}
                onKeyDown={e => e.key === "Enter" && (mode === "login" ? handleLogin() : handleRegister())} />

              {error && <div style={{ color: "#dc2626", fontSize: 13, marginBottom: 10, padding: "8px 12px", background: "#fef2f2", borderRadius: 7, border: "1px solid #fecaca" }}>{error}</div>}

              <button style={{ ...S.btn(), width: "100%", padding: "11px", fontSize: 15, opacity: loading ? 0.7 : 1 }} onClick={mode === "login" ? handleLogin : handleRegister} disabled={loading}>
                {loading ? "Loading…" : mode === "login" ? "Sign In →" : "Create Account →"}
              </button>

              {/* Team options */}
              <div style={{ marginTop: 14, borderTop: "1px solid #f1f5f9", paddingTop: 14 }}>
                <div style={{ fontSize: 12, color: "#9ca3af", textAlign: "center", marginBottom: 10 }}>— or —</div>
                <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 8 }}>
                  <button onClick={() => setMode("join-team")}
                    style={{ ...S.btnOut(), padding: "9px 8px", fontSize: 12, textAlign: "center" }}>
                    👥 Join a Team
                  </button>
                  <button onClick={() => setMode("create-team")}
                    style={{ ...S.btnOut("#15803d"), padding: "9px 8px", fontSize: 12, textAlign: "center", color:"#15803d" }}>
                    🚀 Create Team
                  </button>
                </div>
              </div>

              {mode === "login" && (
                <div style={{ marginTop: 12, padding: "8px 12px", background: "#fffbeb", borderRadius: 8, border: "1px solid #fde68a", fontSize: 11, color: "#92400e" }}>
                  🧠 New members must <b>pass the full 40-question entry test</b> to register. Click <b>Create Account</b> to begin.
                </div>
              )}
            </>
          )}
        </div>
      </div>
    </div>
  );
}

// ─── MY TEAM PANEL ───────────────────────────────────────
function MyTeamPanel({ user }) {
  const [team, setTeam] = useState(null);
  const [members, setMembers] = useState([]);
  const [loading, setLoading] = useState(true);
  const [newAchievements, setNewAchievements] = useState([]);
  const [achievementTimer, setAchievementTimer] = useState(null);
  const [copied, setCopied] = useState(false);

  useEffect(() => { loadTeam(); }, []);

  async function loadTeam() {
    const teams = await storeGet("hub-teams", true) || {};
    const t = teams[user.teamId];
    if (!t) { setLoading(false); return; }
    setTeam(t);
    // Load member details
    const users = await storeGet("hub-users", true) || {};
    const memberList = (t.members || []).map(uname => {
      const u = users[uname] || {};
      return { username: uname, name: u.name || uname, joinedAt: u.joinedAt, placement: u.placementResult, quizScores: u.quizScores || {} };
    });
    setMembers(memberList);
    setLoading(false);
  }

  function copyCode() {
    if (team?.code) {
      navigator.clipboard?.writeText(team.code).catch(()=>{});
      setCopied(true);
      setTimeout(() => setCopied(false), 2000);
    }
  }

  if (loading) return <div style={{ padding: 40, textAlign: "center", color: "#9ca3af" }}>Loading team…</div>;
  if (!team) return <div style={{ ...S.card, textAlign: "center", padding: 40 }}>Team not found.</div>;

  const roleCounts = {};
  members.forEach(m => {
    const role = m.placement?.role?.name || "Unassigned";
    roleCounts[role] = (roleCounts[role] || 0) + 1;
  });

  return (
    <div>
      {/* Team header */}
      <div style={{ ...S.card, background: "linear-gradient(135deg,#1e3a8a,#1d4ed8)", color: "#fff", marginBottom: 16 }}>
        <div style={{ display: "flex", alignItems: "flex-start", justifyContent: "space-between", flexWrap: "wrap", gap: 12 }}>
          <div>
            <div style={{ fontSize: 11, opacity: 0.7, textTransform: "uppercase", letterSpacing: 1, marginBottom: 4 }}>Your Team</div>
            <div style={{ fontSize: 26, fontWeight: 900, marginBottom: 4 }}>👥 {team.name}</div>
            <div style={{ opacity: 0.8, fontSize: 14 }}>{members.length} member{members.length !== 1 ? "s" : ""}</div>
          </div>
          {user.isTeamAdmin && (
            <div style={{ background: "rgba(255,255,255,0.12)", borderRadius: 12, padding: "14px 18px", textAlign: "center" }}>
              <div style={{ fontSize: 11, opacity: 0.7, marginBottom: 4, textTransform: "uppercase", letterSpacing: 1 }}>Team Join Code</div>
              <div style={{ fontFamily: "monospace", fontSize: 24, fontWeight: 900, letterSpacing: 3 }}>{team.code}</div>
              <button onClick={copyCode} style={{ ...S.btn("#fff"), color: "#1d4ed8", fontSize: 12, padding: "5px 14px", marginTop: 8 }}>
                {copied ? "✅ Copied!" : "📋 Copy Code"}
              </button>
              <div style={{ fontSize: 11, opacity: 0.6, marginTop: 6 }}>Share this code with teammates</div>
            </div>
          )}
        </div>
      </div>

      {/* Role breakdown */}
      {Object.keys(roleCounts).length > 0 && (
        <div style={{ ...S.card, marginBottom: 16 }}>
          <div style={{ fontWeight: 800, fontSize: 16, marginBottom: 12 }}>📊 Team Breakdown by Role</div>
          <div style={{ display: "flex", gap: 10, flexWrap: "wrap" }}>
            {Object.entries(roleCounts).map(([role, count]) => {
              const colors = { "Programming Specialist": "#1d4ed8", "Mechanical Specialist": "#b45309", "Strategy Lead": "#15803d", "Safety & Operations Lead": "#7c3aed", Unassigned: "#6b7280" };
              const col = colors[role] || "#6b7280";
              return (
                <div key={role} style={{ background: col + "12", border: `1.5px solid ${col}30`, borderRadius: 10, padding: "10px 16px", textAlign: "center" }}>
                  <div style={{ fontWeight: 900, fontSize: 20, color: col }}>{count}</div>
                  <div style={{ fontSize: 12, color: "#6b7280", marginTop: 2, maxWidth: 100 }}>{role}</div>
                </div>
              );
            })}
          </div>
        </div>
      )}

      {/* Members list */}
      <div style={{ ...S.card }}>
        <div style={{ fontWeight: 800, fontSize: 16, marginBottom: 14 }}>👤 Members</div>
        <div style={{ display: "flex", flexDirection: "column", gap: 10 }}>
          {members.map(m => {
            const role = m.placement?.role;
            const score = m.placement ? Math.round(m.placement.score / m.placement.total * 100) : null;
            return (
              <div key={m.username} style={{ display: "flex", alignItems: "center", gap: 12, padding: "12px 14px", background: "#f8fafc", borderRadius: 10, border: "1px solid #f1f5f9" }}>
                <div style={{ width: 40, height: 40, background: `hsl(${m.username.charCodeAt(0)*13%360},60%,50%)`, borderRadius: 10, display: "flex", alignItems: "center", justifyContent: "center", fontWeight: 900, color: "#fff", fontSize: 16, flexShrink: 0 }}>
                  {m.name?.charAt(0)?.toUpperCase()}
                </div>
                <div style={{ flex: 1 }}>
                  <div style={{ fontWeight: 700, fontSize: 14, color: "#1e293b" }}>{m.name} {m.username === team.createdBy && <span style={{ fontSize: 10, background: "#fef9c3", color: "#a16207", padding: "1px 6px", borderRadius: 4, fontWeight: 700 }}>CAPTAIN</span>}</div>
                  <div style={{ fontSize: 12, color: "#9ca3af" }}>@{m.username} · Joined {new Date(m.joinedAt).toLocaleDateString()}</div>
                </div>
                {role ? (
                  <div style={{ background: role.color + "12", border: `1px solid ${role.color}30`, borderRadius: 8, padding: "4px 10px", textAlign: "center" }}>
                    <div style={{ fontWeight: 700, fontSize: 12, color: role.color }}>{role.name}</div>
                    <div style={{ fontSize: 10, color: "#9ca3af" }}>{score}%</div>
                  </div>
                ) : (
                  <div style={{ fontSize: 11, color: "#9ca3af", fontStyle: "italic" }}>Not placed yet</div>
                )}
              </div>
            );
          })}
        </div>
      </div>

      {/* Non-admin: how to invite */}
      {!user.isTeamAdmin && (
        <div style={{ ...S.card, background: "#f0f9ff", border: "1px solid #bae6fd" }}>
          <div style={{ fontWeight: 700, color: "#0369a1", marginBottom: 4 }}>💡 Invite teammates</div>
          <div style={{ fontSize: 13, color: "#0c4a6e" }}>Ask your team captain for the join code. Teammates can use it when registering a new account by clicking <b>"Join a Team"</b> on the login screen.</div>
        </div>
      )}
    </div>
  );
}

// ─── GROUP CHAT COMPONENT ─────────────────────────────────
const CHAT_CHANNELS = [
  { id: "general", name: "# general", desc: "General team chat", color: "#1d4ed8" },
  { id: "programming", name: "# programming", desc: "Code help & discussion", color: "#b45309" },
  { id: "build", name: "# build", desc: "Mechanical & build questions", color: "#dc2626" },
  { id: "strategy", name: "# strategy", desc: "Match strategy & scouting", color: "#15803d" },
  { id: "media", name: "# media", desc: "Share photos, videos & files", color: "#7c3aed" },
];

function GroupChat({ user }) {
  const [channel, setChannel] = useState("general");
  const [messages, setMessages] = useState({});
  const [text, setText] = useState("");
  const [file, setFile] = useState(null);
  const [filePreview, setFilePreview] = useState(null);
  const [loading, setLoading] = useState(true);
  const [sending, setSending] = useState(false);
  const [error, setError] = useState("");
  const messagesEndRef = useRef(null);
  const fileInputRef = useRef(null);
  const pollRef = useRef(null);

  useEffect(() => {
    loadMessages();
    pollRef.current = setInterval(loadMessages, 5000);
    return () => clearInterval(pollRef.current);
  }, []);

  useEffect(() => {
    messagesEndRef.current?.scrollIntoView({ behavior: "smooth" });
  }, [messages, channel]);

  async function loadMessages() {
    try {
      const data = await storeGet("chat-messages", true);
      if (data) setMessages(data);
    } catch (e) {}
    setLoading(false);
  }

  function handleFileSelect(e) {
    const f = e.target.files?.[0];
    if (!f) return;
    if (f.size > 4 * 1024 * 1024) { setError("File must be under 4MB"); return; }
    const reader = new FileReader();
    reader.onload = ev => {
      setFile({ name: f.name, type: f.type, data: ev.target.result, size: f.size });
      setFilePreview(ev.target.result);
    };
    reader.readAsDataURL(f);
  }

  async function sendMessage() {
    if (!text.trim() && !file) return;
    setSending(true);
    try {
      const current = await storeGet("chat-messages", true) || {};
      if (!current[channel]) current[channel] = [];
      const msg = {
        id: Date.now().toString(),
        author: user.name,
        username: user.username,
        text: text.trim(),
        ts: Date.now(),
        file: file || null,
      };
      current[channel] = [...current[channel], msg].slice(-200); // keep last 200 per channel
      await storeSet("chat-messages", current, true);
      setMessages(current);
      setText("");
      setFile(null);
      setFilePreview(null);
      if (fileInputRef.current) fileInputRef.current.value = "";
    } catch (e) {}
    setSending(false);
  }

  const channelMsgs = messages[channel] || [];
  const ch = CHAT_CHANNELS.find(c => c.id === channel);

  function renderFile(f, compact = false) {
    if (!f) return null;
    const isImage = f.type?.startsWith("image/");
    const isVideo = f.type?.startsWith("video/");
    const isAudio = f.type?.startsWith("audio/");

    if (isImage) return (
      <a href={f.data} target="_blank" rel="noopener noreferrer">
        <img src={f.data} alt={f.name} style={{ maxWidth: compact ? 180 : 320, maxHeight: compact ? 120 : 240, borderRadius: 8, marginTop: 6, display: "block", cursor: "pointer" }} />
      </a>
    );
    if (isVideo) return (
      <video controls src={f.data} style={{ maxWidth: compact ? 240 : 400, borderRadius: 8, marginTop: 6, display: "block" }} />
    );
    if (isAudio) return (
      <audio controls src={f.data} style={{ marginTop: 6, display: "block" }} />
    );
    return (
      <a href={f.data} download={f.name}
        style={{ display: "inline-flex", alignItems: "center", gap: 6, marginTop: 6, padding: "6px 12px", background: "#f1f5f9", borderRadius: 8, textDecoration: "none", color: "#1d4ed8", fontSize: 13, fontWeight: 600 }}>
        📎 {f.name} <span style={{ color: "#9ca3af", fontWeight: 400 }}>({Math.round((f.size || 0) / 1024)}KB)</span>
      </a>
    );
  }

  return (
    <div>
    {error && (
      <div style={{background:"#fef2f2",border:"1px solid #fecaca",borderRadius:8,padding:"8px 12px",marginBottom:10,color:"#991b1b",fontSize:13,display:"flex",justifyContent:"space-between",alignItems:"center"}}>
        ⚠️ {error}
        <button onClick={()=>setError("")} style={{background:"none",border:"none",cursor:"pointer",color:"#991b1b",fontSize:14,padding:0}}>✕</button>
      </div>
    )}
    <div style={{ display: "grid", gridTemplateColumns: "220px 1fr", gap: 0, height: "calc(100vh - 120px)", minHeight: 500, background: "#fff", borderRadius: 16, overflow: "hidden", boxShadow: "0 4px 24px rgba(0,0,0,0.08)", border: "1px solid #e2e8f0" }}>
      {/* Sidebar */}
      <div style={{ background: "#1e293b", display: "flex", flexDirection: "column" }}>
        <div style={{ padding: "16px 14px 12px", borderBottom: "1px solid #334155" }}>
          <div style={{ fontWeight: 900, fontSize: 13, color: "#f1f5f9", letterSpacing: 0.5 }}>⚡ FIRST Hub Chat</div>
          <div style={{ fontSize: 11, color: "#64748b", marginTop: 2 }}>Team communication</div>
        </div>
        <div style={{ padding: "10px 8px", flex: 1, overflowY: "auto" }}>
          <div style={{ fontSize: 10, fontWeight: 700, color: "#475569", textTransform: "uppercase", letterSpacing: 1, padding: "4px 8px", marginBottom: 4 }}>Channels</div>
          {CHAT_CHANNELS.map(c => (
            <button key={c.id} onClick={() => setChannel(c.id)}
              style={{ width: "100%", background: channel === c.id ? "#334155" : "transparent", border: "none", borderRadius: 6, padding: "7px 10px", cursor: "pointer", textAlign: "left", marginBottom: 1, transition: "background 0.15s" }}>
              <div style={{ fontWeight: channel === c.id ? 700 : 500, fontSize: 13, color: channel === c.id ? "#f1f5f9" : "#94a3b8" }}>{c.name}</div>
              <div style={{ fontSize: 10, color: "#475569", marginTop: 1, display: channel === c.id ? "block" : "none" }}>{c.desc}</div>
            </button>
          ))}
        </div>
        <div style={{ padding: "12px 14px", borderTop: "1px solid #334155", display: "flex", alignItems: "center", gap: 8 }}>
          <div style={{ width: 28, height: 28, background: "linear-gradient(135deg,#1d4ed8,#7c3aed)", borderRadius: 7, display: "flex", alignItems: "center", justifyContent: "center", fontWeight: 900, color: "#fff", fontSize: 12, flexShrink: 0 }}>
            {user.name?.charAt(0)?.toUpperCase()}
          </div>
          <div style={{ minWidth: 0 }}>
            <div style={{ fontWeight: 700, fontSize: 12, color: "#f1f5f9", overflow: "hidden", textOverflow: "ellipsis", whiteSpace: "nowrap" }}>{user.name}</div>
            <div style={{ fontSize: 10, color: "#16a34a" }}>● Online</div>
          </div>
        </div>
      </div>

      {/* Main chat area */}
      <div style={{ display: "flex", flexDirection: "column", background: "#fff" }}>
        {/* Channel header */}
        <div style={{ padding: "12px 18px", borderBottom: "1px solid #f1f5f9", display: "flex", alignItems: "center", gap: 10 }}>
          <div style={{ width: 10, height: 10, background: ch?.color || "#1d4ed8", borderRadius: "50%" }} />
          <div style={{ fontWeight: 800, fontSize: 16 }}>{ch?.name}</div>
          <div style={{ color: "#9ca3af", fontSize: 13, marginLeft: 4 }}>{ch?.desc}</div>
          <div style={{ marginLeft: "auto", fontSize: 12, color: "#9ca3af" }}>{channelMsgs.length} messages</div>
        </div>

        {/* Messages */}
        <div style={{ flex: 1, overflowY: "auto", padding: "16px 18px", display: "flex", flexDirection: "column", gap: 2 }}>
          {loading && <div style={{ textAlign: "center", color: "#9ca3af", padding: 30 }}>Loading messages…</div>}
          {!loading && channelMsgs.length === 0 && (
            <div style={{ textAlign: "center", color: "#9ca3af", padding: 40 }}>
              <div style={{ fontSize: 32, marginBottom: 8 }}>💬</div>
              <div style={{ fontWeight: 600 }}>No messages yet</div>
              <div style={{ fontSize: 13, marginTop: 4 }}>Be the first to say something in {ch?.name}!</div>
            </div>
          )}
          {channelMsgs.map((msg, i) => {
            const isMe = msg.username === user.username;
            const showHeader = i === 0 || channelMsgs[i - 1]?.username !== msg.username;
            return (
              <div key={msg.id} style={{ display: "flex", gap: 10, marginTop: showHeader && i > 0 ? 10 : 2, flexDirection: isMe ? "row-reverse" : "row", alignItems: "flex-start" }}>
                {showHeader && !isMe && (
                  <div style={{ width: 32, height: 32, background: `hsl(${msg.username?.charCodeAt(0) * 13 % 360},60%,50%)`, borderRadius: 8, display: "flex", alignItems: "center", justifyContent: "center", fontWeight: 900, color: "#fff", fontSize: 13, flexShrink: 0, marginTop: 2 }}>
                    {msg.author?.charAt(0)?.toUpperCase()}
                  </div>
                )}
                {!showHeader && !isMe && <div style={{ width: 32, flexShrink: 0 }} />}
                <div style={{ maxWidth: "72%", display: "flex", flexDirection: "column", alignItems: isMe ? "flex-end" : "flex-start" }}>
                  {showHeader && (
                    <div style={{ display: "flex", gap: 8, alignItems: "baseline", marginBottom: 3 }}>
                      <span style={{ fontWeight: 700, fontSize: 13, color: isMe ? "#1d4ed8" : "#374151" }}>{isMe ? "You" : msg.author}</span>
                      <span style={{ fontSize: 10, color: "#9ca3af" }}>{new Date(msg.ts).toLocaleTimeString([], { hour: "2-digit", minute: "2-digit" })}</span>
                    </div>
                  )}
                  <div style={{ background: isMe ? "#1d4ed8" : "#f1f5f9", color: isMe ? "#fff" : "#1e293b", padding: "8px 12px", borderRadius: isMe ? "12px 12px 4px 12px" : "12px 12px 12px 4px", fontSize: 14, lineHeight: 1.5, wordBreak: "break-word" }}>
                    {msg.text && <div>{msg.text}</div>}
                    {msg.file && renderFile(msg.file)}
                  </div>
                </div>
              </div>
            );
          })}
          <div ref={messagesEndRef} />
        </div>

        {/* File preview */}
        {filePreview && file && (
          <div style={{ padding: "8px 18px", background: "#f8fafc", borderTop: "1px solid #e2e8f0", display: "flex", alignItems: "center", gap: 10 }}>
            <div style={{ fontSize: 12, color: "#374151", fontWeight: 600, flex: 1 }}>📎 {file.name}</div>
            {file.type?.startsWith("image/") && <img src={filePreview} alt="" style={{ height: 40, borderRadius: 6 }} />}
            {file.type?.startsWith("video/") && <div style={{ fontSize: 11, color: "#7c3aed", fontWeight: 600 }}>🎥 Video ready</div>}
            <button onClick={() => { setFile(null); setFilePreview(null); if (fileInputRef.current) fileInputRef.current.value = ""; }}
              style={{ background: "none", border: "none", cursor: "pointer", color: "#dc2626", fontWeight: 700, fontSize: 16 }}>✕</button>
          </div>
        )}

        {/* Input bar */}
        <div style={{ padding: "12px 18px", borderTop: "1px solid #f1f5f9", display: "flex", gap: 10, alignItems: "flex-end", background: "#fff" }}>
          <label style={{ cursor: "pointer", padding: "8px 10px", borderRadius: 8, background: "#f1f5f9", border: "1.5px solid #e2e8f0", display: "flex", alignItems: "center", justifyContent: "center", flexShrink: 0, title: "Attach file" }}>
            📎
            <input ref={fileInputRef} type="file" style={{ display: "none" }} accept="image/*,video/*,audio/*,.pdf,.doc,.docx,.txt,.zip,.py,.java,.cpp,.h" onChange={handleFileSelect} />
          </label>
          <textarea
            value={text}
            onChange={e => setText(e.target.value)}
            onKeyDown={e => { if (e.key === "Enter" && !e.shiftKey) { e.preventDefault(); sendMessage(); } }}
            placeholder={`Message ${ch?.name}… (Enter to send, Shift+Enter for newline)`}
            style={{ flex: 1, padding: "9px 14px", borderRadius: 10, border: "1.5px solid #e2e8f0", fontSize: 14, fontFamily: "inherit", outline: "none", resize: "none", minHeight: 40, maxHeight: 120, lineHeight: 1.5, background: "#f8fafc" }}
            rows={1}
          />
          <button onClick={sendMessage} disabled={sending || (!text.trim() && !file)}
            style={{ ...S.btn(), padding: "9px 18px", opacity: (sending || (!text.trim() && !file)) ? 0.5 : 1, flexShrink: 0 }}>
            {sending ? "⏳" : "Send"}
          </button>
        </div>
      </div>
    </div>
  </div>
  );
}

// ─── MEDIA HUB COMPONENT ──────────────────────────────────
function MediaHub({ user }) {
  const [media, setMedia] = useState([]);
  const [loading, setLoading] = useState(true);
  const [uploading, setUploading] = useState(false);
  const [ytUrl, setYtUrl] = useState("");
  const [ytTitle, setYtTitle] = useState("");
  const [filter, setFilter] = useState("all");
  const [lightbox, setLightbox] = useState(null);
  const [uploadError, setUploadError] = useState("");
  const fileInputRef = useRef(null);

  useEffect(() => { loadMedia(); }, []);

  async function loadMedia() {
    const data = await storeGet("hub-media", true);
    if (data) setMedia(data);
    setLoading(false);
  }

  async function handleFileUpload(e) {
    const files = e.target.files;
    if (!files?.length) return;
    setUploading(true);
    const newItems = [];
    for (const f of Array.from(files).slice(0, 5)) {
      if (f.size > 4 * 1024 * 1024) { setUploadError(`${f.name} is over 4MB — skipped`); continue; }
      const data = await new Promise((res, rej) => {
        const r = new FileReader();
        r.onload = ev => res(ev.target.result);
        r.onerror = rej;
        r.readAsDataURL(f);
      });
      newItems.push({
        id: Date.now().toString() + Math.random().toString(36).slice(2),
        type: f.type.startsWith("image/") ? "image" : f.type.startsWith("video/") ? "video" : "file",
        name: f.name,
        mimeType: f.type,
        data,
        size: f.size,
        author: user.name,
        username: user.username,
        ts: Date.now(),
      });
    }
    if (newItems.length) {
      const current = await storeGet("hub-media", true) || [];
      const updated = [...newItems, ...current].slice(0, 100); // keep last 100
      await storeSet("hub-media", updated, true);
      setMedia(updated);
    }
    setUploading(false);
    if (fileInputRef.current) fileInputRef.current.value = "";
  }

  function extractYtId(url) {
    const m = url.match(/(?:youtu\.be\/|v=|embed\/)([A-Za-z0-9_-]{11})/);
    return m ? m[1] : null;
  }

  async function addYoutube() {
    const ytId = extractYtId(ytUrl);
    if (!ytId) { setUploadError("Invalid YouTube URL. Use: youtube.com/watch?v=..."); return; }
    const newItem = {
      id: Date.now().toString(),
      type: "youtube",
      name: ytTitle.trim() || "YouTube Video",
      ytId,
      author: user.name,
      username: user.username,
      ts: Date.now(),
    };
    const current = await storeGet("hub-media", true) || [];
    const updated = [newItem, ...current].slice(0, 100);
    await storeSet("hub-media", updated, true);
    setMedia(updated);
    setYtUrl(""); setYtTitle("");
  }

  async function deleteItem(id) {
    const updated = media.filter(m => m.id !== id);
    await storeSet("hub-media", updated, true);
    setMedia(updated);
  }

  const filtered = filter === "all" ? media : media.filter(m => m.type === filter);

  return (
    <div>
      <div style={{ fontWeight: 900, fontSize: 24, marginBottom: 8 }}>🎬 Media Hub</div>
      <div style={{ color: "#6b7280", marginBottom: 20, fontSize: 14 }}>Share photos, videos, YouTube links and files with your team. Shared with everyone.</div>

      {/* Upload area */}
      <div style={{ ...S.card, marginBottom: 20 }}>
        <div style={{ fontWeight: 800, fontSize: 16, marginBottom: 14 }}>📤 Upload / Share</div>
        {uploadError && (
          <div style={{background:"#fef2f2",border:"1px solid #fecaca",borderRadius:8,padding:"8px 12px",marginBottom:12,color:"#991b1b",fontSize:13,display:"flex",justifyContent:"space-between",alignItems:"center"}}>
            ⚠️ {uploadError}
            <button onClick={()=>setUploadError("")} style={{background:"none",border:"none",cursor:"pointer",color:"#991b1b",fontSize:14,padding:0}}>✕</button>
          </div>
        )}
        <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 14, marginBottom: 14 }}>
          {/* File upload */}
          <label style={{ display: "flex", flexDirection: "column", alignItems: "center", justifyContent: "center", padding: 24, borderRadius: 12, border: "2px dashed #e2e8f0", cursor: "pointer", background: "#f8fafc", transition: "all 0.2s", gap: 8 }}
            onMouseEnter={e => { e.currentTarget.style.borderColor = "#1d4ed8"; e.currentTarget.style.background = "#eff6ff"; }}
            onMouseLeave={e => { e.currentTarget.style.borderColor = "#e2e8f0"; e.currentTarget.style.background = "#f8fafc"; }}>
            <div style={{ fontSize: 32 }}>{uploading ? "⏳" : "📁"}</div>
            <div style={{ fontWeight: 700, fontSize: 14, color: "#1d4ed8" }}>{uploading ? "Uploading…" : "Click to upload files"}</div>
            <div style={{ fontSize: 12, color: "#9ca3af", textAlign: "center" }}>Images, videos, PDFs, code files<br />Up to 4MB per file, up to 5 at once</div>
            <input ref={fileInputRef} type="file" multiple accept="image/*,video/*,audio/*,.pdf,.doc,.docx,.txt,.zip,.py,.java,.cpp,.h" style={{ display: "none" }} onChange={handleFileUpload} />
          </label>

          {/* YouTube embed */}
          <div style={{ display: "flex", flexDirection: "column", gap: 10 }}>
            <div style={{ fontWeight: 700, fontSize: 14, color: "#dc2626" }}>▶ Share YouTube Video</div>
            <input style={S.inp} placeholder="YouTube URL (e.g. youtube.com/watch?v=...)" value={ytUrl} onChange={e => setYtUrl(e.target.value)} />
            <input style={{ ...S.inp, marginBottom: 0 }} placeholder="Title (optional)" value={ytTitle} onChange={e => setYtTitle(e.target.value)} />
            <button style={S.btn("#dc2626")} onClick={addYoutube} disabled={!ytUrl.trim()}>Add Video</button>
          </div>
        </div>
      </div>

      {/* Filter bar */}
      <div style={{ display: "flex", gap: 8, marginBottom: 16, flexWrap: "wrap" }}>
        {[["all", "🌐 All"], ["image", "🖼 Images"], ["video", "🎥 Videos"], ["youtube", "▶ YouTube"], ["file", "📎 Files"]].map(([id, lbl]) => (
          <button key={id} onClick={() => setFilter(id)}
            style={{ ...S.chip(filter === id), padding: "6px 14px", fontSize: 13 }}>
            {lbl}
          </button>
        ))}
      </div>

      {/* Media grid */}
      {loading && <div style={{ textAlign: "center", color: "#9ca3af", padding: 40 }}>Loading media…</div>}
      {!loading && filtered.length === 0 && (
        <div style={{ ...S.card, textAlign: "center", padding: 50, color: "#9ca3af" }}>
          <div style={{ fontSize: 40, marginBottom: 10 }}>📭</div>
          <div style={{ fontWeight: 600 }}>No media yet</div>
          <div style={{ fontSize: 13, marginTop: 4 }}>Upload files or share a YouTube link above!</div>
        </div>
      )}
      <div style={{ display: "grid", gridTemplateColumns: "repeat(auto-fill, minmax(240px,1fr))", gap: 14 }}>
        {filtered.map(item => (
          <div key={item.id} style={{ ...S.card, padding: 0, overflow: "hidden", position: "relative" }}>
            {/* Thumbnail / preview */}
            {item.type === "image" && (
              <div style={{ cursor: "pointer", overflow: "hidden" }} onClick={() => setLightbox(item)}>
                <img src={item.data} alt={item.name} style={{ width: "100%", height: 160, objectFit: "cover", display: "block" }} />
              </div>
            )}
            {item.type === "video" && (
              <video controls src={item.data} style={{ width: "100%", height: 160, objectFit: "cover", display: "block", background: "#000" }} />
            )}
            {item.type === "youtube" && (
              <a href={`https://www.youtube.com/watch?v=${item.ytId}`} target="_blank" rel="noopener noreferrer"
                style={{display:"block",position:"relative",background:"#000",cursor:"pointer",textDecoration:"none"}}>
                <img src={`https://img.youtube.com/vi/${item.ytId}/hqdefault.jpg`} alt={item.name}
                  style={{width:"100%",height:160,objectFit:"cover",display:"block",opacity:0.85}}
                  onError={e=>{e.target.style.display="none";e.target.parentNode.style.height="160px";e.target.parentNode.style.background="#1e293b";}} />
                <div style={{position:"absolute",inset:0,display:"flex",alignItems:"center",justifyContent:"center",background:"rgba(0,0,0,0.3)"}}>
                  <div style={{width:48,height:48,background:"#dc2626",borderRadius:"50%",display:"flex",alignItems:"center",justifyContent:"center",boxShadow:"0 4px 16px rgba(0,0,0,0.5)"}}>
                    <div style={{width:0,height:0,borderTop:"10px solid transparent",borderBottom:"10px solid transparent",borderLeft:"18px solid #fff",marginLeft:4}}/>
                  </div>
                </div>
                <div style={{position:"absolute",bottom:6,right:6,background:"#dc2626",color:"#fff",borderRadius:5,padding:"2px 7px",fontSize:10,fontWeight:700}}>▶ YouTube</div>
              </a>
            )}
            {item.type === "file" && (
              <div style={{ height: 100, display: "flex", alignItems: "center", justifyContent: "center", background: "#f1f5f9", fontSize: 40 }}>
                {item.mimeType?.includes("pdf") ? "📄" : item.mimeType?.includes("text") ? "📝" : item.mimeType?.includes("zip") ? "🗜" : "📎"}
              </div>
            )}

            {/* Info */}
            <div style={{ padding: "10px 12px" }}>
              <div style={{ fontWeight: 700, fontSize: 13, overflow: "hidden", textOverflow: "ellipsis", whiteSpace: "nowrap", color: "#1e293b" }}>{item.name}</div>
              <div style={{ fontSize: 11, color: "#9ca3af", marginTop: 2 }}>by {item.author} · {new Date(item.ts).toLocaleDateString()}</div>
