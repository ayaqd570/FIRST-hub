        {/* Completed lessons list */}
        {Object.keys(done).length>0&&(
          <div style={{...S.card,marginTop:16}}>
            <div style={{fontWeight:700,color:"#f1f5f9",fontSize:15,marginBottom:10}}>✅ Completed Lessons ({Object.keys(done).length})</div>
            <div style={{display:"flex",flexWrap:"wrap",gap:6}}>
              {Object.keys(done).map(id=>(
                <span key={id} style={{background:"#0f172a",borderRadius:6,padding:"3px 10px",fontSize:11,color:"#60a5fa",border:"1px solid #1e3a8a"}}>{id}</span>
              ))}
            </div>
          </div>
        )}
      </div>
    );
  }

  // List all students
  const filtered = studentList.filter(([u,d])=>
    !searchQ || u.toLowerCase().includes(searchQ.toLowerCase()) || (d.name||"").toLowerCase().includes(searchQ.toLowerCase())
