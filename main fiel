from flask import Flask, request, jsonify
import json, os

app = Flask(__name__)
DATA_FILE = "scouting_data.json"

def load_data():
    if os.path.exists(DATA_FILE):
        with open(DATA_FILE) as f: return json.load(f)
    return []

def save_data(data):
    with open(DATA_FILE, "w") as f: json.dump(data, f, indent=2)

@app.route("/api/submit", methods=["POST"])
def submit():
    entry = request.json
    data = load_data()
    data.append(entry)
    save_data(data)
    return jsonify({"status": "ok", "total": len(data)})

@app.route("/api/stats/<int:team>")
def team_stats(team):
    data = [d for d in load_data() if d.get("team") == team]
    if not data:
        return jsonify({"error": "Not found"}), 404
    return jsonify({
        "team": team,
        "matches": len(data),
        "avg_auto":   round(sum(d["auto"]   for d in data) / len(data), 1),
        "avg_teleop": round(sum(d["teleop"] for d in data) / len(data), 1),
        "climb_rate": f"{sum(d.get('climbed',0) for d in data)/len(data)*100:.0f}%"
