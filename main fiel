async function checkAndUnlockAchievements(username, totalLessons) {
  const users = await storeGet("hub-users", true) || {};
  const u = users[username];
  if (!u) return [];
  const already = u.achievements || [];
  const newlyUnlocked = [];
  for (const ach of ACHIEVEMENTS) {
    if (!already.includes(ach.id) && ach.check(u, totalLessons)) {
      already.push(ach.id);
      newlyUnlocked.push(ach);
    }
  }
  if (newlyUnlocked.length > 0) {
    u.achievements = already;
    await storeSet("hub-users", users, true);
  }
  return newlyUnlocked;
}

// ─── STREAK TRACKING ──────────────────────────────────────
async function updateStreak(username) {
  const users = await storeGet("hub-users", true) || {};
  const u = users[username];
  if (!u) return;
  const today = new Date().toDateString();
  const yesterday = new Date(Date.now() - 86400000).toDateString();
  if (u.lastStudyDay === today) return; // already counted today
  u.streak = u.lastStudyDay === yesterday ? (u.streak || 0) + 1 : 1;
  u.lastStudyDay = today;
  await storeSet("hub-users", users, true);
}

