                <div style={{width:40,height:40,background:"linear-gradient(135deg,#1d4ed8,#7c3aed)",borderRadius:10,display:"flex",alignItems:"center",justifyContent:"center",fontWeight:900,color:"#fff",fontSize:18}}>
                  {(u.name||uname).charAt(0).toUpperCase()}
