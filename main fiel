      {id:"pa1",title:"OPR Calculation in Python",est:"30 min",content:`## Computing OPR from Scratch
OPR uses linear algebra: given alliance scores, find each robot's individual contribution.

\`\`\`python
import numpy as np
import pandas as pd
import requests

def calculate_opr(event_key, tba_key):
    headers = {"X-TBA-Auth-Key": tba_key}
    base = "https://www.thebluealliance.com/api/v3"

    matches = requests.get(f"{base}/event/{event_key}/matches", headers=headers).json()
    teams   = requests.get(f"{base}/event/{event_key}/teams/simple", headers=headers).json()

    team_list = sorted([t["key"] for t in teams])
    idx = {t: i for i, t in enumerate(team_list)}
    n = len(team_list)

    A_rows, b_rows = [], []
    for m in matches:
        if m["comp_level"] != "qm": continue
        for color in ["red", "blue"]:
            score = m["alliances"][color]["score"]
            if score < 0: continue
            row = [0.0] * n
            for t in m["alliances"][color]["team_keys"]:
                if t in idx: row[idx[t]] = 1.0
            A_rows.append(row)
            b_rows.append(float(score))

    A = np.array(A_rows)
    b = np.array(b_rows)
    opr, _, _, _ = np.linalg.lstsq(A, b, rcond=None)
    return pd.Series(opr, index=team_list).sort_values(ascending=False)

oprs = calculate_opr("2024casd", "YOUR_KEY")
print(oprs.head(10))
