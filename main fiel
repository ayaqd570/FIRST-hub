      {id:"wa2",title:"Real-Time Scouting with Firebase",est:"28 min",content:`## Firebase: Instant Multi-Device Sync
Firebase Realtime Database lets multiple scouts enter data on their phones and everyone sees updates instantly — perfect for competition.

## Setup
\`\`\`bash
npm install firebase
\`\`\`

\`\`\`javascript
// firebase.js
import { initializeApp } from "firebase/app";
import { getDatabase, ref, push, onValue } from "firebase/database";

const app = initializeApp({
  apiKey: "your-key",
  databaseURL: "https://your-app.firebaseio.com",
  projectId: "your-project",
});
export const db = getDatabase(app);
\`\`\`

## Writing Scout Data
\`\`\`javascript
import { db } from "./firebase";
import { ref, push, set } from "firebase/database";

async function saveScoutEntry(entry) {
  const entriesRef = ref(db, "scouting/2024casj");
  await push(entriesRef, {
    ...entry,
    timestamp: Date.now(),
    scoutName: currentUser.name,
  });
  console.log("Entry saved to Firebase!");
}
\`\`\`

## Real-Time Listening
\`\`\`javascript
import { ref, onValue } from "firebase/database";

function subscribeToEntries(eventKey, callback) {
  const entriesRef = ref(db, \`scouting/\${eventKey}\`);
  return onValue(entriesRef, (snapshot) => {
    const data = snapshot.val() || {};
    const entries = Object.values(data);
    callback(entries);
  });
  // Returns unsubscribe function — call it to stop listening
}

// In React component:
useEffect(() => {
  const unsub = subscribeToEntries("2024casj", setEntries);
  return unsub; // cleanup on unmount
}, []);
\`\`\``},
