function stopLearningTimer() {
  if (_sessionStart === null) return 0;
  const elapsed = Math.floor((Date.now() - _sessionStart) / 1000);
  _sessionStart = null;
  return elapsed;
}
async function addLearningTime(username, seconds) {
  if (!username || seconds <= 0) return;
  const users = await storeGet("hub-users", true) || {};
  if (users[username]) {
    users[username].learningTime = (users[username].learningTime || 0) + seconds;
    await storeSet("hub-users", users, true);
  }
}
function fmtTime(secs) {
  if (!secs) return "0 min";
  const h = Math.floor(secs/3600);
  const m = Math.floor((secs%3600)/60);
  if (h > 0) return h + "h " + m + "m";
  return m > 0 ? m + " min" : secs + "s";
}

