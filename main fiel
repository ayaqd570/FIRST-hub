  const [incPerson, setIncPerson] = useState("");
  const [incAction, setIncAction] = useState("");

  function addIncident() {
    if (!incDesc.trim()) return;
    const inc = {id:Date.now(), type:incType, desc:incDesc, date:incDate, person:incPerson, action:incAction};
    const updated = [inc, ...incidents];
    setIncidents(updated);
    localStorage.setItem("hub-incidents", JSON.stringify(updated));
    setIncDesc(""); setIncPerson(""); setIncAction("");
  }

  function downloadCSV() {
    const header = "Team,Match,Auto,Teleop,Climbed,Reliability,Notes,Time\n";
    const rows = scoutSaved.map(e => `${e.team},${e.match},${e.auto},${e.teleop},${e.climbed},${e.reliability},"${e.notes}",${new Date(e.ts).toLocaleString()}`).join("\n");
