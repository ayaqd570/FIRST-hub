leftFront.setPower(profiledPower);
leftBack.setPower(profiledPower);
rightFront.setPower(profiledPower);
rightBack.setPower(profiledPower);

// Completion check with tolerance
if (distanceToTarget < 30) { // Within 30 ticks = done
    stopAll();
    break; // Exit motion profile loop
}`,explanation:"Direction is determined by comparing current position to target — negative power if we've gone past it. The tolerance (30 ticks ≈ 0.7 inches) determines when we declare arrival. Too tight = oscillates. Too loose = inaccurate."},
