// ─── NOTES PAGE ───────────────────────────────────────────
function NotesPage({ user }) {
  const [notes, setNotes] = useState({});
  const [bookmarks, setBookmarks] = useState([]);
  const [activeNote, setActiveNote] = useState(null);
  const [editing, setEditing] = useState("");
  const [filter, setFilter] = useState("notes"); // notes | bookmarks
  const [saving, setSaving] = useState(false);

  useEffect(() => { loadData(); }, []);

  async function loadData() {
    const users = await storeGet("hub-users", true) || {};
    const u = users[user.username] || {};
    setNotes(u.notes || {});
    setBookmarks(u.bookmarks || []);
  }

  async function saveNote(lessonId) {
    setSaving(true);
    const users = await storeGet("hub-users", true) || {};
    if (!users[user.username]) { setSaving(false); return; }
    const updated = { ...notes, [lessonId]: editing };
    users[user.username].notes = updated;
    await storeSet("hub-users", users, true);
    setNotes(updated);
    setSaving(false);
    setActiveNote(null);
  }

  async function deleteNote(lessonId) {
    const users = await storeGet("hub-users", true) || {};
    if (!users[user.username]) return;
    const updated = { ...notes };
    delete updated[lessonId];
    users[user.username].notes = updated;
    await storeSet("hub-users", users, true);
    setNotes(updated);
    if (activeNote === lessonId) setActiveNote(null);
  }

  async function removeBookmark(lessonId) {
    const users = await storeGet("hub-users", true) || {};
    if (!users[user.username]) return;
    const updated = bookmarks.filter(id => id !== lessonId);
    users[user.username].bookmarks = updated;
    await storeSet("hub-users", users, true);
    setBookmarks(updated);
  }

  // Build lookup: lessonId → lesson object
  const lessonMap = {};
  Object.values(LESSONS).forEach(subject => {
    Object.values(subject).forEach(arr => {
      arr.forEach(l => { lessonMap[l.id] = l; });
    });
  });

  const noteEntries = Object.entries(notes).filter(([,v]) => v?.trim());
  const bookmarkLessons = bookmarks.map(id => lessonMap[id]).filter(Boolean);

  return (
    <div>
      <div style={{fontWeight:900,fontSize:24,marginBottom:4}}>📝 My Notes & Bookmarks</div>
      <div style={{color:"#6b7280",fontSize:13,marginBottom:18}}>Notes and bookmarks are private to your account.</div>

      {/* Filter */}
      <div style={{display:"flex",gap:8,marginBottom:18}}>
        {[["notes","📝 Notes",noteEntries.length],["bookmarks","⭐ Bookmarks",bookmarkLessons.length]].map(([key,label,count]) => (
          <button key={key} onClick={()=>setFilter(key)}
            style={{...S.chip(filter===key),fontSize:13,padding:"6px 16px"}}>
            {label} {count > 0 && <span style={{background:filter===key?"rgba(255,255,255,0.3)":"#e2e8f0",borderRadius:20,padding:"0 6px",fontSize:11,marginLeft:4}}>{count}</span>}
          </button>
        ))}
      </div>

      {/* NOTES VIEW */}
      {filter === "notes" && (
        <div>
          {noteEntries.length === 0 && (
            <div style={{textAlign:"center",padding:48,color:"#9ca3af",border:"2px dashed #e2e8f0",borderRadius:14}}>
              <div style={{fontSize:40,marginBottom:10}}>📝</div>
              <div style={{fontWeight:700,fontSize:16,marginBottom:6}}>No notes yet</div>
              <div style={{fontSize:13}}>Open any lesson and click "Add Note" to start.</div>
            </div>
          )}
          <div style={{display:"flex",flexDirection:"column",gap:10}}>
            {noteEntries.map(([lessonId, noteText]) => {
              const lesson = lessonMap[lessonId];
              const isEditing = activeNote === lessonId;
              return (
                <div key={lessonId} style={{...S.card,padding:16}}>
                  <div style={{display:"flex",justifyContent:"space-between",alignItems:"flex-start",gap:8,marginBottom:8}}>
                    <div>
                      <div style={{fontWeight:700,fontSize:14}}>{lesson?.title || lessonId}</div>
                      <div style={{fontSize:11,color:"#9ca3af"}}>Lesson note</div>
                    </div>
                    <div style={{display:"flex",gap:6}}>
                      {!isEditing && <button style={{...S.btnSm(),fontSize:11}} onClick={()=>{setEditing(noteText);setActiveNote(lessonId);}}>Edit</button>}
                      <button style={{...S.btnSm("#dc2626"),fontSize:11}} onClick={()=>deleteNote(lessonId)}>Delete</button>
                    </div>
                  </div>
                  {isEditing ? (
                    <div>
                      <textarea value={editing} onChange={e=>setEditing(e.target.value)}
                        style={{...S.ta,minHeight:100,marginBottom:8}} placeholder="Your notes…" />
                      <div style={{display:"flex",gap:8}}>
                        <button style={S.btn()} onClick={()=>saveNote(lessonId)} disabled={saving}>{saving?"Saving…":"Save Note"}</button>
                        <button style={S.btnOut()} onClick={()=>setActiveNote(null)}>Cancel</button>
                      </div>
                    </div>
                  ) : (
                    <div style={{background:"#f8fafc",borderRadius:8,padding:"10px 12px",fontSize:13,color:"#374151",lineHeight:1.6,whiteSpace:"pre-wrap"}}>{noteText}</div>
                  )}
                </div>
              );
            })}
          </div>
        </div>
      )}

      {/* BOOKMARKS VIEW */}
      {filter === "bookmarks" && (
        <div>
          {bookmarkLessons.length === 0 && (
            <div style={{textAlign:"center",padding:48,color:"#9ca3af",border:"2px dashed #e2e8f0",borderRadius:14}}>
              <div style={{fontSize:40,marginBottom:10}}>⭐</div>
              <div style={{fontWeight:700,fontSize:16,marginBottom:6}}>No bookmarks yet</div>
              <div style={{fontSize:13}}>Star any lesson to save it here for quick access.</div>
            </div>
          )}
          <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(280px,1fr))",gap:10}}>
            {bookmarkLessons.map(lesson => (
              <div key={lesson.id} style={{...S.card,padding:14,display:"flex",alignItems:"center",gap:12}}>
                <div style={{flex:1}}>
                  <div style={{fontWeight:700,fontSize:14}}>{lesson.title}</div>
                  <div style={{fontSize:11,color:"#9ca3af",marginTop:2}}>⏱ {lesson.est}</div>
                </div>
                <button onClick={()=>removeBookmark(lesson.id)}
                  style={{background:"none",border:"none",cursor:"pointer",fontSize:20,color:"#f59e0b",padding:4}}>⭐</button>
              </div>
            ))}
          </div>
        </div>
      )}
    </div>
  );
}


