// ─── ADMIN ANALYTICS ──────────────────────────────────────
function AdminAnalytics({ students, totalLessons }) {
  const [view, setView] = useState("overview");

  if (!students) return <div style={{padding:40,textAlign:"center",color:"#94a3b8"}}>Loading analytics…</div>;
  const studentList = Object.entries(students).filter(([u])=>u!=="admin");
  const total = studentList.length;
  if (total===0) return <div style={{padding:40,textAlign:"center",color:"#94a3b8"}}>No students registered yet.</div>;

  // Overall stats
  const avgProgress = Math.round(studentList.reduce((s,[,u])=>s+(Object.keys(u.done||{}).length/totalLessons*100),0)/total);
  const avgQuiz = (() => {
    const scores = studentList.flatMap(([,u])=>Object.values(u.quizScores||{}).map(v=>v.score/v.total*100));
    return scores.length ? Math.round(scores.reduce((a,b)=>a+b,0)/scores.length) : null;
  })();
  const avgTime = Math.round(studentList.reduce((s,[,u])=>s+(u.learningTime||0),0)/total);
  const avgStreak = Math.round(studentList.reduce((s,[,u])=>s+(u.streak||0),0)/total);
  const active = studentList.filter(([,u])=>Object.keys(u.done||{}).length>0).length;
  const placed = studentList.filter(([,u])=>u.placementResult).length;

  // At-risk: less than 10% done + no quiz scores
  const atRisk = studentList.filter(([,u])=>{
    const pct = Object.keys(u.done||{}).length/totalLessons*100;
    const quizzes = Object.keys(u.quizScores||{}).length;
    return pct < 10 && quizzes === 0;
  });

  // Per-subject completion heatmap
  const subjectHeatmap = SUBJECTS.map(sub => {
    const prefix = sub.id==="java"?["jb","ji","ja"]:sub.id==="python"?["pb","pi","pa"]:sub.id==="mechanics"?["mb","mi","ma"]:sub.id==="electronics"?["eb","ei","ea"]:sub.id==="strategy"?["sb","si","sa","sfe","sfb","sfa"]:sub.id==="webdev"?["wb","wi","wa"]:["fb","fi","fa"];
    const counts = studentList.map(([,u])=>{
      const done = Object.keys(u.done||{});
      return done.filter(id=>prefix.some(p=>id.startsWith(p))).length;
    });
    const avg = counts.length ? Math.round(counts.reduce((a,b)=>a+b,0)/counts.length*10)/10 : 0;
    const maxPossible = 15;
    return {...sub, avg, pct: Math.round(avg/maxPossible*100)};
  });

  // Grade distribution
  const gradeDist = {A:0,B:0,C:0,D:0,F:0,None:0};
  studentList.forEach(([,u])=>{
    const scores = Object.values(u.quizScores||{});
    if (scores.length===0){gradeDist.None++;return;}
    const avg = scores.reduce((s,v)=>s+(v.score/v.total*100),0)/scores.length;
    if(avg>=90)gradeDist.A++;else if(avg>=80)gradeDist.B++;else if(avg>=70)gradeDist.C++;else if(avg>=60)gradeDist.D++;else gradeDist.F++;
  });

  const S = {
    card:{background:"#1e293b",borderRadius:14,padding:20,border:"1px solid #334155"},
    label:{fontSize:11,color:"#64748b",textTransform:"uppercase",letterSpacing:1},
    big:{fontSize:28,fontWeight:900,color:"#f1f5f9"},
  };

  return (
    <div>
      <div style={{fontWeight:900,fontSize:22,marginBottom:20,color:"#f1f5f9"}}>📊 Class Analytics</div>

      {/* KPI Row */}
      <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(160px,1fr))",gap:12,marginBottom:22}}>
        {[
          {label:"Total Students",val:total,icon:"👥",color:"#60a5fa"},
          {label:"Active Learners",val:active,icon:"🟢",color:"#34d399"},
          {label:"Placed Students",val:placed,icon:"🧪",color:"#a78bfa"},
          {label:"Avg Progress",val:`${avgProgress}%`,icon:"📈",color:"#fbbf24"},
          {label:"Avg Quiz Score",val:avgQuiz?`${avgQuiz}%`:"—",icon:"🧠",color:"#f87171"},
          {label:"Avg Time",val:fmtTime(avgTime),icon:"⏱",color:"#34d399"},
          {label:"Avg Streak",val:`${avgStreak}🔥`,icon:"",color:"#fb923c"},
          {label:"At-Risk Students",val:atRisk.length,icon:"⚠️",color:atRisk.length>0?"#ef4444":"#34d399"},
        ].map(k=>(
          <div key={k.label} style={S.card}>
            <div style={{...S.label,marginBottom:6}}>{k.label}</div>
            <div style={{...S.big,color:k.color}}>{k.icon} {k.val}</div>
          </div>
        ))}
      </div>

      <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:16,marginBottom:20}}>
        {/* Subject Heatmap */}
        <div style={{...S.card}}>
          <div style={{fontWeight:700,fontSize:15,color:"#f1f5f9",marginBottom:14}}>📚 Subject Engagement (Class Average)</div>
          {subjectHeatmap.map(s=>(
            <div key={s.id} style={{marginBottom:10}}>
              <div style={{display:"flex",justifyContent:"space-between",marginBottom:4}}>
                <span style={{fontSize:13,color:"#cbd5e1"}}>{s.icon} {s.name}</span>
                <span style={{fontSize:12,color:"#94a3b8"}}>{s.avg} lessons avg</span>
              </div>
              <div style={{background:"#334155",borderRadius:999,height:7}}>
                <div style={{width:`${Math.min(s.pct,100)}%`,background:s.color,height:"100%",borderRadius:999,transition:"width 0.5s"}}></div>
              </div>
            </div>
          ))}
        </div>

        {/* Grade Distribution */}
        <div style={{...S.card}}>
          <div style={{fontWeight:700,fontSize:15,color:"#f1f5f9",marginBottom:14}}>🎓 Quiz Grade Distribution</div>
          {Object.entries(gradeDist).map(([g,cnt])=>{
            const pct = total>0?Math.round(cnt/total*100):0;
            const color={A:"#10b981",B:"#34d399",C:"#fbbf24",D:"#f97316",F:"#ef4444",None:"#6b7280"}[g];
            return (
              <div key={g} style={{display:"flex",alignItems:"center",gap:10,marginBottom:8}}>
                <span style={{width:24,fontWeight:800,color,fontSize:14}}>{g}</span>
                <div style={{flex:1,background:"#334155",borderRadius:999,height:8}}>
                  <div style={{width:`${pct}%`,background:color,height:"100%",borderRadius:999}}></div>
                </div>
                <span style={{fontSize:12,color:"#94a3b8",width:50,textAlign:"right"}}>{cnt} ({pct}%)</span>
              </div>
            );
          })}
        </div>
      </div>

      {/* At-Risk Students */}
      {atRisk.length > 0 && (
        <div style={{...S.card,borderColor:"#7f1d1d",background:"rgba(127,29,29,0.2)",marginBottom:20}}>
          <div style={{fontWeight:700,fontSize:15,color:"#fca5a5",marginBottom:12}}>⚠️ At-Risk Students — Low Activity, No Quizzes</div>
          <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(220px,1fr))",gap:10}}>
            {atRisk.map(([uname,u])=>(
              <div key={uname} style={{background:"rgba(0,0,0,0.3)",borderRadius:10,padding:"12px 14px"}}>
                <div style={{fontWeight:700,color:"#f1f5f9",fontSize:14}}>{u.name||uname}</div>
                <div style={{fontSize:12,color:"#94a3b8",marginTop:4}}>
                  {Object.keys(u.done||{}).length} lessons · 0 quizzes · {fmtTime(u.learningTime||0)} logged
                </div>
                <div style={{fontSize:11,color:"#f97316",marginTop:4}}>
                  💡 Suggest: Send a personalized message encouraging them to start
                </div>
              </div>
            ))}
          </div>
        </div>
      )}

      {/* Top performers */}
      <div style={S.card}>
        <div style={{fontWeight:700,fontSize:15,color:"#f1f5f9",marginBottom:14}}>🏆 Top 5 Learners by Progress</div>
        <div style={{display:"flex",flexDirection:"column",gap:8}}>
          {[...studentList]
            .sort((a,b)=>Object.keys(b[1].done||{}).length-Object.keys(a[1].done||{}).length)
            .slice(0,5)
            .map(([uname,u],i)=>{
              const pct = Math.round(Object.keys(u.done||{}).length/totalLessons*100);
              const medals=["🥇","🥈","🥉","4️⃣","5️⃣"];
              return (
                <div key={uname} style={{display:"flex",alignItems:"center",gap:12,padding:"8px 12px",background:"#0f172a",borderRadius:8}}>
                  <span style={{fontSize:18}}>{medals[i]}</span>
                  <div style={{flex:1}}>
                    <div style={{fontWeight:700,color:"#f1f5f9",fontSize:14}}>{u.name||uname}</div>
                    <div style={{background:"#334155",borderRadius:999,height:5,marginTop:4}}>
                      <div style={{width:`${pct}%`,background:"#1d4ed8",height:"100%",borderRadius:999}}></div>
                    </div>
                  </div>
                  <span style={{fontSize:13,color:"#60a5fa",fontWeight:700}}>{pct}%</span>
                </div>
              );
            })}
        </div>
      </div>
    </div>
  );
}

// ─── ADMIN STUDENT REPORTS ─────────────────────────────────
function AdminStudentReports({ students, totalLessons }) {
  const [selStudent, setSelStudent] = useState(null);
  const [searchQ, setSearchQ] = useState("");

  if (!students) return <div style={{padding:40,textAlign:"center",color:"#94a3b8"}}>Loading…</div>;
  const studentList = Object.entries(students).filter(([u])=>u!=="admin");

  const S = {
    card:{background:"#1e293b",borderRadius:14,padding:20,border:"1px solid #334155"},
  };

  if (selStudent) {
    const [uname, u] = selStudent;
    const done = u.done||{};
    const quizScores = u.quizScores||{};
    const allQuizArr = Object.values(quizScores);
    const overallPct = Math.round(Object.keys(done).length/totalLessons*100);
    const overallQuizAvg = allQuizArr.length ? Math.round(allQuizArr.reduce((s,v)=>s+(v.score/v.total*100),0)/allQuizArr.length) : null;
    const grade = overallQuizAvg===null?"—":overallQuizAvg>=90?"A":overallQuizAvg>=80?"B":overallQuizAvg>=70?"C":overallQuizAvg>=60?"D":"F";

    const subjectStats = SUBJECTS.map(sub => {
      const prefix = sub.id==="java"?["jb","ji","ja"]:sub.id==="python"?["pb","pi","pa"]:sub.id==="mechanics"?["mb","mi","ma"]:sub.id==="electronics"?["eb","ei","ea"]:sub.id==="strategy"?["sb","si","sa","sfe","sfb","sfa"]:sub.id==="webdev"?["wb","wi","wa"]:["fb","fi","fa"];
      const doneSub = Object.keys(done).filter(id=>prefix.some(p=>id.startsWith(p))).length;
      const subQuizzes = Object.entries(quizScores).filter(([k])=>k.startsWith(sub.id));
      const avgQuiz = subQuizzes.length>0 ? Math.round(subQuizzes.reduce((s,[,v])=>s+(v.score/v.total*100),0)/subQuizzes.length) : null;
      return {...sub, done:doneSub, total:15, pct:Math.round(doneSub/15*100), avgQuiz};
    });

    const strengths = subjectStats.filter(s=>s.pct>=60||(s.avgQuiz!==null&&s.avgQuiz>=75));
    const weak = subjectStats.filter(s=>s.done>0&&s.pct<40);
    const notStarted = subjectStats.filter(s=>s.done===0);

    // Generate personalized teacher recommendation
    function getTeacherNotes() {
      const notes = [];
      if (overallPct < 15) notes.push("⚠️ Very low engagement. Consider reaching out directly — this student may need motivation or has unresolved questions.");
      if (overallPct >= 15 && overallPct < 50) notes.push("📈 Making some progress but still early. Encourage them to complete at least one full subject before branching out.");
      if (overallPct >= 50) notes.push("🌟 Strong learner! They would benefit from Advanced lessons and contributing code to the team.");
      if (overallQuizAvg !== null && overallQuizAvg < 65) notes.push("📚 Quiz scores are below average. Recommend they revisit lessons and use flashcards before retaking quizzes.");
      if (overallQuizAvg !== null && overallQuizAvg >= 85) notes.push("🧠 Excellent quiz performance — this student has strong comprehension and retention.");
      if (allQuizArr.length === 0 && Object.keys(done).length > 3) notes.push("🧠 Has completed lessons but hasn't taken any quizzes — nudge them to assess their knowledge.");
      if (weak.length > 0) notes.push(`⚙️ Weakest areas: ${weak.map(s=>s.name).join(", ")}. Consider pairing with a stronger teammate in these areas.`);
      if (strengths.length > 0) notes.push(`💪 Clear strengths in: ${strengths.map(s=>s.name).join(", ")}. Could serve as a peer mentor in these areas.`);
