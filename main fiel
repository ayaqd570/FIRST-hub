          )}
        </div>
        <div style={{display:"flex",flexDirection:"column",gap:8,marginBottom:16}}>
          {q.opts.map((opt,j) => {
            let bg="#f8fafc",border="1.5px solid #e2e8f0",col="#374151";
            if(answered){
              if(j===q.ans){bg="#f0fdf4";border="2px solid #86efac";col="#166534";}
              else if(quizAns===j){bg="#fef2f2";border="2px solid #fca5a5";col="#991b1b";}
            } else if(quizAns===j){bg="#f3e8ff";border="2px solid #c084fc";col="#7c3aed";}
            return (
              <button key={j} onClick={()=>{if(!answered){setQuizAns(j);if(j===q.ans)setQuizScore(s=>s+1);}}}
                style={{background:bg,border,color:col,padding:"11px 16px",borderRadius:10,cursor:answered?"default":"pointer",textAlign:"left",fontWeight:600,fontSize:14,fontFamily:"inherit"}}>
                {["A","B","C","D"][j]}. {opt}
              </button>
            );
          })}
        </div>
        {answered && (
          <div style={{background:"#f3e8ff",border:"2px solid #c4b5fd",borderRadius:10,padding:12,marginBottom:14,fontSize:13,color:"#4c1d95",lineHeight:1.6}}>
            {q.explanation || (quizAns===q.ans ? "✅ Correct!" : `💡 The answer is ${["A","B","C","D"][q.ans]}.`)}
          </div>
        )}
        {answered && (
          <button onClick={()=>{
            if(quizIdx+1 >= quizzes.length){setPhase("done");}
            else{setQuizIdx(i=>i+1);setQuizAns(null);}
          }} style={{background:"#7c3aed",color:"#fff",border:"none",padding:"11px 24px",borderRadius:9,cursor:"pointer",fontWeight:700,fontSize:14,fontFamily:"inherit"}}>
            {quizIdx+1>=quizzes.length?"Finish ✓":"Next Question →"}
          </button>
        )}
      </div>
    );
  }

  return (
    <div style={{background:"linear-gradient(135deg,#4c1d95,#7c3aed)",borderRadius:14,padding:24,color:"#fff",textAlign:"center"}}>
      <div style={{fontSize:48,marginBottom:10}}>🧩</div>
      <div style={{fontSize:22,fontWeight:900,marginBottom:6}}>Blocks Complete!</div>
      <div style={{fontSize:15,opacity:0.85,marginBottom:6}}>Quiz score: {quizScore}/{quizzes.length}</div>
      <div style={{fontSize:13,opacity:0.7,marginBottom:18}}>You've learned {blocks.length} code blocks with explanations.</div>
      <button onClick={()=>{setPhase("learn");setStep(0);setQuizIdx(0);setQuizAns(null);setQuizScore(0);}}
        style={{background:"rgba(255,255,255,0.2)",border:"2px solid rgba(255,255,255,0.5)",color:"#fff",padding:"9px 22px",borderRadius:8,cursor:"pointer",fontWeight:700,fontSize:13,fontFamily:"inherit"}}>
        Review Blocks
      </button>
    </div>
  );
}

// ─── STUDENT PROGRESS REPORT ──────────────────────────────
function StudentReportPage({ user, done, totalLessons }) {
  const [quizScores, setQuizScores] = useState({});
  const [flashProg, setFlashProg] = useState({});
  const [learningTime, setLearningTime] = useState(0);
  const [streak, setStreak] = useState(0);
  const [loading, setLoading] = useState(true);

  useEffect(()=>{
    async function load() {
      const userData = await storeGet("hub-users", true);
      const u = userData?.[user.username] || {};
      setQuizScores(u.quizScores || {});
      setLearningTime(u.learningTime || 0);
      setStreak(u.streak || 0);
      const fp = await storeGet("hub-flashcards-"+user.username, false);
      setFlashProg(fp || {});
      setLoading(false);
    }
    load();
  }, [user]);

  if (loading) return <div style={{padding:40,textAlign:"center",color:"#64748b"}}>Loading your report…</div>;

  // Per-subject stats
  const subjectStats = SUBJECTS.map(sub => {
    const subLessons = Object.values(LESSONS).flatMap(lvlObj => 
      (lvlObj[sub.id] || []).flatMap(lvl => 
        typeof lvl === "object" && !Array.isArray(lvl) ? [] : 
        (lvlObj[sub.id] || [])
      )
    );
    
    // Simpler: count done lessons by subject prefix
    const prefix = sub.id === "java" ? ["jb","ji","ja"] :
                   sub.id === "python" ? ["pb","pi","pa"] :
                   sub.id === "mechanics" ? ["mb","mi","ma"] :
                   sub.id === "electronics" ? ["eb","ei","ea"] :
                   sub.id === "strategy" ? ["sb","si","sa","sfe","sfb","sfa"] :
                   sub.id === "webdev" ? ["wb","wi","wa"] :
                   sub.id === "fundraising" ? ["fb","fi","fa"] : [];
    
    const allIds = Object.keys(done);
    const doneSub = allIds.filter(id => prefix.some(p => id.startsWith(p)));
    
    // Count total lessons for this subject
    const allLessonsFlat = Object.values(LESSONS).reduce((acc, lvlMap) => {
      const subArr = lvlMap[sub.id];
      if (Array.isArray(subArr)) subArr.forEach(l => acc.push(l.id));
      return acc;
    }, []);
    const total = Math.max(allLessonsFlat.length, 1);
    
    // Quiz scores for this subject
    const subQuizzes = Object.entries(quizScores).filter(([k]) => k.startsWith(sub.id));
    const avgQuiz = subQuizzes.length > 0
      ? Math.round(subQuizzes.reduce((s,[,v])=>s+(v.score/v.total*100),0)/subQuizzes.length)
      : null;

    const flashDeck = FLASHCARD_DECKS[sub.id];
    const flashKnown = flashDeck ? Object.values(flashProg[sub.id]||{}).filter(v=>v==="know").length : 0;
    const flashTotal = flashDeck ? flashDeck.cards.length : 0;

    return {
      ...sub,
      done: doneSub.length,
      total,
      pct: Math.round(doneSub.length/total*100),
      avgQuiz,
      flashKnown,
      flashTotal,
    };
  });

  const overallPct = Math.round(Object.keys(done).length / Math.max(totalLessons,1) * 100);
  const strengths = subjectStats.filter(s => s.pct >= 60 || (s.avgQuiz !== null && s.avgQuiz >= 75));
  const improve = subjectStats.filter(s => s.done > 0 && s.pct < 40 && (s.avgQuiz === null || s.avgQuiz < 60));
  const notStarted = subjectStats.filter(s => s.done === 0);

  // Recommended next lessons (incomplete, in subjects with some progress)
  const inProgress = subjectStats.filter(s => s.done > 0 && s.pct < 100);
  
  // Grade based on overall quiz average
  const allQuizArr = Object.values(quizScores);
  const overallQuizAvg = allQuizArr.length > 0
    ? Math.round(allQuizArr.reduce((s,v)=>s+(v.score/v.total*100),0)/allQuizArr.length) : null;
  const grade = overallQuizAvg === null ? "—" : overallQuizAvg >= 90 ? "A" : overallQuizAvg >= 80 ? "B" : overallQuizAvg >= 70 ? "C" : overallQuizAvg >= 60 ? "D" : "F";

  return (
    <div style={{maxWidth:900,margin:"0 auto",padding:"24px 16px"}}>
      {/* Header */}
      <div style={{background:"linear-gradient(135deg,#1e3a8a,#1d4ed8,#7c3aed)",borderRadius:20,padding:"28px 28px",color:"#fff",marginBottom:24,position:"relative",overflow:"hidden"}}>
        <div style={{position:"absolute",right:-20,top:-20,fontSize:120,opacity:0.05}}>📊</div>
        <div style={{fontSize:22,fontWeight:900,marginBottom:4}}>📊 Your Learning Report</div>
        <div style={{opacity:0.8,marginBottom:18}}>Personalized analysis for {user.name || user.username}</div>
        <div style={{display:"flex",gap:20,flexWrap:"wrap"}}>
          {[
            {label:"Lessons Done",val:`${Object.keys(done).length}/${totalLessons}`,icon:"📚"},
            {label:"Overall Progress",val:`${overallPct}%`,icon:"📈"},
            {label:"Quiz Grade",val:grade,icon:"🧠"},
            {label:"Learning Time",val:fmtTime(learningTime),icon:"⏱"},
            {label:"Day Streak",val:`${streak}🔥`,icon:""},
            {label:"Quizzes Taken",val:allQuizArr.length,icon:"✅"},
          ].map(stat=>(
            <div key={stat.label} style={{background:"rgba(255,255,255,0.12)",borderRadius:12,padding:"12px 18px",minWidth:100}}>
              <div style={{fontSize:20,fontWeight:900}}>{stat.icon} {stat.val}</div>
