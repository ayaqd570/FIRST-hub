// ─── STUDY PLAN PAGE ─────────────────────────────────────
function StudyPlanPage({ user, done, totalLessons }) {
  const [plan, setPlan] = useState(null);
  const [loading, setLoading] = useState(false);
  const [goal, setGoal] = useState("competition");
  const [hoursPerWeek, setHoursPerWeek] = useState(5);
  const [focusSubjects, setFocusSubjects] = useState([]);
  const [generated, setGenerated] = useState(false);
  const [checkedMilestones, setCheckedMilestones] = useState({});

  const GOALS = [
    {id:"competition",label:"🏆 Prepare for Competition",desc:"Prioritizes strategy, programming, and mechanics for match readiness"},
    {id:"programming",label:"💻 Master Programming",desc:"Deep focus on Java/Python, autonomy, and code quality"},
    {id:"allround",label:"⚙️ Well-Rounded Engineer",desc:"Balanced coverage of all subjects"},
    {id:"rookie",label:"🌱 Rookie — Start from Scratch",desc:"Beginner-friendly path covering basics first"},
    {id:"advanced",label:"🚀 Push to Advanced",desc:"Skip basics, focus on Intermediate/Advanced content"},
  ];

  function toggleSubject(id) {
    setFocusSubjects(prev => prev.includes(id) ? prev.filter(s=>s!==id) : [...prev, id]);
  }

  function generatePlan() {
    setLoading(true);
    setTimeout(() => {
      const doneIds = new Set(Object.keys(done));
      
      // Build ordered lesson list based on goal
      const subjectOrder = goal==="programming" ? ["java","python","electronics","strategy","mechanics","webdev","fundraising"]
        : goal==="competition" ? ["strategy","java","mechanics","electronics","python","webdev","fundraising"]
        : goal==="rookie" ? ["java","mechanics","electronics","strategy","python","webdev","fundraising"]
        : goal==="advanced" ? ["java","python","mechanics","electronics","strategy","webdev","fundraising"]
        : ["java","mechanics","electronics","strategy","python","webdev","fundraising"];

      const levelOrder = goal==="advanced" ? ["Intermediate","Advanced","Beginner"]
        : goal==="rookie" ? ["Beginner","Intermediate","Advanced"]
        : ["Beginner","Intermediate","Advanced"];

      const focused = focusSubjects.length > 0
        ? [...focusSubjects, ...subjectOrder.filter(s=>!focusSubjects.includes(s))]
        : subjectOrder;

      const allLessons = [];
      focused.forEach(subId => {
        const sub = SUBJECTS.find(s=>s.id===subId);
        if (!sub) return;
        levelOrder.forEach(level => {
          const arr = LESSONS[subId]?.[level] || [];
          arr.forEach(l => {
            if (!doneIds.has(l.id)) allLessons.push({...l, subId, subName:sub.name, subIcon:sub.icon, level, subColor:sub.color});
          });
        });
      });

      const minsPerLesson = 25;
      const minsPerWeek = hoursPerWeek * 60;
      const lessonsPerWeek = Math.max(1, Math.floor(minsPerWeek / minsPerLesson));
      const weeks = [];
      for (let i = 0; i < allLessons.length; i += lessonsPerWeek) {
        weeks.push(allLessons.slice(i, i + lessonsPerWeek));
      }

      // Milestones
      const milestones = [
        {week:1, label:"🌱 First Lesson Complete", desc:"Finish your very first lesson on this plan"},
        {week:Math.ceil(weeks.length*0.25), label:"📈 25% Progress", desc:"One quarter of your remaining lessons done"},
        {week:Math.ceil(weeks.length*0.5), label:"🏁 Halfway!", desc:"Half your planned lessons completed"},
        {week:Math.ceil(weeks.length*0.75), label:"🔥 Almost There", desc:"75% of the plan finished"},
        {week:weeks.length, label:"🏆 Plan Complete!", desc:"All planned lessons done — competition ready!"},
      ];

      setPlan({ weeks, milestones, lessonsPerWeek, totalRemaining: allLessons.length, weeksTotal: weeks.length });
      setLoading(false);
      setGenerated(true);
    }, 600);
  }

  const CS = {
    card:{background:"#fff",borderRadius:16,padding:20,border:"1px solid #e2e8f0",boxShadow:"0 1px 4px rgba(0,0,0,0.05)"},
