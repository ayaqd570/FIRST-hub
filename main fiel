dt = 0.02  # 20ms loop

def pid_step(target, current):
    global integral, last_error
    error = target - current
    integral += error * dt
    derivative = (error - last_error) / dt
    output = kP*error + kI*integral + kD*derivative
    last_error = error
    return output
