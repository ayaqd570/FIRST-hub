      {id:"wa1",title:"Full Scouting App with Analytics",est:"30 min",content:`## Building a Complete Scouting System
A production scouting app has three layers: data entry, storage, and analytics.

## Architecture
- ScoutForm.jsx — match data entry
- TeamDashboard.jsx — per-team analytics
- MatchList.jsx — browsable match history
- utils/storage.js — data persistence
- utils/analytics.js — OPR calculations

## Simple OPR in JavaScript
\`\`\`js
function calculateOPR(matchData) {
  const scores = {};
  const counts = {};
  
  matchData.forEach(match => {
    match.redAlliance.forEach(team => {
      scores[team] = (scores[team] || 0) + match.redScore;
      counts[team] = (counts[team] || 0) + 1;
    });
    match.blueAlliance.forEach(team => {
      scores[team] = (scores[team] || 0) + match.blueScore;
      counts[team] = (counts[team] || 0) + 1;
    });
  });
  
  const opr = {};
  Object.keys(scores).forEach(t => { opr[t] = scores[t] / counts[t]; });
  return opr;
}
\`\`\`

## Export to CSV
\`\`\`js
function exportCSV(data) {
  const rows = data.map(d => [d.team,d.match,d.auto,d.teleop,d.rating].join(","));
  const csv = ["Team,Match,Auto,Teleop,Rating", ...rows].join("\\n");
  const a = document.createElement("a");
  a.href = URL.createObjectURL(new Blob([csv], {type:"text/csv"}));
  a.download = "scout_data.csv";
  a.click();
}
\`\`\``},
