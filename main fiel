function shuffleArr(a){const b=[...a];for(let i=b.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[b[i],b[j]]=[b[j],b[i]];}return b;}

function pickPlacementQuestions(){
  const bycat={};
  PLACEMENT_BANK.forEach(q=>{if(!bycat[q.cat])bycat[q.cat]=[];bycat[q.cat].push(q);});
  const counts={Programming:16,Mechanics:16,Strategy:4,Safety:4};
  let picks=[];
  Object.keys(counts).forEach(cat=>{
    const pool=shuffleArr(bycat[cat]||[]);
    picks=picks.concat(pool.slice(0,Math.min(counts[cat],pool.length)));
  });
  return shuffleArr(picks).map(q=>{
    const idxs=shuffleArr([0,1,2,3].slice(0,q.opts.length));
    const newOpts=idxs.map(i=>q.opts[i]);
    const newAns=idxs.indexOf(q.ans);
    return {cat:q.cat,q:q.q,opts:newOpts,ans:newAns,exp:q.exp};
  });
}

function calcPlacementRole(catScores){
  const roles={
    Programming:{name:'💻 Programming Subteam',desc:'Your code knowledge stands out. You would thrive writing robot code, vision systems, or autonomous routines.',color:'#1d4ed8'},
    Mechanics:{name:'🔧 Build / Mechanical Subteam',desc:'Strong mechanical understanding. You would excel designing mechanisms, fabricating parts, or maintaining the robot.',color:'#b45309'},
    Strategy:{name:'📋 Strategy & Scouting',desc:'Sharp strategic mind. Consider leading scouting, drive team support, or match planning.',color:'#15803d'},
    Safety:{name:'🦺 Safety Captain / Pit Crew',desc:'Great safety and team awareness. You would be a strong Safety Captain or pit crew lead.',color:'#7c3aed'},
  };
  const cats=Object.keys(catScores).filter(k=>catScores[k].t>0);
  if(!cats.length) return roles.Programming;
  const best=cats.sort((a,b)=>(catScores[b].c/catScores[b].t)-(catScores[a].c/catScores[a].t))[0];
  return {...roles[best],category:best};
}

