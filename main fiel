    <div style={{maxWidth:800,margin:"0 auto",padding:"24px 16px"}}>
      <div style={{display:"flex",alignItems:"center",gap:12,marginBottom:20,flexWrap:"wrap"}}>
        <div>
          <div style={{fontWeight:900,fontSize:22}}>📅 Your Personalized Study Plan</div>
          <div style={{color:"#64748b",fontSize:13}}>{plan.totalRemaining} lessons · {plan.weeksTotal} weeks · {hoursPerWeek}h/week</div>
        </div>
        <button onClick={()=>setGenerated(false)} style={{marginLeft:"auto",background:"#f1f5f9",color:"#475569",border:"none",borderRadius:8,padding:"8px 16px",cursor:"pointer",fontWeight:600,fontSize:13}}>↺ Rebuild Plan</button>
      </div>

      {/* Milestones */}
      <div style={{background:"linear-gradient(135deg,#1e3a8a,#7c3aed)",borderRadius:16,padding:"20px 22px",marginBottom:20,color:"#fff"}}>
        <div style={{fontWeight:800,fontSize:15,marginBottom:12}}>🏁 Milestones</div>
        <div style={{display:"flex",gap:8,flexWrap:"wrap"}}>
          {plan.milestones.map((m,i)=>{
            const checked = checkedMilestones[i];
            return (
              <div key={i} onClick={()=>setCheckedMilestones(p=>({...p,[i]:!p[i]}))}
                style={{background:checked?"rgba(16,185,129,0.3)":"rgba(255,255,255,0.1)",borderRadius:10,padding:"10px 14px",cursor:"pointer",border:`1px solid ${checked?"#10b981":"rgba(255,255,255,0.2)"}`,flex:1,minWidth:140}}>
                <div style={{fontSize:13,fontWeight:700}}>{checked?"✅ ":""}{m.label}</div>
