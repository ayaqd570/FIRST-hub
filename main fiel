                    </div>
                    <div>
                      <div style={{fontSize:12,color:"#9ca3af",marginBottom:4}}>Cycles / Game Pieces</div>
                      <input type="number" value={cycleCount} onChange={e=>setCycleCount(e.target.value)} placeholder="e.g. 8"
                        style={{width:"100%",padding:"9px 12px",borderRadius:8,border:"1.5px solid #e2e8f0",fontSize:14,boxSizing:"border-box",fontFamily:"inherit"}}/>
                    </div>
                    <div>
                      <div style={{fontSize:12,color:"#9ca3af",marginBottom:6}}>Auto Consistency</div>
                      <div style={{display:"flex",gap:6}}>
                        {[["fail","❌ Failed"],["partial","⚠️ Partial"],["full","✅ Full"]].map(([v,l])=>(
                          <button key={v} onClick={()=>setAutoConsistency(v)}
                            style={{flex:1,background:autoConsistency===v?{fail:"#fef2f2",partial:"#fffbeb",full:"#f0fdf4"}[v]:"#f8fafc",
                              border:`2px solid ${autoConsistency===v?{fail:"#fca5a5",partial:"#fcd34d",full:"#86efac"}[v]:"#e2e8f0"}`,
                              borderRadius:7,padding:"6px 4px",cursor:"pointer",fontSize:11,fontWeight:700,fontFamily:"inherit",textAlign:"center"}}>
                            {l}
                          </button>
                        ))}
                      </div>
                    </div>
                  </div>
                  <div style={{marginBottom:14}}>
                    <div style={{fontSize:12,color:"#9ca3af",marginBottom:6}}>Scoring Zones Used</div>
                    <div style={{display:"flex",gap:6,flexWrap:"wrap"}}>
                      {["Low Goal","Mid Goal","High Goal","Speaker","Amp","Trap","Ground Intake","Feeder Station"].map(z=>(
                        <button key={z} onClick={()=>setScoringZone(prev=>prev.includes(z)?prev.filter(x=>x!==z):[...prev,z])}
                          style={{background:scoringZone.includes(z)?"#1d4ed8":"#f1f5f9",color:scoringZone.includes(z)?"#fff":"#374151",border:"none",borderRadius:7,padding:"6px 10px",cursor:"pointer",fontWeight:600,fontSize:12,fontFamily:"inherit"}}>
                          {z}
                        </button>
                      ))}
                    </div>
                  </div>
                  <RatingPicker val={offenseRating} set={setOffenseRating} max={5} color="#1d4ed8" label="Offense Rating"/>
                </div>

                {/* DEFENSE */}
                <div style={{background:"#fff",borderRadius:12,padding:16,border:`2px solid ${playedDefense?"#fed7aa":"#e2e8f0"}`,marginBottom:12,transition:"border-color 0.2s"}}>
                  <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:playedDefense?14:0}}>
                    <div style={{fontWeight:800,fontSize:15,color:"#ea580c"}}>🛡️ Defense</div>
                    <button onClick={()=>setPlayedDefense(!playedDefense)}
                      style={{background:playedDefense?"#fff7ed":"#f1f5f9",border:`2px solid ${playedDefense?"#f97316":"#e2e8f0"}`,color:playedDefense?"#ea580c":"#6b7280",borderRadius:8,padding:"6px 14px",cursor:"pointer",fontWeight:700,fontSize:13,fontFamily:"inherit"}}>
                      {playedDefense?"✅ Played Defense":"⬜ Did Not Play Defense"}
                    </button>
                  </div>
                  {playedDefense && (
                    <div>
                      <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:12,marginBottom:14}}>
                        <div>
                          <div style={{fontSize:12,color:"#9ca3af",marginBottom:4}}>Who Did They Target?</div>
                          <input value={defenseTarget} onChange={e=>setDefenseTarget(e.target.value)} placeholder="e.g. 1678, top scorer"
                            style={{width:"100%",padding:"9px 12px",borderRadius:8,border:"1.5px solid #e2e8f0",fontSize:13,boxSizing:"border-box",fontFamily:"inherit"}}/>
                        </div>
                        <div>
                          <div style={{fontSize:12,color:"#9ca3af",marginBottom:4}}>Penalties Taken</div>
                          <div style={{display:"flex",gap:6,alignItems:"center"}}>
                            <button onClick={()=>setDefensePenalties(p=>Math.max(0,p-1))}
                              style={{width:32,height:32,borderRadius:7,border:"1.5px solid #e2e8f0",background:"#f8fafc",cursor:"pointer",fontWeight:900,fontSize:16,fontFamily:"inherit"}}>-</button>
                            <span style={{fontWeight:800,fontSize:18,minWidth:28,textAlign:"center",color:defensePenalties>2?"#dc2626":"#374151"}}>{defensePenalties}</span>
                            <button onClick={()=>setDefensePenalties(p=>p+1)}
                              style={{width:32,height:32,borderRadius:7,border:"1.5px solid #e2e8f0",background:"#f8fafc",cursor:"pointer",fontWeight:900,fontSize:16,fontFamily:"inherit"}}>+</button>
                          </div>
                        </div>
                      </div>
                      <div style={{marginBottom:12}}>
                        <div style={{fontSize:12,color:"#9ca3af",marginBottom:4}}>Defense Style Notes</div>
                        <input value={defenseNotes} onChange={e=>setDefenseNotes(e.target.value)} placeholder="e.g. Bumper to bumper, pushed them out of shooting zone, was effective"
                          style={{width:"100%",padding:"9px 12px",borderRadius:8,border:"1.5px solid #e2e8f0",fontSize:13,boxSizing:"border-box",fontFamily:"inherit"}}/>
                      </div>
                      <RatingPicker val={defenseEffective} set={setDefenseEffective} max={5} color="#ea580c" label="Defense Effectiveness"/>
                    </div>
                  )}
                </div>

                {/* ENDGAME */}
                <div style={{background:"#fff",borderRadius:12,padding:16,border:"2px solid #d1fae5",marginBottom:12}}>
                  <div style={{fontWeight:800,fontSize:15,color:"#059669",marginBottom:12}}>🧗 Endgame / Climb</div>
                  <div style={{display:"flex",gap:8,marginBottom:10,flexWrap:"wrap"}}>
                    {[["no","❌ No Climb"],["attempted","⚠️ Attempted"],["success","✅ Climbed"],["harmony","🤝 Harmony"]].map(([val,lbl])=>(
                      <button key={val} onClick={()=>setClimbed(val)}
                        style={{background:climbed===val?{no:"#fef2f2",attempted:"#fffbeb",success:"#f0fdf4",harmony:"#eff6ff"}[val]:"#f8fafc",
                          border:`2px solid ${climbed===val?{no:"#fca5a5",attempted:"#fcd34d",success:"#86efac",harmony:"#93c5fd"}[val]:"#e2e8f0"}`,
                          borderRadius:8,padding:"8px 14px",cursor:"pointer",fontWeight:700,fontSize:12,fontFamily:"inherit"}}>
                        {lbl}
                      </button>
                    ))}
                  </div>
                  {climbed!=="no" && (
                    <div>
                      <div style={{fontSize:12,color:"#9ca3af",marginBottom:4}}>Climb Time (seconds from endgame start)</div>
                      <input type="number" value={climbTime} onChange={e=>setClimbTime(e.target.value)} placeholder="e.g. 12"
                        style={{width:120,padding:"8px 12px",borderRadius:8,border:"1.5px solid #e2e8f0",fontSize:14,boxSizing:"border-box",fontFamily:"inherit"}}/>
                    </div>
                  )}
                </div>

                {/* OVERALL RATINGS */}
                <div style={{background:"#fff",borderRadius:12,padding:16,border:"1px solid #e2e8f0",marginBottom:12}}>
                  <div style={{fontWeight:800,fontSize:15,color:"#374151",marginBottom:14}}>⭐ Overall Assessment</div>
                  <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:14,marginBottom:14}}>
                    <RatingPicker val={reliability} set={setReliability} max={5} color="#7c3aed" label="Reliability (no breakdowns, consistent)"/>
                    <RatingPicker val={robotSpeed} set={setRobotSpeed} max={5} color="#0891b2" label="Robot Speed (movement, cycle time)"/>
                    <RatingPicker val={driverSkill} set={setDriverSkill} max={5} color="#0d9488" label="Driver Skill (control, positioning)"/>
                    <div>
                      <div style={{fontSize:12,color:"#6b7280",marginBottom:8,fontWeight:600}}>Robot broke down / had issues?</div>
                      <button onClick={()=>setBrokeDown(!brokeDown)}
                        style={{background:brokeDown?"#fef2f2":"#f0fdf4",border:`2px solid ${brokeDown?"#fca5a5":"#86efac"}`,color:brokeDown?"#991b1b":"#166534",borderRadius:8,padding:"9px 16px",cursor:"pointer",fontWeight:700,fontFamily:"inherit",fontSize:13}}>
                        {brokeDown?"💀 Yes — broke down":"✅ No issues"}
                      </button>
                    </div>
                  </div>
                  <div>
                    <div style={{fontSize:12,color:"#9ca3af",marginBottom:4}}>Scouter Notes</div>
                    <textarea value={scoutNotes} onChange={e=>setScoutNotes(e.target.value)} rows={2}
                      placeholder="e.g. Very fast shooter, jammed intake in Q2, climbed in 8 sec, excellent driver..."
                      style={{width:"100%",padding:"9px 12px",borderRadius:8,border:"1.5px solid #e2e8f0",fontSize:13,boxSizing:"border-box",resize:"vertical",fontFamily:"inherit"}}/>
                  </div>
                </div>

                {/* PREVIEW SCORE */}
                {scoutTeam && (() => {
                  const preview = {offenseRating,playedDefense,defenseEffective,defensePenalties,climbed,reliability};
                  const r = calcOverallRating(preview);
                  return (
                    <div style={{background:`linear-gradient(135deg,${overallColor(r)}15,${overallColor(r)}05)`,border:`2px solid ${overallColor(r)}40`,borderRadius:12,padding:14,marginBottom:12,display:"flex",alignItems:"center",gap:14}}>
                      <div style={{width:56,height:56,borderRadius:"50%",background:overallColor(r),color:"#fff",display:"flex",alignItems:"center",justifyContent:"center",fontWeight:900,fontSize:22,flexShrink:0}}>{r}</div>
                      <div>
                        <div style={{fontWeight:800,fontSize:16,color:overallColor(r)}}>{overallLabel(r)}</div>
                        <div style={{fontSize:12,color:"#6b7280"}}>Predicted overall rating for Team #{scoutTeam}</div>
                      </div>
                    </div>
                  );
                })()}

                <div style={{display:"flex",gap:10}}>
                  <button onClick={saveScoutEntry}
                    style={{background:"#1d4ed8",color:"#fff",border:"none",padding:"12px 28px",borderRadius:10,cursor:"pointer",fontWeight:800,fontSize:15,fontFamily:"inherit",opacity:scoutTeam?"1":"0.5"}}>
                    💾 Save Scout Entry
                  </button>
                  <button onClick={scoutReset}
                    style={{background:"#f1f5f9",color:"#374151",border:"none",padding:"12px 16px",borderRadius:10,cursor:"pointer",fontWeight:700,fontFamily:"inherit"}}>
                    Clear
                  </button>
                  {scoutSaved.length>0 && (
                    <button onClick={()=>{
                      const hdr="Team,Match,Auto,Teleop,Cycles,OffenseRating,PlayedDefense,DefenseRating,Penalties,Climb,Reliability,Speed,DriverSkill,Overall,Notes\n";
                      const rows=scoutSaved.map(e=>`${e.team},${e.match},${e.auto||0},${e.teleop||0},${e.cycleCount||0},${e.offenseRating||0},${e.playedDefense?1:0},${e.defenseEffective||0},${e.defensePenalties||0},${e.climbed},${e.reliability||0},${e.robotSpeed||0},${e.driverSkill||0},${e.overallRating||0},"${(e.notes||"").replace(/"/g,"'")}"`).join("\n");
                      const blob=new Blob([hdr+rows],{type:"text/csv"});
                      const url=URL.createObjectURL(blob);
                      const a=document.createElement("a");a.href=url;a.download="scout_data.csv";a.click();
                    }}
                    style={{background:"#059669",color:"#fff",border:"none",padding:"12px 18px",borderRadius:10,cursor:"pointer",fontWeight:700,fontFamily:"inherit"}}>
                    ⬇ CSV
                  </button>
                  )}
                </div>
              </div>
            )}

            {/* LIST VIEW */}
            {scoutView==="list" && (
              <div>
                {scoutSaved.length===0 ? (
                  <div style={{textAlign:"center",padding:40,color:"#9ca3af"}}>No entries yet — fill out the form first!</div>
                ) : (
                  <div style={{display:"flex",flexDirection:"column",gap:8}}>
                    {scoutSaved.map((e,i)=>{
                      const c=overallColor(e.overallRating||5);
                      return (
                        <div key={i} style={{background:"#fff",borderRadius:12,padding:"12px 16px",border:`2px solid ${c}30`,display:"flex",gap:12,alignItems:"flex-start",flexWrap:"wrap",position:"relative"}}>
                          <div style={{width:44,height:44,borderRadius:10,background:c,color:"#fff",display:"flex",alignItems:"center",justifyContent:"center",fontWeight:900,fontSize:18,flexShrink:0}}>{e.overallRating||"?"}</div>
                          <div style={{flex:1,minWidth:150}}>
                            <div style={{fontWeight:900,fontSize:16,color:"#1e293b"}}>Team #{e.team}</div>
                            <div style={{fontSize:12,color:"#6b7280"}}>{e.match} · {new Date(e.ts).toLocaleDateString()}</div>
                          </div>
                          <div style={{display:"flex",gap:8,flexWrap:"wrap",fontSize:12}}>
                            <div style={{background:"#dbeafe",color:"#1e40af",borderRadius:6,padding:"4px 8px"}}>⚡ Off: {e.offenseRating}/5</div>
                            {e.playedDefense&&<div style={{background:"#fff7ed",color:"#c2410c",borderRadius:6,padding:"4px 8px"}}>🛡️ Def: {e.defenseEffective}/5</div>}
                            <div style={{background:{success:"#d1fae5",attempted:"#fef9c3",no:"#fee2e2",harmony:"#dbeafe"}[e.climbed]||"#f3f4f6",
                              color:{success:"#065f46",attempted:"#854d0e",no:"#991b1b",harmony:"#1e40af"}[e.climbed]||"#374151",borderRadius:6,padding:"4px 8px"}}>
                              {e.climbed==="success"?"✅":e.climbed==="harmony"?"🤝":e.climbed==="attempted"?"⚠️":"❌"} Climb
                            </div>
                            <div style={{background:"#f3e8ff",color:"#6d28d9",borderRadius:6,padding:"4px 8px"}}>⭐ Rel: {e.reliability}/5</div>
                            {e.brokeDown&&<div style={{background:"#fef2f2",color:"#991b1b",borderRadius:6,padding:"4px 8px"}}>💀 Broke Down</div>}
                          </div>
                          {e.notes&&<div style={{width:"100%",fontSize:12,color:"#6b7280",marginTop:4}}>{e.notes}</div>}
                          <div style={{position:"absolute",top:10,right:10,fontWeight:700,fontSize:11,color:c}}>{overallLabel(e.overallRating||5)}</div>
                        </div>
                      );
                    })}
                  </div>
                )}
              </div>
            )}

            {/* ANALYSIS VIEW */}
            {scoutView==="analysis" && (
              <div>
                {teamSummaries.length===0 ? (
                  <div style={{textAlign:"center",padding:40,color:"#9ca3af"}}>Scout some teams first!</div>
                ) : (
                  <div>
                    <div style={{marginBottom:16}}>
                      <input value={analysisTeam} onChange={e=>setAnalysisTeam(e.target.value)} placeholder="Filter by team number..."
                        style={{width:"100%",padding:"10px 14px",borderRadius:9,border:"1.5px solid #e2e8f0",fontSize:14,boxSizing:"border-box",fontFamily:"inherit"}}/>
                    </div>
                    {teamSummaries.filter(t=>!analysisTeam||t.team.includes(analysisTeam)).map(t=>{
                      const c=overallColor(t.avgOvr);
                      return (
                        <div key={t.team} style={{background:"#fff",borderRadius:14,padding:18,border:`2px solid ${c}30`,marginBottom:12,boxShadow:`0 2px 12px ${c}10`}}>
                          <div style={{display:"flex",gap:14,alignItems:"center",marginBottom:14,flexWrap:"wrap"}}>
                            <div style={{width:56,height:56,borderRadius:12,background:`linear-gradient(135deg,${c},${c}cc)`,color:"#fff",display:"flex",alignItems:"center",justifyContent:"center",fontWeight:900,fontSize:22,flexShrink:0}}>{t.avgOvr.toFixed(1)}</div>
                            <div>
                              <div style={{fontWeight:900,fontSize:18}}>Team #{t.team}</div>
                              <div style={{fontSize:13,color:c,fontWeight:700}}>{overallLabel(t.avgOvr)}</div>
                              <div style={{fontSize:12,color:"#6b7280"}}>{t.entries.length} match{t.entries.length>1?"es":""} scouted</div>
                            </div>
                          </div>
                          <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(140px,1fr))",gap:10}}>
                            {[
                              ["⚡ Offense",t.avgOff.toFixed(1)+"/5","#1d4ed8"],
                              t.avgDef!==null?["🛡️ Defense",t.avgDef.toFixed(1)+"/5","#ea580c"]:null,
                              ["⭐ Reliability",t.avgRel.toFixed(1)+"/5","#7c3aed"],
                              ["🧗 Climb Rate",Math.round(t.climbPct)+"%","#059669"],
                              t.avgAuto!==null?["🤖 Avg Auto",t.avgAuto.toFixed(0)+" pts","#0891b2"]:null,
                              ["💀 Breakdown",t.entries.filter(e=>e.brokeDown).length+" of "+t.entries.length,"#dc2626"],
                            ].filter(Boolean).map(([l,v,c2])=>(
                              <div key={l} style={{background:"#f8fafc",borderRadius:9,padding:"10px 12px",border:`1px solid ${c2}20`}}>
                                <div style={{fontSize:11,color:"#9ca3af",marginBottom:3}}>{l}</div>
                                <div style={{fontWeight:900,fontSize:18,color:c2}}>{v}</div>
                              </div>
                            ))}
                          </div>
                          {t.entries.some(e=>e.scoringZone?.length>0) && (
                            <div style={{marginTop:10}}>
                              <div style={{fontSize:11,color:"#9ca3af",marginBottom:5}}>Scoring Zones Used</div>
                              <div style={{display:"flex",flexWrap:"wrap",gap:4}}>
                                {[...new Set(t.entries.flatMap(e=>e.scoringZone||[]))].map(z=>(
                                  <span key={z} style={{fontSize:11,background:"#eff6ff",color:"#1e40af",borderRadius:5,padding:"2px 7px",fontWeight:600}}>{z}</span>
                                ))}
                              </div>
                            </div>
                          )}
                          {t.entries.some(e=>e.notes) && (
                            <div style={{marginTop:10,fontSize:12,color:"#6b7280",background:"#f8fafc",borderRadius:7,padding:"8px 12px"}}>
                              {t.entries.filter(e=>e.notes).map((e,i)=><div key={i}>{e.notes}</div>)}
                            </div>
                          )}
                        </div>
                      );
                    })}

                    {/* Alliance Recommendation */}
                    {teamSummaries.length>=3 && (
                      <div style={{background:"linear-gradient(135deg,#1e3a8a,#4f46e5)",borderRadius:14,padding:18,color:"#fff",marginTop:8}}>
                        <div style={{fontWeight:800,fontSize:16,marginBottom:12}}>🤝 Top Alliance Recommendation</div>
                        <div style={{display:"flex",gap:10,flexWrap:"wrap"}}>
                          {teamSummaries.slice(0,3).map((t,i)=>(
                            <div key={t.team} style={{flex:1,minWidth:100,background:"rgba(255,255,255,0.12)",borderRadius:10,padding:"12px 14px",textAlign:"center"}}>
                              <div style={{fontSize:11,opacity:0.7,marginBottom:3}}>#{i+1} Pick</div>
                              <div style={{fontWeight:900,fontSize:18}}>Team {t.team}</div>
                              <div style={{fontSize:14,fontWeight:700,color:"#fbbf24"}}>{t.avgOvr.toFixed(1)}/10</div>
                            </div>
                          ))}
                        </div>
                        <div style={{fontSize:12,opacity:0.6,marginTop:10}}>Based on overall rating across all scouted matches. Always combine with live observations.</div>
                      </div>
                    )}
                  </div>
                )}
              </div>
            )}
          </div>
        );
      })()}

      {/* ── ALLIANCE PICKER ── */}
      {tool==="alliance" && (
        <div>
          <div style={{fontWeight:800,fontSize:17,marginBottom:4}}>🤝 Alliance Picker</div>
          <div style={{color:"#6b7280",fontSize:13,marginBottom:16}}>Enter candidate teams, compare stats, and build your ideal alliance.</div>
          <div style={{display:"flex",flexDirection:"column",gap:10,marginBottom:16}}>
            {allianceTeams.map((team,i)=>(
              <div key={i} style={{background:"#fff",borderRadius:12,padding:14,border:"1px solid #e2e8f0"}}>
                <div style={{fontWeight:700,fontSize:13,marginBottom:10,color:"#1d4ed8"}}>🤖 Robot {i+1}</div>
                <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(120px,1fr))",gap:8}}>
                  {[["Team #","num","e.g. 4512"],["OPR","opr","e.g. 42"],["Auto Pts","auto","e.g. 15"],["Teleop Pts","teleop","e.g. 30"],["Climb","climb","none/low/high"]].map(([label,key,ph])=>(
                    <div key={key}>
                      <div style={{fontSize:11,color:"#9ca3af",marginBottom:3}}>{label}</div>
                      <input value={team[key]} onChange={e=>{const t=[...allianceTeams];t[i]={...t[i],[key]:e.target.value};setAllianceTeams(t);}}
                        placeholder={ph} style={{width:"100%",padding:"7px 10px",borderRadius:7,border:"1px solid #e2e8f0",fontSize:13,boxSizing:"border-box",fontFamily:"inherit"}}/>
                    </div>
                  ))}
                  <div>
                    <div style={{fontSize:11,color:"#9ca3af",marginBottom:3}}>Notes</div>
                    <input value={team.notes} onChange={e=>{const t=[...allianceTeams];t[i]={...t[i],notes:e.target.value};setAllianceTeams(t);}}
                      placeholder="Strengths/weaknesses" style={{width:"100%",padding:"7px 10px",borderRadius:7,border:"1px solid #e2e8f0",fontSize:13,boxSizing:"border-box",fontFamily:"inherit"}}/>
                  </div>
                </div>
              </div>
            ))}
          </div>
          <div style={{display:"flex",gap:8,marginBottom:20,flexWrap:"wrap"}}>
            <button onClick={()=>setAllianceTeams([...allianceTeams,{num:"",opr:"",auto:"",teleop:"",climb:"",notes:""}])}
              style={{background:"#1d4ed8",color:"#fff",border:"none",borderRadius:8,padding:"8px 16px",cursor:"pointer",fontWeight:700,fontSize:13,fontFamily:"inherit"}}>+ Add Robot</button>
            {allianceTeams.length>3&&<button onClick={()=>setAllianceTeams(allianceTeams.slice(0,-1))}
              style={{background:"#ef4444",color:"#fff",border:"none",borderRadius:8,padding:"8px 16px",cursor:"pointer",fontWeight:700,fontSize:13,fontFamily:"inherit"}}>− Remove Last</button>}
          </div>
          {/* Alliance summary */}
          {allianceTeams.some(t=>t.num) && (
            <div style={{background:"linear-gradient(135deg,#1e3a8a,#1d4ed8)",borderRadius:14,padding:20,color:"#fff"}}>
              <div style={{fontWeight:800,fontSize:15,marginBottom:12}}>📊 Alliance Summary</div>
              <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(140px,1fr))",gap:10}}>
                {[
                  ["Total Projected Auto", allianceTeams.reduce((s,t)=>s+(parseFloat(t.auto)||0),0).toFixed(0)+" pts"],
                  ["Total Projected Teleop", allianceTeams.reduce((s,t)=>s+(parseFloat(t.teleop)||0),0).toFixed(0)+" pts"],
                  ["Combined OPR", allianceTeams.reduce((s,t)=>s+(parseFloat(t.opr)||0),0).toFixed(1)],
                  ["Climbers", allianceTeams.filter(t=>t.climb&&t.climb!=="none"&&t.climb!=="").length+"/"+allianceTeams.length],
                ].map(([label,val])=>(
                  <div key={label} style={{background:"rgba(255,255,255,0.1)",borderRadius:10,padding:"10px 14px"}}>
                    <div style={{fontSize:11,opacity:0.7,marginBottom:2}}>{label}</div>
                    <div style={{fontWeight:800,fontSize:18}}>{val}</div>
                  </div>
                ))}
              </div>
              <div style={{marginTop:12,fontSize:12,opacity:0.7}}>
                Teams: {allianceTeams.filter(t=>t.num).map(t=>"#"+t.num).join(" + ")}
              </div>
            </div>
          )}
        </div>
      )}

      {/* ── PIT SCOUT ── */}
      {tool==="pitscout" && (
        <div>
          <div style={{fontWeight:800,fontSize:17,marginBottom:4}}>🏗️ Pit Scouting Form</div>
