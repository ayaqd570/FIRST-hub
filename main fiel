Every modern FRC robot uses command-based. Subsystems own hardware. Commands operate subsystems.

## Writing a Subsystem
\`\`\`java
public class Shooter extends SubsystemBase {
    private final CANSparkMax motor = new CANSparkMax(5, kBrushless);
    private final SparkMaxPIDController pid = motor.getPIDController();
    private double targetRPM = 0;

    public Shooter() {
        motor.restoreFactoryDefaults();
        motor.setIdleMode(kCoast);
        pid.setP(0.0003); pid.setFF(0.000175);
    }

    public void setRPM(double rpm) {
        targetRPM = rpm;
        pid.setReference(rpm, kVelocity);
    }

    public boolean atSpeed() {
        return Math.abs(motor.getEncoder().getVelocity() - targetRPM) < 50;
    }

    @Override public void periodic() {
        SmartDashboard.putNumber("Shooter RPM",
            motor.getEncoder().getVelocity());
    }
}
