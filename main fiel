      {id:"pi12",title:"Match Simulation with Python",est:"28 min",content:`## Simulate Matches Before Playing Them

Simulation lets you answer questions like "what if we focus on cycles instead of climbing?" before you're on the field.

### Simple Match Simulator
\`\`\`python
import random

def simulate_match(team_a, team_b, team_c, team_d, team_e, team_f, n=1000):
    """
    Alliance 1: team_a, team_b, team_c
    Alliance 2: team_d, team_e, team_f
    n = number of simulations
    Returns: win probability for Alliance 1
    """
    wins = 0
    for _ in range(n):
        score1 = sum(simulate_robot(t) for t in [team_a, team_b, team_c])
        score2 = sum(simulate_robot(t) for t in [team_d, team_e, team_f])
        if score1 > score2:
            wins += 1
    return wins / n

def simulate_robot(team_stats):
    """Simulate one robot's score with variance"""
    # Base score ± std deviation (normal distribution)
    auto   = max(0, random.gauss(team_stats['avg_auto'],   team_stats['std_auto']))
    teleop = max(0, random.gauss(team_stats['avg_teleop'], team_stats['std_teleop']))
    climb  = team_stats['climb_pts'] if random.random() < team_stats['climb_pct'] else 0
    return auto + teleop + climb
