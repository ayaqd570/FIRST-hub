  const [assembled, setAssembled] = useState([]);
  const [phase, setPhase] = useState("learn"); // learn | build | quiz | done
  const [quizIdx, setQuizIdx] = useState(0);
  const [quizAns, setQuizAns] = useState(null);
  const [quizScore, setQuizScore] = useState(0);

  const BLOCK_COLORS = {
    control:    {bg:"#fef3c7", border:"#f59e0b", text:"#92400e", icon:"🔄"},
    action:     {bg:"#dbeafe", border:"#3b82f6", text:"#1e40af", icon:"⚡"},
    sensor:     {bg:"#d1fae5", border:"#10b981", text:"#065f46", icon:"📡"},
    variable:   {bg:"#ede9fe", border:"#8b5cf6", text:"#4c1d95", icon:"📦"},
    comment:    {bg:"#f1f5f9", border:"#94a3b8", text:"#475569", icon:"💬"},
    math:       {bg:"#fce7f3", border:"#ec4899", text:"#9d174d", icon:"➕"},
