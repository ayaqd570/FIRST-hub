              <div style={{color:"#64748b",fontSize:13,marginBottom:14}}>Irreversible actions — use with caution.</div>
              <div style={{display:"flex",gap:10,flexWrap:"wrap"}}>
                <button style={S.btnSm("#dc2626")} onClick={async()=>{
                  const ok = window.confirm ? window.confirm("Delete ALL student accounts? Cannot be undone!") : true;
                  if(!ok) return;
