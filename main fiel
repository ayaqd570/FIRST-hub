          </div>
        </div>

        <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:16,marginBottom:16}}>
          {/* Subject breakdown */}
          <div style={{...S.card,gridColumn:"1/-1"}}>
            <div style={{fontWeight:700,color:"#f1f5f9",fontSize:15,marginBottom:14}}>📚 Subject Breakdown</div>
            {subjectStats.map(s=>(
              <div key={s.id} style={{marginBottom:12}}>
                <div style={{display:"flex",justifyContent:"space-between",marginBottom:4}}>
                  <span style={{fontSize:13,color:"#cbd5e1"}}>{s.icon} {s.name}</span>
                  <div style={{display:"flex",gap:10,fontSize:12}}>
                    {s.avgQuiz!==null&&<span style={{color:s.avgQuiz>=80?"#34d399":s.avgQuiz>=60?"#fbbf24":"#f87171",fontWeight:700}}>Quiz: {s.avgQuiz}%</span>}
                    <span style={{color:"#94a3b8"}}>{s.done} done</span>
                    <span style={{fontWeight:700,color:s.pct>=60?"#34d399":s.pct>=30?"#fbbf24":"#f87171"}}>{s.pct}%</span>
                  </div>
                </div>
                <div style={{background:"#334155",borderRadius:999,height:6}}>
                  <div style={{width:`${s.pct}%`,background:s.color,height:"100%",borderRadius:999}}></div>
