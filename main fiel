static final double TICKS_PER_REV  = 537.7;
static final double WHEEL_DIAM_CM  = 9.6;
static final double TICKS_PER_CM   = TICKS_PER_REV / (WHEEL_DIAM_CM * Math.PI);

public void driveInches(double inches, double power) {
    int ticks = (int)(inches * 2.54 * TICKS_PER_CM);
    leftMotor.setTargetPosition(leftMotor.getCurrentPosition() + ticks);
    rightMotor.setTargetPosition(rightMotor.getCurrentPosition() + ticks);
    leftMotor.setMode(DcMotor.RunMode.RUN_TO_POSITION);
    rightMotor.setMode(DcMotor.RunMode.RUN_TO_POSITION);
    leftMotor.setPower(Math.abs(power));
    rightMotor.setPower(Math.abs(power));
    while (opModeIsActive() && (leftMotor.isBusy() || rightMotor.isBusy())) {
        telemetry.addData("Target", leftMotor.getTargetPosition());
        telemetry.update();
    }
    leftMotor.setPower(0); rightMotor.setPower(0);
}
