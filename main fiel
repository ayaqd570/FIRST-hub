}

// ─── ADMIN TEAMS PANEL ────────────────────────────────────
function AdminTeamsPanel() {
  const [teams, setTeams] = useState(null);
  const [users, setUsers] = useState({});
  const [loading, setLoading] = useState(true);

  useEffect(() => {
    Promise.all([storeGet("hub-teams",true), storeGet("hub-users",true)]).then(([t,u]) => {
      setTeams(t||{}); setUsers(u||{}); setLoading(false);
    });
  }, []);

  async function deleteTeam(teamId) {
    if (!confirm("Delete this team? Members will lose their team association.")) return;
    const updated = {...teams};
    // Unlink members
    const usersUpdated = {...users};
    Object.keys(usersUpdated).forEach(uname => {
      if (usersUpdated[uname].teamId === teamId) {
        delete usersUpdated[uname].teamId;
        delete usersUpdated[uname].teamName;
        delete usersUpdated[uname].isTeamAdmin;
      }
    });
    delete updated[teamId];
    await storeSet("hub-teams", updated, true);
    await storeSet("hub-users", usersUpdated, true);
    setTeams(updated); setUsers(usersUpdated);
  }

  if (loading) return <div style={{color:"#64748b",padding:30}}>Loading teams…</div>;

  const teamList = Object.values(teams||{});
  return (
    <div>
      <div style={{fontWeight:900,fontSize:22,color:"#f1f5f9",marginBottom:18}}>🏷 Registered Teams</div>
      {teamList.length===0 && (
        <div style={{background:"#1e293b",borderRadius:12,padding:40,textAlign:"center",color:"#475569"}}>No teams created yet. Members create teams from the registration screen.</div>
      )}
      <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(300px,1fr))",gap:14}}>
        {teamList.map(team => {
          const memberDetails = (team.members||[]).map(uname => ({uname, ...users[uname]}));
          return (
            <div key={team.id} style={{background:"#1e293b",borderRadius:14,padding:18,border:"1px solid #334155"}}>
              <div style={{display:"flex",justifyContent:"space-between",alignItems:"flex-start",marginBottom:10}}>
                <div>
                  <div style={{fontWeight:900,fontSize:16,color:"#f1f5f9"}}>{team.name}</div>
                  <div style={{fontSize:12,color:"#64748b",marginTop:2}}>Created {new Date(team.createdAt).toLocaleDateString()}</div>
                </div>
                <div style={{background:"#0f172a",borderRadius:8,padding:"6px 12px",textAlign:"center"}}>
                  <div style={{fontFamily:"monospace",fontWeight:900,color:"#fbbf24",fontSize:16,letterSpacing:2}}>{team.code}</div>
                  <div style={{fontSize:9,color:"#475569",marginTop:1}}>JOIN CODE</div>
                </div>
              </div>
              <div style={{marginBottom:12}}>
                <div style={{fontSize:11,color:"#475569",textTransform:"uppercase",fontWeight:700,letterSpacing:1,marginBottom:6}}>Members ({memberDetails.length})</div>
                {memberDetails.map(m => (
                  <div key={m.uname} style={{display:"flex",alignItems:"center",gap:8,padding:"5px 0",borderBottom:"1px solid #0f172a"}}>
                    <div style={{width:24,height:24,background:`hsl(${m.uname?.charCodeAt(0)*13%360},50%,40%)`,borderRadius:5,display:"flex",alignItems:"center",justifyContent:"center",color:"#fff",fontWeight:900,fontSize:10}}>{m.name?.charAt(0)?.toUpperCase()}</div>
                    <div style={{flex:1}}>
                      <span style={{fontSize:12,color:"#cbd5e1",fontWeight:600}}>{m.name}</span>
                      {m.uname===team.createdBy && <span style={{fontSize:9,background:"#854d0e",color:"#fef3c7",padding:"1px 5px",borderRadius:3,marginLeft:5,fontWeight:700}}>CAPTAIN</span>}
                    </div>
                    {m.placementResult?.role && <span style={{fontSize:10,color:m.placementResult.role.color,fontWeight:700}}>{m.placementResult.role.name?.split(" ")[0]}</span>}
                  </div>
                ))}
