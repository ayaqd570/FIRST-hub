// ─── MARKDOWN RENDERER ────────────────────────────────────
function renderMD(text) {
  if (!text) return null;
  const lines = text.split('\n');
  const els = []; let i = 0;
  while (i < lines.length) {
    const line = lines[i];
    if (line.startsWith('## ')) {
      els.push(<h3 key={i} style={{color:'#1d4ed8',margin:'18px 0 6px',fontSize:15,fontWeight:800,borderBottom:'2px solid #dbeafe',paddingBottom:4}}>{line.slice(3)}</h3>);
      i++;
    } else if (line.startsWith('### ')) {
      els.push(<h4 key={i} style={{color:'#b91c1c',margin:'14px 0 4px',fontSize:14,fontWeight:700}}>{line.slice(4)}</h4>);
      i++;
    } else if (line.startsWith('```')) {
      const lang = line.slice(3).trim();
      const code = [];
      i++;
      while (i < lines.length && !lines[i].startsWith('```')) { code.push(lines[i]); i++; }
      i++;
      els.push(
        <div key={i} style={{background:'#0f172a',borderRadius:10,padding:'14px 16px',margin:'10px 0',overflowX:'auto',border:'1px solid #1e293b'}}>
          {lang && <div style={{color:'#64748b',fontSize:11,marginBottom:6,fontFamily:'monospace',textTransform:'uppercase',letterSpacing:1}}>{lang}</div>}
          <pre style={{color:'#e2e8f0',margin:0,fontSize:13,lineHeight:1.7,fontFamily:"'Fira Code','Cascadia Code','Courier New',monospace",whiteSpace:'pre-wrap'}}>{code.join('\n')}</pre>
        </div>
      );
    } else if (line.startsWith('- ') || line.startsWith('• ')) {
      const items = [];
      while (i < lines.length && (lines[i].startsWith('- ')||lines[i].startsWith('• '))) { items.push(lines[i].slice(2)); i++; }
      els.push(<ul key={i} style={{margin:'6px 0 10px',paddingLeft:20}}>{items.map((it,j)=><li key={j} style={{margin:'3px 0',lineHeight:1.6,fontSize:14}} dangerouslySetInnerHTML={{__html:it.replace(/\*\*(.+?)\*\*/g,'<strong>$1</strong>').replace(/`(.+?)`/g,'<code style="background:#f1f5f9;padding:1px 5px;border-radius:3px;font-size:12px;font-family:monospace">$1</code>')}}/>)}</ul>);
    } else if (line.startsWith('✅')||line.startsWith('❌')||line.startsWith('□')) {
      const items = [];
      while (i < lines.length && (lines[i].startsWith('✅')||lines[i].startsWith('❌')||lines[i].startsWith('□'))) { items.push(lines[i]); i++; }
      els.push(<div key={i} style={{margin:'6px 0 10px'}}>{items.map((it,j)=><div key={j} style={{margin:'4px 0',fontSize:14,lineHeight:1.6,padding:'3px 8px',background:it.startsWith('✅')?'#f0fdf4':it.startsWith('❌')?'#fef2f2':'#f8fafc',borderRadius:5}} dangerouslySetInnerHTML={{__html:it.replace(/\*\*(.+?)\*\*/g,'<strong>$1</strong>')}}/>)}</div>);
    } else if (line.startsWith('|')) {
      const rows = [];
      while (i < lines.length && lines[i].startsWith('|')) { if (!lines[i].match(/^\|[\s\-|]+\|$/)) rows.push(lines[i]); i++; }
      els.push(<div key={i} style={{overflowX:'auto',margin:'10px 0',borderRadius:8,border:'1px solid #e2e8f0'}}><table style={{borderCollapse:'collapse',width:'100%',fontSize:13}}>{rows.map((row,ri)=>{const cells=row.split('|').filter(c=>c.trim()!=='');return(<tr key={ri} style={{background:ri===0?'#1e40af':ri%2===0?'#f8fafc':'#fff'}}>{cells.map((c,ci)=>{const Tag=ri===0?'th':'td';return<Tag key={ci} style={{padding:'8px 12px',borderBottom:'1px solid #e2e8f0',color:ri===0?'#fff':'#374151',fontWeight:ri===0?700:400,textAlign:'left'}} dangerouslySetInnerHTML={{__html:c.trim().replace(/\*\*(.+?)\*\*/g,'<strong>$1</strong>')}}/>;})}</tr>);})}</table></div>);
    } else if (line.trim()==='---') {
      els.push(<hr key={i} style={{border:'none',borderTop:'2px solid #e2e8f0',margin:'14px 0'}}/>);
      i++;
    } else if (line.trim()==='') {
      els.push(<div key={i} style={{height:6}}/>);
      i++;
    } else {
      const html = line.replace(/\*\*(.+?)\*\*/g,'<strong>$1</strong>').replace(/`(.+?)`/g,'<code style="background:#f1f5f9;padding:1px 5px;border-radius:3px;font-family:monospace;font-size:12px">$1</code>');
      els.push(<p key={i} style={{margin:'3px 0 6px',lineHeight:1.7,fontSize:14}} dangerouslySetInnerHTML={{__html:html}}/>);
      i++;
    }
  }
  return els;
}

// ─── SCENARIO LESSON RENDERER ─────────────────────────────
function ScenarioLesson({ lesson }) {
  const [phase, setPhase] = useState("intro");
  const [scIdx, setScIdx] = useState(0);
  const [chosen, setChosen] = useState(null);
  const [revealed, setRevealed] = useState(false);

  const sc = lesson.scenarios[scIdx];
  const total = lesson.scenarios.length;

  if (phase === "intro") return (
    <div>
      <div style={{background:"linear-gradient(135deg,#1e3a8a,#1d4ed8)",borderRadius:14,padding:22,color:"#fff",marginBottom:18}}>
        <div style={{fontSize:28,marginBottom:8}}>🎯 Scenario Training</div>
        <div style={{fontSize:15,opacity:0.9,lineHeight:1.6,marginBottom:16}}>{lesson.intro}</div>
        <div style={{fontSize:13,opacity:0.75}}>{total} scenario{total>1?"s":""} · Make decisions, see outcomes</div>
      </div>
      <button style={{background:"#1d4ed8",color:"#fff",border:"none",padding:"11px 24px",borderRadius:9,cursor:"pointer",fontWeight:700,fontSize:14,fontFamily:"inherit"}} onClick={()=>setPhase("quiz")}>Start Scenarios →</button>
    </div>
  );

  if (phase === "done") return (
    <div style={{background:"linear-gradient(135deg,#166534,#16a34a)",borderRadius:14,padding:24,color:"#fff",textAlign:"center"}}>
      <div style={{fontSize:40,marginBottom:10}}>🏆</div>
      <div style={{fontSize:22,fontWeight:900,marginBottom:6}}>Scenarios Complete!</div>
      <div style={{fontSize:14,opacity:0.85,marginBottom:16}}>You've worked through all {total} real FIRST decision scenarios.</div>
      <button style={{background:"rgba(255,255,255,0.2)",border:"2px solid rgba(255,255,255,0.5)",color:"#fff",padding:"9px 22px",borderRadius:8,cursor:"pointer",fontWeight:700,fontSize:13,fontFamily:"inherit"}} onClick={()=>{setPhase("intro");setScIdx(0);setChosen(null);setRevealed(false);}}>Replay Scenarios</button>
    </div>
  );

  const choiceColors = ["#1d4ed8","#7c3aed","#b45309"];

  return (
    <div>
      <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:14}}>
        <div style={{fontWeight:800,fontSize:15,color:"#0f172a"}}>🎯 Scenario {scIdx+1} of {total}</div>
        <div style={{background:"#e2e8f0",borderRadius:20,height:6,width:120,overflow:"hidden"}}>
          <div style={{background:"#1d4ed8",width:`${((scIdx)/total)*100}%`,height:"100%",borderRadius:20,transition:"width 0.4s"}}/>
        </div>
      </div>
      <div style={{background:"#fef9f0",border:"2px solid #fed7aa",borderRadius:12,padding:18,marginBottom:18}}>
        <div style={{fontWeight:700,fontSize:15,color:"#92400e",lineHeight:1.6}}>{sc.question}</div>
      </div>
      <div style={{display:"flex",flexDirection:"column",gap:10,marginBottom:16}}>
        {sc.choices.map((ch,i)=>{
          let bg="#f8fafc",border="1.5px solid #e2e8f0",col="#374151";
          if(revealed){
            if(i===sc.correct){bg="#f0fdf4";border="2px solid #86efac";col="#166534";}
            else if(chosen===i){bg="#fef2f2";border="2px solid #fca5a5";col="#991b1b";}
          } else if(chosen===i){bg=choiceColors[i%3]+"12";border=`2px solid ${choiceColors[i%3]}`;col=choiceColors[i%3];}
          return (
            <button key={i} onClick={()=>{if(!revealed)setChosen(i);}}
              style={{background:bg,border,color:col,padding:"12px 16px",borderRadius:10,cursor:revealed?"default":"pointer",textAlign:"left",fontWeight:chosen===i?700:500,fontSize:14,fontFamily:"inherit",transition:"all 0.15s",lineHeight:1.5}}>
              <span style={{fontWeight:800,marginRight:10}}>{String.fromCharCode(65+i)}.</span>{ch}
            </button>
          );
        })}
      </div>
      {revealed && (
        <div style={{background:chosen===sc.correct?"#f0fdf4":"#fff7ed",border:`2px solid ${chosen===sc.correct?"#86efac":"#fed7aa"}`,borderRadius:10,padding:14,marginBottom:14,fontSize:14,lineHeight:1.6,color:chosen===sc.correct?"#166534":"#92400e"}}>
          <div style={{fontWeight:800,marginBottom:4}}>{chosen===sc.correct?"✅ Good thinking!":"💡 Here's why:"}</div>
          {sc.outcomes[chosen]}
        </div>
      )}
      <div style={{display:"flex",gap:10}}>
        {!revealed && <button style={{background:"#1d4ed8",color:"#fff",border:"none",padding:"9px 20px",borderRadius:8,cursor:"pointer",fontWeight:700,fontSize:14,fontFamily:"inherit",opacity:chosen===null?0.5:1}} onClick={()=>setRevealed(true)} disabled={chosen===null}>See Outcome</button>}
        {revealed && <button style={{background:"#16a34a",color:"#fff",border:"none",padding:"9px 20px",borderRadius:8,cursor:"pointer",fontWeight:700,fontSize:14,fontFamily:"inherit"}} onClick={()=>{if(scIdx+1>=total){setPhase("done");}else{setScIdx(s=>s+1);setChosen(null);setRevealed(false);}}}>
          {scIdx+1>=total?"Finish ✓":"Next Scenario →"}
        </button>}
      </div>
    </div>
  );
}

