                </div>
                <button onClick={()=>deleteTask(t.id)} style={{background:"none",border:"none",color:"#cbd5e1",cursor:"pointer",fontSize:16,padding:2,flexShrink:0}}>✕</button>
              </div>
            );
          })}
        </div>
      )}

      {/* Category progress bars */}
      {total>0&&(
        <div style={{background:"#fff",borderRadius:14,border:"1px solid #e2e8f0",padding:"16px 18px",marginTop:20}}>
          <div style={{fontWeight:700,fontSize:13,marginBottom:12}}>📊 Progress by Category</div>
          <div style={{display:"flex",flexDirection:"column",gap:8}}>
            {CATS.map(cat=>{
              const catTasks = tasks.filter(t=>t.cat===cat.id);
              if (!catTasks.length) return null;
              const catDone = catTasks.filter(t=>t.done).length;
              const pct = Math.round(catDone/catTasks.length*100);
              return (
                <div key={cat.id}>
                  <div style={{display:"flex",justifyContent:"space-between",marginBottom:4,fontSize:12}}>
                    <span style={{fontWeight:600,color:"#374151"}}>{cat.label}</span>
                    <span style={{color:"#94a3b8"}}>{catDone}/{catTasks.length}</span>
                  </div>
                  <div style={{height:6,background:"#f1f5f9",borderRadius:3,overflow:"hidden"}}>
                    <div style={{width:`${pct}%`,height:"100%",background:cat.color,borderRadius:3,transition:"width 0.4s"}}/>
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      )}
    </div>
  );
}

