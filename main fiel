                      f"Location: {data.get('city')}, {data.get('state_prov')}\\n"
                      f"Rookie Year: {data.get('rookie_year')}")
    else:
        await ctx.send("Team not found.")

bot.run(os.getenv("DISCORD_TOKEN"))
