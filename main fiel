  const [mobileMenuOpen, setMobileMenuOpen] = useState(false);
  const [placementResult, setPlacementResult] = useState(null);

  // Learn state
  const [selSub, setSelSub] = useState(null);
  const [selLevel, setSelLevel] = useState("Beginner");
  const [selLesson, setSelLesson] = useState(null);
  const [done, setDone] = useState({});
  const [quizMode, setQuizMode] = useState(false);
  const [lessonNote, setLessonNote] = useState("");
  const [showLessonNote, setShowLessonNote] = useState(false);
  const [bookmarks, setBookmarks] = useState([]);
  const [savingNote, setSavingNote] = useState(false);

  // Forum state
  const [posts, setPosts] = useState([]);
  const [viewPost, setViewPost] = useState(null);
  const [showNewPost, setShowNewPost] = useState(false);
  const [npTitle, setNpTitle] = useState("");
  const [npBody, setNpBody] = useState("");
  const [repText, setRepText] = useState("");

  // Announcements
  const [anns, setAnns] = useState([]);

  // Messages
  const [inbox, setInbox] = useState([]);
  const [replyText, setReplyText] = useState("");
  const [showInbox, setShowInbox] = useState(false);

  const [loading, setLoading] = useState(false);
  const [newAchievements, setNewAchievements] = useState([]);

  // Define early so useCallbacks below can reference it
  const totalLessons = Object.values(LESSONS).reduce((a,s)=>a+Object.values(s).reduce((b,l)=>b+l.length,0),0);

  useEffect(()=>{ loadShared(); },[]);
  useEffect(()=>{ if(user&&!user.isAdmin) loadUserData(); },[user]);
useEffect(()=>{
  const interval = setInterval(()=>{
    loadShared();
    if(user&&!user.isAdmin) loadUserData();
  }, 15000);
  return ()=>clearInterval(interval);
},[user]);

  async function loadShared() {
    setLoading(true);
    const p = await storeGet("fr-posts",true); if(p) setPosts(p);
    const a = await storeGet("fr-anns",true); if(a) setAnns(a);
    setLoading(false);
  }

  async function loadUserData() {
    if (!user||user.isAdmin) return;
    const users = await storeGet("hub-users",true)||{};
    const u = users[user.username];
    if (u) {
      setDone(u.done||{});
      setInbox(u.messages||[]);
      if(u.placementResult) setPlacementResult(u.placementResult);
      if(u.bookmarks) setBookmarks(u.bookmarks);
    }
  }

  const savePosts = useCallback(async p=>{setPosts(p);await storeSet("fr-posts",p,true);},[]);
  const saveAnns = useCallback(async a=>{setAnns(a);await storeSet("fr-anns",a,true);},[]);

  // Time tracking: start timer when lesson opens, pause when leaving
  useEffect(()=>{
    if (selLesson && user && !user.isAdmin) {
      startLearningTimer();
      setShowLessonNote(false);
      // Load existing note for this lesson
      storeGet("hub-users",true).then(users=>{
        const note = users?.[user.username]?.notes?.[selLesson.id] || "";
        setLessonNote(note);
      });
      return () => {
        const t = stopLearningTimer();
        if (t > 0) addLearningTime(user.username, t);
      };
    }
  }, [selLesson?.id]);

  const markDone = useCallback(async id=>{
    if (!user) return;
    // Save elapsed learning time
    const elapsed = stopLearningTimer();
    if (elapsed > 0) addLearningTime(user.username, elapsed);
    // Update streak
    await updateStreak(user.username);
    setDone(prev=>{
      const c={...prev,[id]:true};
      storeGet("hub-users",true).then(async users=>{
        if(users&&users[user.username]){
          users[user.username].done=c;
          await storeSet("hub-users",users,true);
          // Check for new achievements
          const newAchs = await checkAndUnlockAchievements(user.username, totalLessons);
          if (newAchs.length > 0) {
            setNewAchievements(prev=>[...prev,...newAchs]);
          }
        }
      });
      return c;
    });
  },[user,totalLessons]);

  const saveQuizScore = useCallback(async(subjectId,level,score,total)=>{
    if(!user) return;
    const users = await storeGet("hub-users",true)||{};
    if(users[user.username]){
      if(!users[user.username].quizScores) users[user.username].quizScores={};
      const key=`${subjectId}-${level}`;
      const prev = users[user.username].quizScores[key];
      if(!prev||score/total>prev.score/prev.total){
        users[user.username].quizScores[key]={score,total,ts:Date.now()};
        await storeSet("hub-users",users,true);
      }
    }
  },[user]);

  async function saveCurrentNote(lessonId) {
    if (!user || !lessonId) return;
    setSavingNote(true);
    const users = await storeGet("hub-users",true)||{};
    if(users[user.username]) {
      users[user.username].notes = {...(users[user.username].notes||{}), [lessonId]: lessonNote};
      await storeSet("hub-users",users,true);
      await checkAndUnlockAchievements(user.username, totalLessons);
    }
    setSavingNote(false);
    setShowLessonNote(false);
  }

  async function toggleBookmark(lessonId) {
    if (!user) return;
    const users = await storeGet("hub-users",true)||{};
    if(!users[user.username]) return;
    const prev = users[user.username].bookmarks || [];
    const updated = prev.includes(lessonId) ? prev.filter(id=>id!==lessonId) : [...prev,lessonId];
