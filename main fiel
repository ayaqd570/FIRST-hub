        ))}
      </div>
      {loading && <div style={{ color: "#64748b", fontSize: 13 }}>Loading…</div>}
      <div style={{ maxHeight: 400, overflowY: "auto", display: "flex", flexDirection: "column", gap: 6 }}>
        {channelMsgs.length === 0 && <div style={{ color: "#475569", fontSize: 13, padding: 20, textAlign: "center" }}>No messages in this channel yet.</div>}
        {channelMsgs.map(msg => (
          <div key={msg.id} style={{ background: "#0f172a", borderRadius: 8, padding: "10px 12px", border: "1px solid #1e293b", display: "flex", alignItems: "flex-start", gap: 10 }}>
            <div style={{ width: 28, height: 28, background: `hsl(${msg.username?.charCodeAt(0) * 13 % 360},60%,40%)`, borderRadius: 6, display: "flex", alignItems: "center", justifyContent: "center", fontWeight: 900, color: "#fff", fontSize: 11, flexShrink: 0 }}>{msg.author?.charAt(0)?.toUpperCase()}</div>
            <div style={{ flex: 1, minWidth: 0 }}>
              <div style={{ display: "flex", justifyContent: "space-between", alignItems: "baseline", gap: 8 }}>
                <span style={{ fontWeight: 700, fontSize: 12, color: "#94a3b8" }}>{msg.author}</span>
                <span style={{ fontSize: 10, color: "#475569" }}>{new Date(msg.ts).toLocaleString()}</span>
              </div>
              {msg.text && <div style={{ fontSize: 13, color: "#cbd5e1", marginTop: 3, wordBreak: "break-word" }}>{msg.text}</div>}
              {msg.file && <div style={{ fontSize: 11, color: "#64748b", marginTop: 3 }}>📎 {msg.file.name}</div>}
