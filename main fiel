function CodeEditor({ user }) {
  const [lang, setLang] = useState("java");
  const [code, setCode] = useState(CODE_TEMPLATES.java.starter);
  const [output, setOutput] = useState("");
  const [saved, setSaved] = useState(false);
  const [savedSnippets, setSavedSnippets] = useState([]);
  const [snippetName, setSnippetName] = useState("");
  const [showSave, setShowSave] = useState(false);
  const [activeSnippet, setActiveSnippet] = useState(null);
  const [sharing, setSharing] = useState(false);
  const [shareMsg, setShareMsg] = useState("");
  const [shareTitle, setShareTitle] = useState("");
  const [sharedPosts, setSharedPosts] = useState([]);
  const [showShared, setShowShared] = useState(false);
  const [findText, setFindText] = useState("");
  const [showFind, setShowFind] = useState(false);
  const lineCount = code.split("\n").length;
  const charCount = code.length;
  const textareaRef = useRef(null);

  useEffect(() => { loadSnippets(); loadSharedCode(); }, []);

  async function loadSnippets() {
    const data = await storeGet("hub-code-" + user.username, false);
    if (data) setSavedSnippets(data);
  }

  async function loadSharedCode() {
    const data = await storeGet("hub-shared-code", true);
    if (data) setSharedPosts(data);
  }

  async function shareCode() {
    if (!shareTitle.trim()) { setShareMsg("Give your snippet a title first!"); return; }
    setSharing(true);
    const post = {
      id: Date.now().toString(),
      title: shareTitle.trim(),
      lang, code,
      author: user.name,
      username: user.username,
      ts: Date.now(),
      likes: [],
    };
    const existing = await storeGet("hub-shared-code", true) || [];
    const updated = [post, ...existing].slice(0, 50);
    await storeSet("hub-shared-code", updated, true);
    setSharedPosts(updated);
    setSharing(false);
    setShareTitle("");
    setShareMsg("✅ Code shared with your team!");
    setShowShared(true);
    setTimeout(() => setShareMsg(""), 3000);
  }

  async function likePost(postId) {
    const updated = sharedPosts.map(p => {
      if (p.id !== postId) return p;
      const already = (p.likes||[]).includes(user.username);
      return {...p, likes: already ? p.likes.filter(u=>u!==user.username) : [...(p.likes||[]), user.username]};
    });
    setSharedPosts(updated);
    await storeSet("hub-shared-code", updated, true);
  }

  async function deleteSharedPost(postId) {
    const updated = sharedPosts.filter(p => p.id !== postId);
    setSharedPosts(updated);
    await storeSet("hub-shared-code", updated, true);
  }

  function findInCode() {
    if (!findText.trim()) return;
    const ta = textareaRef.current;
    const idx = code.indexOf(findText);
    if (idx === -1) { setShareMsg("Text not found."); setTimeout(()=>setShareMsg(""),2000); return; }
    ta.focus();
    setTimeout(() => { ta.selectionStart = idx; ta.selectionEnd = idx + findText.length; }, 0);
  }

  function handleLangChange(newLang) {
    const hasChanges = code !== CODE_TEMPLATES[lang].starter;
    if (hasChanges && window.confirm && !window.confirm("Switch language? Unsaved changes will be lost.")) return;
    setLang(newLang); setCode(CODE_TEMPLATES[newLang].starter); setOutput(""); setActiveSnippet(null);
  }

  function runCode() {
    if (lang === "html") { setOutput("__HTML_PREVIEW__"); return; }
    const lines = code.split("\n").filter(l => l.trim()).length;
    const issues = [];
    if (lang === "java") {
      if (!code.includes(";")) issues.push("\u26a0  Missing semicolons — every Java statement needs a semicolon.");
      if (code.includes("setpower") || code.includes("SetPower")) issues.push("\u26a0  Case-sensitive: use .setPower() not .setpower()");
      if (!code.includes("hardwareMap") && code.includes("DcMotor")) issues.push("\ud83d\udca1  Initialize motors with hardwareMap.get(DcMotor.class, name)");
    }
    if (lang === "python") {
      if (code.includes("    ") && code.includes("\t")) issues.push("\u26a0  Mixed tabs and spaces — Python requires one or the other.");
    }
    const summary = [
      "\ud83d\udcca Code Analysis",
      "\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500",
      "Lines of code: " + lines,
      "",
      issues.length > 0 ? "\u26a0  Issues found:" : "\u2705 No obvious issues found",
      ...issues,
      "",
      "\u2139\ufe0f  This is a static analyzer, not a live compiler.",
      "   Use Android Studio (FTC) or WPILib VSCode (FRC) for real execution.",
    ].join("\n");
    setOutput(summary);
  }

  async function saveSnippet() {
    if (!snippetName.trim()) return;
    const snippet = { id: Date.now().toString(), name: snippetName.trim(), lang, code, ts: Date.now() };
    const updated = [snippet, ...savedSnippets.filter(s=>s.id!==activeSnippet)].slice(0, 20);
    setSavedSnippets(updated);
    await storeSet("hub-code-" + user.username, updated, false);
    setSnippetName(""); setShowSave(false); setSaved(true);
    setTimeout(() => setSaved(false), 2500);
    setActiveSnippet(snippet.id);
  }

  async function deleteSnippet(id) {
    const updated = savedSnippets.filter(s=>s.id!==id);
    setSavedSnippets(updated);
    await storeSet("hub-code-" + user.username, updated, false);
    if (activeSnippet === id) setActiveSnippet(null);
  }

  function handleKeyDown(e) {
    const ta = textareaRef.current;
    const start = ta.selectionStart, end = ta.selectionEnd;

    // Tab -> 2 spaces
    if (e.key === "Tab") {
      e.preventDefault();
      const newCode = code.substring(0, start) + "  " + code.substring(end);
      setCode(newCode);
      setTimeout(() => { ta.selectionStart = ta.selectionEnd = start + 2; }, 0);
      return;
    }

    // Auto-close brackets and quotes
    const pairs = { "{":"}","(":")","[":"]",'"':'"',"'":"'","`":"`" };
    const closers = new Set(Object.values(pairs));
    if (pairs[e.key]) {
      // If there's selected text, wrap it
      if (start !== end) {
        e.preventDefault();
        const selected = code.substring(start, end);
        const wrapped = e.key + selected + pairs[e.key];
        const newCode = code.substring(0, start) + wrapped + code.substring(end);
        setCode(newCode);
        setTimeout(() => { ta.selectionStart = start + 1; ta.selectionEnd = end + 1; }, 0);
        return;
      }
      // No selection - insert pair and put cursor in middle
      e.preventDefault();
      const newCode = code.substring(0, start) + e.key + pairs[e.key] + code.substring(end);
      setCode(newCode);
      setTimeout(() => { ta.selectionStart = ta.selectionEnd = start + 1; }, 0);
      return;
    }

    // Skip over closing bracket if it's already there
    if (closers.has(e.key) && code[start] === e.key && e.key !== code[start-1]) {
      e.preventDefault();
      setTimeout(() => { ta.selectionStart = ta.selectionEnd = start + 1; }, 0);
      return;
    }

    // Auto-indent on Enter after {
    if (e.key === "Enter") {
      const lineStart = code.lastIndexOf("\n", start - 1) + 1;
      const currentLine = code.substring(lineStart, start);
      const indent = currentLine.match(/^(\s*)/)[1];
      const charBefore = code[start - 1];
      const charAfter = code[start];
      if (charBefore === "{" && charAfter === "}") {
        e.preventDefault();
        const newCode = code.substring(0, start) + "\n" + indent + "  " + "\n" + indent + code.substring(end);
        setCode(newCode);
        setTimeout(() => { ta.selectionStart = ta.selectionEnd = start + indent.length + 3; }, 0);
        return;
      }
      if (charBefore === "{") {
        e.preventDefault();
        const newCode = code.substring(0, start) + "\n" + indent + "  " + code.substring(end);
        setCode(newCode);
        setTimeout(() => { ta.selectionStart = ta.selectionEnd = start + indent.length + 3; }, 0);
        return;
      }
      if (indent.length > 0) {
        e.preventDefault();
        const newCode = code.substring(0, start) + "\n" + indent + code.substring(end);
        setCode(newCode);
        setTimeout(() => { ta.selectionStart = ta.selectionEnd = start + indent.length + 1; }, 0);
        return;
      }
    }

    // Backspace: remove pair if cursor is between them
    if (e.key === "Backspace" && start === end) {
      const before = code[start - 1];
      const after = code[start];
      const pairs2 = { "{":"}","(":")","[":"]" };
      if (pairs2[before] === after) {
        e.preventDefault();
        const newCode = code.substring(0, start - 1) + code.substring(start + 1);
        setCode(newCode);
        setTimeout(() => { ta.selectionStart = ta.selectionEnd = start - 1; }, 0);
        return;
      }
    }
  }

  return (
    <div>
      <div style={{display:"flex",alignItems:"center",justifyContent:"space-between",marginBottom:6,flexWrap:"wrap",gap:8}}>
        <div style={{fontWeight:900,fontSize:24}}>💻 Code Editor</div>
        <div style={{display:"flex",gap:8}}>
          <button style={{...S.btnOut(),fontSize:12,padding:"5px 14px"}} onClick={()=>{setShowShared(s=>!s);loadSharedCode();}}>
            🌐 {showShared?"Hide":"View"} Team Code ({sharedPosts.length})
          </button>
        </div>
      </div>
      <div style={{color:"#6b7280",fontSize:12,marginBottom:14}}>
        Auto-closes brackets ( ) [ ] {"{}"} and quotes. Tab = 2 spaces. Wrap selected text in brackets by typing one.
      </div>

      {/* SHARED CODE FEED */}
      {showShared && (
        <div style={{...S.card,marginBottom:18,background:"#f8fafc"}}>
          <div style={{fontWeight:800,fontSize:15,marginBottom:12}}>🌐 Team Code Posts</div>
          {sharedPosts.length === 0 && <div style={{color:"#9ca3af",fontSize:13,textAlign:"center",padding:20}}>No shared code yet — be the first to post!</div>}
          <div style={{display:"flex",flexDirection:"column",gap:10,maxHeight:400,overflowY:"auto"}}>
            {sharedPosts.map(p=>(
              <div key={p.id} style={{background:"#fff",borderRadius:10,border:"1px solid #e2e8f0",overflow:"hidden"}}>
                <div style={{padding:"10px 14px",display:"flex",justifyContent:"space-between",alignItems:"center",borderBottom:"1px solid #f1f5f9"}}>
                  <div>
                    <span style={{fontWeight:700,fontSize:13}}>{p.title}</span>
                    <span style={{background:p.lang==="java"?"#fffbeb":p.lang==="python"?"#f0fdf4":p.lang==="html"?"#ecfeff":"#f5f3ff",color:p.lang==="java"?"#b45309":p.lang==="python"?"#15803d":p.lang==="html"?"#0891b2":"#7c3aed",borderRadius:6,padding:"1px 8px",fontSize:11,fontWeight:700,marginLeft:8}}>{p.lang}</span>
                  </div>
                  <div style={{display:"flex",gap:8,alignItems:"center"}}>
                    <span style={{fontSize:12,color:"#9ca3af"}}>by {p.author} · {new Date(p.ts).toLocaleDateString()}</span>
                    <button onClick={()=>likePost(p.id)} style={{background:"none",border:"1px solid #e2e8f0",borderRadius:6,padding:"2px 8px",cursor:"pointer",fontSize:12,color:(p.likes||[]).includes(user.username)?"#dc2626":"#6b7280",fontWeight:700}}>
                      ♥ {(p.likes||[]).length}
                    </button>
                    <button onClick={()=>{setCode(p.code);setLang(p.lang);setShowShared(false);}} style={{...S.btnSm("#1d4ed8"),fontSize:11}}>Load</button>
                    {p.username===user.username && <button onClick={()=>deleteSharedPost(p.id)} style={{background:"none",border:"none",cursor:"pointer",color:"#dc2626",fontSize:13}}>🗑</button>}
                  </div>
                </div>
                <pre style={{margin:0,padding:"10px 14px",fontFamily:"monospace",fontSize:11,color:"#374151",background:"#0f172a",overflowX:"auto",maxHeight:120,color:"#94a3b8"}}>
                  {p.code.split("\n").slice(0,8).join("\n")}{p.code.split("\n").length>8?"\n...":""}
                </pre>
              </div>
            ))}
          </div>
        </div>
      )}

      <div style={{display:"grid",gridTemplateColumns:"1fr 260px",gap:16,alignItems:"start"}}>
        <div>
          {/* Language tabs */}
          <div style={{display:"flex",gap:6,marginBottom:8,flexWrap:"wrap"}}>
            {Object.entries(CODE_TEMPLATES).map(([k,v])=>(
              <button key={k} onClick={()=>handleLangChange(k)}
                style={{...S.chip(lang===k),padding:"5px 12px",fontSize:12}}>
                {k==="java"?"☕":k==="python"?"🐍":k==="html"?"🌐":"📝"} {v.label}
              </button>
            ))}
          </div>

          {/* Find bar */}
          {showFind && (
            <div style={{display:"flex",gap:6,marginBottom:6,alignItems:"center"}}>
              <input style={{...S.inp,marginBottom:0,flex:1,fontSize:12,padding:"6px 12px"}} placeholder="Find in code…"
                value={findText} onChange={e=>setFindText(e.target.value)} onKeyDown={e=>e.key==="Enter"&&findInCode()} autoFocus />
              <button style={S.btn()} onClick={findInCode}>Find</button>
              <button style={S.btnOut("#6b7280")} onClick={()=>{setShowFind(false);setFindText("");}}>✕</button>
            </div>
          )}

          {/* Editor with line numbers */}
          <div style={{position:"relative",display:"flex",borderRadius:10,overflow:"hidden",border:"1px solid #334155"}}>
            {/* Line numbers */}
            <div style={{background:"#0a1525",color:"#475569",fontFamily:"'Fira Code','Consolas',monospace",fontSize:13,lineHeight:1.6,padding:"14px 10px",userSelect:"none",minWidth:36,textAlign:"right",borderRight:"1px solid #1e293b"}}>
              {Array.from({length:lineCount},(_,i)=>(
                <div key={i} style={{lineHeight:"20.8px"}}>{i+1}</div>
