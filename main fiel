class DriveSystem:
    def __init__(self, hardware_map, max_speed=1.0):
        self.left_front  = hardware_map.get("leftFront")
        self.right_front = hardware_map.get("rightFront")
        self.left_back   = hardware_map.get("leftBack")
        self.right_back  = hardware_map.get("rightBack")
        self.max_speed   = max_speed

    def drive(self, x, y, rotate):
        lf = (y + x + rotate) * self.max_speed
        rf = (y - x - rotate) * self.max_speed
        lb = (y - x + rotate) * self.max_speed
        rb = (y + x - rotate) * self.max_speed
        self.left_front.set(lf)
        self.right_front.set(rf)
        self.left_back.set(lb)
        self.right_back.set(rb)

    def stop(self):
        self.drive(0, 0, 0)
