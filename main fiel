  function addSponsor() {
    if (!spName.trim()) return;
    const s = {id:Date.now(), name:spName, amount:parseFloat(spAmount)||0, type:spType, status:spStatus, contact:spContact, notes:spNotes};
    const updated = [...sponsors, s];
