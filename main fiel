          <button onClick={()=>{setPhase("quiz");setQuizIdx(0);setQuizAns(null);}} style={{background:"#059669",color:"#fff",border:"none",padding:"11px 24px",borderRadius:9,cursor:"pointer",fontWeight:700,fontSize:14,fontFamily:"inherit"}}>
            Take Quiz ✓
