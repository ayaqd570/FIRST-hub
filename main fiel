      {id:"pa7",title:"Robot State Machines",est:"24 min",content:`## Finite State Machines in Python
State machines make complex robot behavior readable and testable. Instead of tangled if/else chains, each state is clear and transitions are explicit.

\`\`\`python
from enum import Enum, auto
import time

class ArmState(Enum):
    STOWED     = auto()
    EXTENDING  = auto()
    EXTENDED   = auto()
    RETRACTING = auto()

class ArmSubsystem:
    def __init__(self, motor, encoder, limit_switch):
        self.motor = motor
        self.encoder = encoder
        self.limit = limit_switch
        self.state = ArmState.STOWED
        self._state_start = time.time()

    @property
    def state_time(self) -> float:
        return time.time() - self._state_start

    def _set_state(self, new_state: ArmState):
        print(f"Arm: {self.state.name} → {new_state.name}")
        self.state = new_state
        self._state_start = time.time()

    def update(self):
        match self.state:
            case ArmState.STOWED:
                self.motor.set(0)

            case ArmState.EXTENDING:
                self.motor.set(0.6)
                if self.encoder.position >= 1000:
                    self._set_state(ArmState.EXTENDED)
                elif self.state_time > 3.0:  # timeout safety
                    self._set_state(ArmState.STOWED)

            case ArmState.EXTENDED:
                self.motor.set(0.05)  # hold

            case ArmState.RETRACTING:
                self.motor.set(-0.5)
                if self.limit.get():
                    self._set_state(ArmState.STOWED)

    def extend(self):
        if self.state == ArmState.STOWED:
            self._set_state(ArmState.EXTENDING)

    def retract(self):
        if self.state == ArmState.EXTENDED:
            self._set_state(ArmState.RETRACTING)
