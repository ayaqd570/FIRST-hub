                    return (
                      <button key={j} onClick={()=>!rqRevealed&&setRqAnswers(prev=>({...prev,[i]:j}))}
                        style={{background:bg,color,border,borderRadius:8,padding:"8px 12px",textAlign:"left",cursor:rqRevealed?"default":"pointer",fontFamily:"inherit",fontSize:13}}>
