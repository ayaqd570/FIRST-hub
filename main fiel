          const climbPct = entries.filter(e=>e.climbed==="success").length/entries.length*100;
          const avgOvr = entries.reduce((s,e)=>s+(e.overallRating||5),0)/entries.length;
          const avgAuto = entries.filter(e=>e.auto).length>0
            ? entries.filter(e=>e.auto).reduce((s,e)=>s+parseFloat(e.auto||0),0)/entries.filter(e=>e.auto).length : null;
