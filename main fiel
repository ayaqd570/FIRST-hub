                    </a>
                  ))}
                </div>
              </div>
            ))}
          </div>
        )}

        {/* FORUM */}
        {tab==="forum" && (
          <div>
            {viewPost ? (
              (() => {
                const p=posts.find(x=>x.id===viewPost);
                if(!p){setViewPost(null);return null;}
                return (
                  <div>
                    <button style={S.btnOut()} onClick={()=>setViewPost(null)}>← Forum</button>
                    <div style={{...S.card,marginTop:16}}>
                      {p.pinned && <span style={{background:"#b91c1c",color:"#fff",padding:"2px 10px",borderRadius:10,fontSize:11,fontWeight:700,display:"inline-block",marginBottom:8}}>📌 PINNED</span>}
                      <div style={{fontSize:22,fontWeight:900}}>{p.title}</div>
                      <div style={{color:"#9ca3af",fontSize:13,marginTop:4}}>by <b style={{color:"#374151"}}>{p.author}</b> · {fmt(p.ts)}</div>
                      <div style={{marginTop:14,lineHeight:1.75,fontSize:15}}>{p.body}</div>
                    </div>
                    <div style={{fontWeight:800,fontSize:17,margin:"20px 0 12px"}}>💬 Replies ({p.replies?.length||0})</div>
                    {(p.replies||[]).map((r,i)=>(
                      <div key={i} style={{...S.card,marginBottom:10}}>
                        <div style={{display:"flex",justifyContent:"space-between",marginBottom:8}}>
                          <div style={{fontWeight:700,fontSize:14}}>👤 {r.author}</div>
                          <span style={{color:"#9ca3af",fontSize:12}}>{fmt(r.ts)}</span>
                        </div>
                        <div style={{lineHeight:1.65,fontSize:14}}>{r.text}</div>
                      </div>
                    ))}
                    <div style={S.card}>
                      <div style={{fontWeight:700,fontSize:15,marginBottom:12}}>Add a Reply</div>
                      <textarea style={S.ta} placeholder="Write your reply…" value={repText} onChange={e=>setRepText(e.target.value)} />
                      <button style={S.btn()} onClick={()=>{
                        if(!repText.trim()) return;
                        const np=posts.map(x=>x.id===p.id?{...x,replies:[...(x.replies||[]),{author:user.name,text:repText,ts:Date.now()}]}:x);
                        savePosts(np);setRepText("");
                      }}>Post Reply</button>
                    </div>
                  </div>
                );
              })()
            ) : (
              <div>
                <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:20,flexWrap:"wrap",gap:10}}>
                  <div style={{fontWeight:900,fontSize:24}}>💬 Team Forum</div>
                  <button style={S.btn()} onClick={()=>setShowNewPost(true)}>+ New Post</button>
                </div>
                <div style={{...S.card,background:"#eff6ff",padding:12,marginBottom:16,fontSize:13,color:"#1d4ed8",fontWeight:600,border:"1px solid #bfdbfe"}}>
                  🌐 Forum posts are shared with your whole team!
                </div>
                {showNewPost && (
                  <div style={{...S.card,border:"2px solid #1d4ed8",marginBottom:20}}>
                    <div style={{fontWeight:800,fontSize:16,marginBottom:14}}>Create New Post</div>
                    <input style={S.inp} placeholder="Post title" value={npTitle} onChange={e=>setNpTitle(e.target.value)} />
                    <textarea style={S.ta} placeholder="What's your question or topic?" value={npBody} onChange={e=>setNpBody(e.target.value)} />
                    <div style={{display:"flex",gap:10}}>
                      <button style={S.btn()} onClick={()=>{
                        if(!npTitle.trim()||!npBody.trim()) return;
                        const p={id:Date.now().toString(),ts:Date.now(),replies:[],pinned:false,title:npTitle,body:npBody,author:user.name};
                        savePosts([p,...posts]);setNpTitle("");setNpBody("");setShowNewPost(false);
                      }}>Post</button>
                      <button style={S.btnOut()} onClick={()=>setShowNewPost(false)}>Cancel</button>
                    </div>
                  </div>
                )}
                {posts.length===0 && <div style={{textAlign:"center",padding:50,color:"#9ca3af"}}>No posts yet — start the first discussion!</div>}
                {posts.filter(p=>p.pinned).map(p=>(
                  <div key={p.id} style={{...S.card,cursor:"pointer",borderLeft:"4px solid #b91c1c",marginBottom:10}} onClick={()=>setViewPost(p.id)}>
                    <div style={{fontWeight:800,fontSize:15}}>{p.title} <span style={{background:"#b91c1c",color:"#fff",padding:"1px 8px",borderRadius:8,fontSize:10,fontWeight:700,marginLeft:4}}>📌</span></div>
                    <div style={{color:"#9ca3af",fontSize:12,marginTop:4}}>by {p.author} · {fmt(p.ts)} · {p.replies?.length||0} replies</div>
                  </div>
                ))}
                {posts.filter(p=>!p.pinned).map(p=>(
                  <div key={p.id} style={{...S.card,cursor:"pointer",marginBottom:10,transition:"all 0.2s"}}
                    onClick={()=>setViewPost(p.id)}
                    onMouseEnter={e=>{e.currentTarget.style.transform="translateY(-1px)";e.currentTarget.style.boxShadow="0 6px 20px rgba(0,0,0,0.1)";}}
                    onMouseLeave={e=>{e.currentTarget.style.transform="";e.currentTarget.style.boxShadow="";}}>
                    <div style={{display:"flex",justifyContent:"space-between",gap:10}}>
                      <div style={{flex:1,minWidth:0}}>
                        <div style={{fontWeight:800,fontSize:15}}>{p.title}</div>
                        <div style={{color:"#9ca3af",fontSize:12,marginTop:4}}>by <b style={{color:"#374151"}}>{p.author}</b> · {fmt(p.ts)}</div>
                        <div style={{color:"#6b7280",fontSize:13,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap",marginTop:4}}>{p.body}</div>
                      </div>
                      <div style={{background:"#f1f5f9",borderRadius:8,padding:"4px 12px",fontSize:13,fontWeight:700,flexShrink:0}}>{p.replies?.length||0} 💬</div>
                    </div>
                  </div>
                ))}
              </div>
            )}
          </div>
        )}

        {/* ANNOUNCEMENTS */}
        {tab==="announcements" && (
          <div>
            <div style={{fontWeight:900,fontSize:24,marginBottom:18}}>📣 Announcements</div>
            {anns.length===0 && <div style={{textAlign:"center",padding:50,color:"#9ca3af"}}>No announcements yet.</div>}
            {anns.map(a=>(
              <div key={a.id} style={{...S.card,borderLeft:"5px solid #b91c1c",marginBottom:14}}>
                <div style={{fontWeight:800,fontSize:18}}>{a.title}</div>
                <div style={{color:"#9ca3af",fontSize:12,marginTop:2}}>{fmt(a.ts)}</div>
                <div style={{marginTop:10,lineHeight:1.7,fontSize:15}}>{a.body}</div>
              </div>
            ))}
          </div>
        )}

        {/* PROFILE TAB */}
        {tab==="profile" && (
          <ProfileSettings user={user} done={done} placementResult={placementResult} totalLessons={totalLessons} />
        )}

        {/* CODE EDITOR */}
        {tab==="code" && (
          <CodeEditor user={user} />
        )}

        {/* ACHIEVEMENTS */}
        {tab==="achievements" && (
          <AchievementsPage user={user} done={done} totalLessons={totalLessons} />
        )}

        {/* LEADERBOARD */}
        {tab==="leaderboard" && (
          <LeaderboardPage user={user} />
        )}

        {/* NOTES & BOOKMARKS */}
        {tab==="notes" && (
          <NotesPage user={user} />
        )}

        {/* FIRST TOOLS */}
        {tab==="tools" && (
          <FIRSTToolsPage />
        )}

        {tab==="flashcards" && (
          <FlashcardsPage user={user} />
        )}

        {tab==="report" && (
          <StudentReportPage user={user} done={done} totalLessons={totalLessons} />
        )}

        {tab==="studyplan" && (
          <StudyPlanPage user={user} done={done} totalLessons={totalLessons} />
        )}

        {tab==="goals" && (
          <GoalsPage user={user} done={done} totalLessons={totalLessons} />
        )}

        {tab==="skilltree" && (
          <SkillTreePage user={user} done={done} setTab={setTab} setSelSub={setSelSub} setSelLevel={setSelLevel} setSelLesson={setSelLesson} />
        )}

        {tab==="practicetest" && (
          <PracticeTestPage user={user} />
        )}
      </div>

        {newAchievements.length > 0 && (
          <div style={{position:"fixed",bottom:24,right:24,zIndex:9999,display:"flex",flexDirection:"column",gap:10,alignItems:"flex-end"}}>
            {newAchievements.map((ach,i)=>(
              <div key={ach.id+i} style={{background:"linear-gradient(135deg,#1e3a8a,#1d4ed8)",color:"#fff",
                borderRadius:14,padding:"14px 18px",boxShadow:"0 8px 30px rgba(0,0,0,0.3)",
                display:"flex",alignItems:"center",gap:12,minWidth:260,
                animation:"slideIn 0.3s ease-out"}}>
                <div style={{fontSize:32}}>{ach.icon}</div>
                <div>
                  <div style={{fontSize:11,opacity:0.8,marginBottom:2}}>🎉 Achievement Unlocked!</div>
                  <div style={{fontWeight:800,fontSize:15}}>{ach.name}</div>
                  <div style={{fontSize:12,opacity:0.8,marginTop:1}}>{ach.desc}</div>
                </div>
                <button onClick={()=>setNewAchievements(prev=>prev.filter((_,j)=>j!==i))}
                  style={{background:"none",border:"none",color:"rgba(255,255,255,0.6)",cursor:"pointer",fontSize:18,marginLeft:"auto",padding:0}}>✕</button>
              </div>
            ))}
          </div>
        )}

      {/* INBOX MODAL */}
      {showInbox && (
        <div style={{position:"fixed",inset:0,background:"rgba(0,0,0,0.6)",display:"flex",alignItems:"center",justifyContent:"center",zIndex:999,backdropFilter:"blur(4px)"}}
          onClick={()=>setShowInbox(false)}>
          <div style={{background:"#fff",borderRadius:18,width:"100%",maxWidth:480,maxHeight:"80vh",display:"flex",flexDirection:"column",boxShadow:"0 25px 60px rgba(0,0,0,0.3)",overflow:"hidden"}} onClick={e=>e.stopPropagation()}>
            <div style={{padding:"18px 22px",borderBottom:"1px solid #e2e8f0",display:"flex",justifyContent:"space-between",alignItems:"center"}}>
              <div style={{fontWeight:800,fontSize:18}}>📬 Messages from Admin</div>
              <button onClick={()=>setShowInbox(false)} style={{background:"none",border:"none",fontSize:18,cursor:"pointer",color:"#9ca3af"}}>✕</button>
            </div>
            <div style={{flex:1,overflowY:"auto",padding:"16px 22px",display:"flex",flexDirection:"column",gap:10}}>
              {inbox.length===0 && <div style={{textAlign:"center",color:"#9ca3af",padding:30}}>No messages yet.</div>}
              {inbox.map((m,i)=>(
                <div key={i} style={{display:"flex",flexDirection:m.isAdmin?"row":"row-reverse",gap:8,alignItems:"flex-end"}}>
                  <div style={{width:28,height:28,background:m.isAdmin?"#b91c1c":"#1d4ed8",borderRadius:7,display:"flex",alignItems:"center",justifyContent:"center",fontSize:12,fontWeight:700,color:"#fff",flexShrink:0}}>
                    {m.isAdmin?"A":user.name?.charAt(0)?.toUpperCase()}
                  </div>
                  <div style={{maxWidth:"75%"}}>
                    <div style={{background:m.isAdmin?"#fef2f2":"#eff6ff",color:"#1e293b",padding:"10px 14px",borderRadius:m.isAdmin?"12px 12px 12px 4px":"12px 12px 4px 12px",fontSize:14,lineHeight:1.5,border:`1px solid ${m.isAdmin?"#fecaca":"#bfdbfe"}`}}>
                      {m.text}
                    </div>
                    <div style={{color:"#9ca3af",fontSize:11,marginTop:3,textAlign:m.isAdmin?"left":"right"}}>{fmt(m.ts)}</div>
                  </div>
                </div>
              ))}
            </div>
            <div style={{padding:"14px 22px",borderTop:"1px solid #e2e8f0",display:"flex",gap:10}}>
              <input style={{...S.inp,margin:0,flex:1}} placeholder="Reply to admin…" value={replyText} onChange={e=>setReplyText(e.target.value)} onKeyDown={e=>e.key==="Enter"&&sendReply()} />
              <button style={S.btn()} onClick={sendReply}>Send</button>
            </div>
          </div>
        </div>
      )}
    </div>
  );
}
