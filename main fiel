                    <button onClick={startDpChallenge}
                      style={{background:"#10b981",color:"#fff",border:"none",borderRadius:10,padding:"14px 32px",cursor:"pointer",fontWeight:800,fontSize:16,fontFamily:"inherit"}}>
                      ▶ Start Timer
                    </button>
                  ) : (
                    <button onClick={stopDpChallenge}
                      style={{background:"#ef4444",color:"#fff",border:"none",borderRadius:10,padding:"14px 32px",cursor:"pointer",fontWeight:800,fontSize:16,fontFamily:"inherit"}}>
                      ⏹ Stop
                    </button>
                  )}
                  <button onClick={()=>{clearInterval(dpRef.current);setDpRunning(false);setDpTime(0);}}
                    style={{background:"rgba(255,255,255,0.1)",color:"#fff",border:"1px solid rgba(255,255,255,0.2)",borderRadius:10,padding:"14px 20px",cursor:"pointer",fontWeight:700,fontSize:14,fontFamily:"inherit"}}>
                    Reset
                  </button>
                </div>
                <div style={{display:"flex",gap:16,justifyContent:"center",fontSize:13,opacity:0.8}}>
                  <span>🎯 Goal: {ch.goal}s</span>
                  {best&&<span>🏆 Best: {best}s {best<=ch.goal?"✅":""}</span>}
                  {dpTime>0&&!dpRunning&&<span style={{color:underGoal?"#34d399":"#fbbf24"}}>{underGoal?"🎉 Goal Met!":"Keep practicing!"}</span>}
                </div>
              </div>
            );
          })()}
        </div>
      )}
      {/* ── BUILD LOG ── */}
      {tool==="buildlog" && (
        <div>
          <div style={{fontWeight:800,fontSize:17,marginBottom:4}}>📓 Build Log</div>
          <div style={{color:"#6b7280",fontSize:13,marginBottom:16}}>Record what your team builds, fixes, and learns every meeting. Great for Chairman's Award and engineering notebooks.</div>
          <div style={{background:"#fff",borderRadius:14,padding:18,border:"1px solid #e2e8f0",marginBottom:16}}>
            <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:10,marginBottom:10}}>
              <div>
                <div style={{fontSize:12,color:"#9ca3af",marginBottom:4}}>Date</div>
                <input type="date" value={logDate} onChange={e=>setLogDate(e.target.value)}
                  style={{width:"100%",padding:"8px 10px",borderRadius:8,border:"1px solid #e2e8f0",fontSize:13,boxSizing:"border-box",fontFamily:"inherit"}}/>
              </div>
              <div>
                <div style={{fontSize:12,color:"#9ca3af",marginBottom:4}}>Category</div>
                <select value={logCategory} onChange={e=>setLogCategory(e.target.value)}
                  style={{width:"100%",padding:"8px 10px",borderRadius:8,border:"1px solid #e2e8f0",fontSize:13,boxSizing:"border-box",fontFamily:"inherit",background:"#fff"}}>
                  {[["build","🔧 Build"],["code","💻 Code"],["design","📐 Design"],["test","🧪 Testing"],["strategy","🎯 Strategy"],["other","📝 Other"]].map(([v,l])=>
                    <option key={v} value={v}>{l}</option>)}
                </select>
              </div>
            </div>
            <div style={{marginBottom:10}}>
              <div style={{fontSize:12,color:"#9ca3af",marginBottom:4}}>What was accomplished?</div>
              <textarea value={logWhat} onChange={e=>setLogWhat(e.target.value)} rows={3}
                placeholder="e.g. Finished mounting the intake, tested shooter at 4000 RPM, tuned PID for lift..."
                style={{width:"100%",padding:"8px 10px",borderRadius:8,border:"1px solid #e2e8f0",fontSize:13,resize:"vertical",boxSizing:"border-box",fontFamily:"inherit"}}/>
            </div>
            <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:10,marginBottom:10}}>
              <div>
                <div style={{fontSize:12,color:"#9ca3af",marginBottom:4}}>Who worked on it?</div>
                <input value={logWho} onChange={e=>setLogWho(e.target.value)} placeholder="e.g. Alex, Jamie, whole team"
                  style={{width:"100%",padding:"8px 10px",borderRadius:8,border:"1px solid #e2e8f0",fontSize:13,boxSizing:"border-box",fontFamily:"inherit"}}/>
              </div>
              <div>
                <div style={{fontSize:12,color:"#9ca3af",marginBottom:4}}>Issues / blockers?</div>
                <input value={logIssues} onChange={e=>setLogIssues(e.target.value)} placeholder="e.g. Waiting on bolts, belt keeps slipping"
                  style={{width:"100%",padding:"8px 10px",borderRadius:8,border:"1px solid #e2e8f0",fontSize:13,boxSizing:"border-box",fontFamily:"inherit"}}/>
              </div>
            </div>
            <button onClick={saveLogEntry} style={{background:"#1d4ed8",color:"#fff",border:"none",borderRadius:8,padding:"10px 22px",cursor:"pointer",fontWeight:700,fontSize:14,fontFamily:"inherit"}}>
              📝 Save Log Entry
            </button>
          </div>
          {logEntries.length>0 && (
            <div>
              <div style={{fontWeight:700,marginBottom:10}}>📅 Log History ({logEntries.length} entries)</div>
              {logEntries.map((e,i)=>(
                <div key={i} style={{background:"#fff",borderRadius:12,padding:"12px 16px",border:"1px solid #e2e8f0",marginBottom:8}}>
                  <div style={{display:"flex",gap:10,alignItems:"center",marginBottom:6,flexWrap:"wrap"}}>
                    <span style={{fontWeight:700,fontSize:13}}>{e.date}</span>
                    <span style={{background:{build:"#dbeafe",code:"#d1fae5",design:"#fef3c7",test:"#fce7f3",strategy:"#ede9fe",other:"#f3f4f6"}[e.category]||"#f3f4f6",
                      color:{build:"#1e40af",code:"#065f46",design:"#92400e",test:"#9d174d",strategy:"#4c1d95",other:"#374151"}[e.category]||"#374151",
                      borderRadius:6,padding:"2px 8px",fontSize:12,fontWeight:700}}>
                      {{build:"🔧 Build",code:"💻 Code",design:"📐 Design",test:"🧪 Test",strategy:"🎯 Strategy",other:"📝 Other"}[e.category]}
                    </span>
                    {e.who&&<span style={{fontSize:12,color:"#6b7280"}}>👤 {e.who}</span>}
                  </div>
                  <div style={{fontSize:13,color:"#1e293b",marginBottom:e.issues?4:0}}>{e.what}</div>
                  {e.issues&&<div style={{fontSize:12,color:"#ef4444"}}>⚠️ {e.issues}</div>}
                </div>
              ))}
            </div>
          )}
        </div>
      )}

      {/* ── PARTS CALCULATOR ── */}
      {tool==="partscalc" && (
        <div>
          <div style={{fontWeight:800,fontSize:17,marginBottom:4}}>🔩 Parts Calculator</div>
          <div style={{color:"#6b7280",fontSize:13,marginBottom:16}}>Calculate gear ratios, belt lengths, chain links, and robot speed.</div>
          <div style={{display:"flex",gap:8,marginBottom:20,flexWrap:"wrap"}}>
            {[["gear","⚙️ Gear Ratio"],["belt","📏 Belt Length"],["chain","🔗 Chain Links"],["speed","🚀 Robot Speed"]].map(([v,l])=>(
              <button key={v} onClick={()=>setPartsCalcMode(v)}
                style={{background:partsCalcMode===v?"#1d4ed8":"#f1f5f9",color:partsCalcMode===v?"#fff":"#374151",border:"none",borderRadius:8,padding:"9px 18px",cursor:"pointer",fontWeight:700,fontSize:13,fontFamily:"inherit"}}>
                {l}
              </button>
            ))}
          </div>
          {partsCalcMode==="gear" && (() => {
            const ratio = (parseFloat(pcGearOut)||1)/(parseFloat(pcGearIn)||1);
            const outRPM = (parseFloat(pcRPM)||0)/ratio;
            const torqueMult = ratio;
            return (
              <div style={{background:"#fff",borderRadius:14,padding:18,border:"1px solid #e2e8f0"}}>
                <div style={{fontWeight:700,marginBottom:14}}>⚙️ Gear / Sprocket Ratio</div>
                <div style={{display:"grid",gridTemplateColumns:"1fr 1fr 1fr",gap:10,marginBottom:16}}>
                  {[["Driver Teeth / Radius",pcGearIn,setPcGearIn,"e.g. 12"],["Driven Teeth / Radius",pcGearOut,setPcGearOut,"e.g. 60"],["Motor Free RPM",pcRPM,setPcRPM,"e.g. 6000"]].map(([label,val,set,ph])=>(
                    <div key={label}>
                      <div style={{fontSize:12,color:"#9ca3af",marginBottom:4}}>{label}</div>
                      <input type="number" value={val} onChange={e=>set(e.target.value)} placeholder={ph}
                        style={{width:"100%",padding:"8px 10px",borderRadius:8,border:"1px solid #e2e8f0",fontSize:14,boxSizing:"border-box",fontFamily:"inherit"}}/>
                    </div>
                  ))}
                </div>
                <div style={{display:"grid",gridTemplateColumns:"1fr 1fr 1fr",gap:10}}>
                  {[["Gear Ratio",ratio.toFixed(3)+":1","#1d4ed8"],["Output RPM",outRPM.toFixed(0)+" RPM","#7c3aed"],["Torque Multiplier",torqueMult.toFixed(2)+"×","#059669"]].map(([l,v,c])=>(
                    <div key={l} style={{background:"#f8fafc",borderRadius:10,padding:14,textAlign:"center",border:`2px solid ${c}20`}}>
                      <div style={{fontSize:12,color:"#6b7280",marginBottom:4}}>{l}</div>
                      <div style={{fontWeight:900,fontSize:22,color:c}}>{v}</div>
                    </div>
                  ))}
                </div>
                <div style={{marginTop:14,fontSize:13,color:"#6b7280",background:"#f8fafc",borderRadius:8,padding:10}}>
                  A {ratio.toFixed(2)}:1 reduction means {ratio.toFixed(1)}× more torque but {ratio.toFixed(1)}× less speed. {ratio>5?"High reduction — good for lifting.":ratio>2?"Moderate reduction — good for arms.":"Low reduction — good for driving fast."}
                </div>
              </div>
            );
          })()}
          {partsCalcMode==="belt" && (() => {
            const t1 = parseFloat(pcTeeth1)||16, t2 = parseFloat(pcTeeth2)||32;
            const c = parseFloat(pcCenter)||150, pitch = parseFloat(pcPitch)||5;
            const links = Math.round(2*(c/pitch) + (t1+t2)/2 + ((t2-t1)/(2*Math.PI))**2*(pitch/c));
            const actualC = (pitch*(2*links - t1 - t2 + Math.sqrt((2*links-t1-t2)**2 - (t2-t1)**2/Math.PI**2)))/4;
            return (
              <div style={{background:"#fff",borderRadius:14,padding:18,border:"1px solid #e2e8f0"}}>
                <div style={{fontWeight:700,marginBottom:14}}>📏 Belt Length Calculator</div>
                <div style={{display:"grid",gridTemplateColumns:"1fr 1fr 1fr 1fr",gap:10,marginBottom:16}}>
                  {[["Pulley 1 Teeth",pcTeeth1,setPcTeeth1,"16"],["Pulley 2 Teeth",pcTeeth2,setPcTeeth2,"32"],["Center Distance (mm)",pcCenter,setPcCenter,"150"],["Belt Pitch (mm)",pcPitch,setPcPitch,"5"]].map(([l,v,s,ph])=>(
                    <div key={l}>
                      <div style={{fontSize:12,color:"#9ca3af",marginBottom:4}}>{l}</div>
                      <input type="number" value={v} onChange={e=>s(e.target.value)} placeholder={ph}
                        style={{width:"100%",padding:"8px 10px",borderRadius:8,border:"1px solid #e2e8f0",fontSize:14,boxSizing:"border-box",fontFamily:"inherit"}}/>
                    </div>
                  ))}
                </div>
                <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:10}}>
                  {[["Belt Links Needed",links+" links","#1d4ed8"],["Actual Center Distance",actualC.toFixed(1)+" mm","#059669"]].map(([l,v,c])=>(
                    <div key={l} style={{background:"#f8fafc",borderRadius:10,padding:14,textAlign:"center"}}>
                      <div style={{fontSize:12,color:"#6b7280",marginBottom:4}}>{l}</div>
                      <div style={{fontWeight:900,fontSize:22,color:c}}>{v}</div>
                    </div>
                  ))}
                </div>
                <div style={{marginTop:12,fontSize:12,color:"#6b7280"}}>Note: Always round UP to the nearest even number of links for standard belt sizing.</div>
              </div>
            );
          })()}
          {partsCalcMode==="chain" && (() => {
            const t1=parseFloat(pcTeeth1)||16, t2=parseFloat(pcTeeth2)||32, c=parseFloat(pcCenter)||150;
            const pitch = 25.4/parseFloat(pcPitch||"1"); // #25 = 6.35mm, #35 = 9.525mm
            const links = Math.round(2*(c/6.35) + (t1+t2)/2);
            return (
              <div style={{background:"#fff",borderRadius:14,padding:18,border:"1px solid #e2e8f0"}}>
                <div style={{fontWeight:700,marginBottom:14}}>🔗 Chain Links Calculator (#25 Chain)</div>
                <div style={{display:"grid",gridTemplateColumns:"1fr 1fr 1fr",gap:10,marginBottom:16}}>
                  {[["Sprocket 1 Teeth",pcTeeth1,setPcTeeth1,"16"],["Sprocket 2 Teeth",pcTeeth2,setPcTeeth2,"32"],["Center Distance (mm)",pcCenter,setPcCenter,"150"]].map(([l,v,s,ph])=>(
                    <div key={l}>
                      <div style={{fontSize:12,color:"#9ca3af",marginBottom:4}}>{l}</div>
                      <input type="number" value={v} onChange={e=>s(e.target.value)} placeholder={ph}
                        style={{width:"100%",padding:"8px 10px",borderRadius:8,border:"1px solid #e2e8f0",fontSize:14,boxSizing:"border-box",fontFamily:"inherit"}}/>
                    </div>
                  ))}
                </div>
                <div style={{background:"#f8fafc",borderRadius:10,padding:14,textAlign:"center"}}>
                  <div style={{fontSize:12,color:"#6b7280",marginBottom:4}}>Chain Links Needed (#25)</div>
                  <div style={{fontWeight:900,fontSize:28,color:"#1d4ed8"}}>{links} links</div>
                  <div style={{fontSize:12,color:"#6b7280",marginTop:4}}>Round to even number · Ratio: {t2>t1?(t2/t1).toFixed(2):( t1/t2).toFixed(2)}:1</div>
                </div>
              </div>
            );
          })()}
          {partsCalcMode==="speed" && (() => {
            const rpm = parseFloat(pcRPM)||6000;
            const ratio = (parseFloat(pcGearOut)||60)/(parseFloat(pcGearIn)||12);
            const dia = parseFloat(pcWheelDia)||4;
            const outRPM = rpm/ratio;
            const speedFPS = outRPM * Math.PI * (dia/12) / 60;
            const speedMPS = speedFPS * 0.3048;
            return (
              <div style={{background:"#fff",borderRadius:14,padding:18,border:"1px solid #e2e8f0"}}>
                <div style={{fontWeight:700,marginBottom:14}}>🚀 Robot Speed Calculator</div>
                <div style={{display:"grid",gridTemplateColumns:"1fr 1fr 1fr 1fr",gap:10,marginBottom:16}}>
                  {[["Motor Free RPM",pcRPM,setPcRPM,"6000"],["Driver Teeth",pcGearIn,setPcGearIn,"12"],["Driven Teeth",pcGearOut,setPcGearOut,"60"],["Wheel Diameter (in)",pcWheelDia,setPcWheelDia,"4"]].map(([l,v,s,ph])=>(
                    <div key={l}>
                      <div style={{fontSize:12,color:"#9ca3af",marginBottom:4}}>{l}</div>
                      <input type="number" value={v} onChange={e=>s(e.target.value)} placeholder={ph}
                        style={{width:"100%",padding:"8px 10px",borderRadius:8,border:"1px solid #e2e8f0",fontSize:14,boxSizing:"border-box",fontFamily:"inherit"}}/>
                    </div>
                  ))}
                </div>
                <div style={{display:"grid",gridTemplateColumns:"1fr 1fr 1fr",gap:10}}>
                  {[["Output RPM",outRPM.toFixed(0)+" RPM","#7c3aed"],["Speed (ft/s)",speedFPS.toFixed(1)+" ft/s","#1d4ed8"],["Speed (m/s)",speedMPS.toFixed(2)+" m/s","#059669"]].map(([l,v,c])=>(
                    <div key={l} style={{background:"#f8fafc",borderRadius:10,padding:14,textAlign:"center",border:`2px solid ${c}20`}}>
                      <div style={{fontSize:12,color:"#6b7280",marginBottom:4}}>{l}</div>
                      <div style={{fontWeight:900,fontSize:22,color:c}}>{v}</div>
                    </div>
                  ))}
                </div>
                <div style={{marginTop:14,fontSize:13,color:"#6b7280",background:"#f8fafc",borderRadius:8,padding:10}}>
                  {speedFPS>20?"⚡ Very fast — may sacrifice pushing power.":speedFPS>14?"✅ Good competition speed.":speedFPS>8?"⚠️ Moderate — consider reducing ratio for more speed.":"🐢 Slow — increase ratio or wheel size for more speed."}
                </div>
              </div>
            );
          })()}
        </div>
      )}

      {/* ── MOTOR COMPARISON ── */}
      {tool==="motorcomp" && (
        <div>
          <div style={{fontWeight:800,fontSize:17,marginBottom:4}}>⚡ Motor Comparison</div>
          <div style={{color:"#6b7280",fontSize:13,marginBottom:14}}>Compare stall torque, free speed, and weight for common FRC and FTC motors.</div>
          <div style={{display:"flex",gap:8,flexWrap:"wrap",marginBottom:14}}>
            {["ALL","FRC","FTC"].map(f=>(
              <button key={f} onClick={()=>setMotorFilter(f)}
                style={{background:motorFilter===f?"#1d4ed8":"#f1f5f9",color:motorFilter===f?"#fff":"#374151",border:"none",borderRadius:7,padding:"7px 14px",cursor:"pointer",fontWeight:700,fontSize:13,fontFamily:"inherit"}}>
                {f}
              </button>
            ))}
            <span style={{color:"#9ca3af",fontSize:12,alignSelf:"center",marginLeft:8}}>Sort by:</span>
            {[["stall","Stall Torque"],["free","Free Speed"],["weight","Weight"]].map(([k,l])=>(
              <button key={k} onClick={()=>setMotorSort(k)}
                style={{background:motorSort===k?"#7c3aed":"#f1f5f9",color:motorSort===k?"#fff":"#374151",border:"none",borderRadius:7,padding:"7px 14px",cursor:"pointer",fontWeight:700,fontSize:13,fontFamily:"inherit"}}>
                {l}
              </button>
            ))}
          </div>
          <div style={{display:"flex",flexDirection:"column",gap:6,marginBottom:16}}>
            {[...MOTORS]
              .filter(m=>motorFilter==="ALL"||m.type===motorFilter)
              .sort((a,b)=>motorSort==="weight"?a.weight-b.weight:b[motorSort]-a[motorSort])
              .map((m,i)=>{
                const picked = motorPicked.includes(m.name);
                const maxStall = Math.max(...MOTORS.map(x=>x.stall));
                const maxFree = Math.max(...MOTORS.map(x=>x.free));
                return (
                  <div key={m.name} onClick={()=>setMotorPicked(prev=>prev.includes(m.name)?prev.filter(n=>n!==m.name):[...prev,m.name])}
                    style={{background:picked?"#eff6ff":"#fff",border:`2px solid ${picked?"#1d4ed8":"#e2e8f0"}`,borderRadius:12,padding:"12px 16px",cursor:"pointer",transition:"all 0.15s"}}>
                    <div style={{display:"flex",gap:10,alignItems:"center",marginBottom:8,flexWrap:"wrap"}}>
                      <div style={{fontWeight:800,fontSize:14,flex:1}}>{m.name}</div>
                      <span style={{fontSize:11,background:m.type==="FRC"?"#dbeafe":"#d1fae5",color:m.type==="FRC"?"#1e40af":"#065f46",borderRadius:5,padding:"2px 7px",fontWeight:700}}>{m.type}</span>
                      <span style={{fontSize:12,color:"#6b7280"}}>{m.weight} kg</span>
                    </div>
                    <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:8}}>
                      <div>
                        <div style={{fontSize:11,color:"#9ca3af",marginBottom:3}}>Stall Torque: {m.stall} N·m</div>
                        <div style={{background:"#e5e7eb",borderRadius:999,height:8,overflow:"hidden"}}>
                          <div style={{width:(m.stall/maxStall*100)+"%",background:"#ef4444",height:"100%",borderRadius:999}}/>
                        </div>
                      </div>
                      <div>
                        <div style={{fontSize:11,color:"#9ca3af",marginBottom:3}}>Free Speed: {m.free.toLocaleString()} RPM</div>
                        <div style={{background:"#e5e7eb",borderRadius:999,height:8,overflow:"hidden"}}>
                          <div style={{width:(m.free/maxFree*100)+"%",background:"#3b82f6",height:"100%",borderRadius:999}}/>
                        </div>
                      </div>
                    </div>
                  </div>
                );
              })}
          </div>
          {motorPicked.length>=2 && (
            <div style={{background:"linear-gradient(135deg,#1e3a8a,#4c1d95)",borderRadius:14,padding:18,color:"#fff"}}>
              <div style={{fontWeight:800,marginBottom:12}}>📊 Comparison: {motorPicked.join(" vs ")}</div>
              <div style={{overflowX:"auto"}}>
                <table style={{width:"100%",borderCollapse:"collapse",fontSize:13}}>
                  <thead>
                    <tr>{["Metric",...motorPicked].map(h=><th key={h} style={{textAlign:"left",padding:"6px 10px",borderBottom:"1px solid rgba(255,255,255,0.2)",fontWeight:700,whiteSpace:"nowrap"}}>{h}</th>)}</tr>
                  </thead>
                  <tbody>
                    {[["Stall Torque (N·m)","stall"],["Free Speed (RPM)","free"],["Stall Current (A)","stallA"],["Free Current (A)","freeA"],["Weight (kg)","weight"]].map(([label,key])=>(
                      <tr key={key}>
                        <td style={{padding:"6px 10px",opacity:0.7,whiteSpace:"nowrap"}}>{label}</td>
                        {motorPicked.map(name=>{
                          const m = MOTORS.find(x=>x.name===name);
                          const vals = motorPicked.map(n=>MOTORS.find(x=>x.name===n)?.[key]||0);
                          const best = key==="weight"?Math.min(...vals):Math.max(...vals);
                          return <td key={name} style={{padding:"6px 10px",fontWeight:m?.[key]===best?900:400,color:m?.[key]===best?"#fbbf24":"#fff"}}>{m?.[key]}</td>;
                        })}
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
              <div style={{fontSize:12,opacity:0.6,marginTop:8}}>🏆 Gold = best in category. Click motors above to change selection.</div>
            </div>
          )}
        </div>
      )}

      {/* ── RULES QUIZ ── */}
      {tool==="rulesquiz" && (
        <div>
          <div style={{fontWeight:800,fontSize:17,marginBottom:4}}>📜 FIRST Rules Quiz</div>
          <div style={{color:"#6b7280",fontSize:13,marginBottom:16}}>Test your knowledge of FRC and FTC rules. 8 random questions each time.</div>
          <div style={{display:"flex",flexDirection:"column",gap:12,marginBottom:16}}>
            {rqShuffled.map((q,i)=>(
