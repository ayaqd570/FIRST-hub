  const [confirmAdminPass, setConfirmAdminPass] = useState("");
  const [passChangeMsg, setPassChangeMsg] = useState("");
  const [gateThreshold, setGateThreshold] = useState(25);
  const [gateMsg, setGateMsg] = useState("");
  const [settingsLoaded, setSettingsLoaded] = useState(false);
  const [bulkMsg, setBulkMsg] = useState("");
  const [bulkSent, setBulkSent] = useState("");

  useEffect(()=>{ loadStudents(); loadSettings(); },[]);

  async function loadSettings() {
    const t = await getGateThreshold();
    setGateThreshold(t);
    setSettingsLoaded(true);
  }

  async function handlePassChange() {
    if (!newAdminPass.trim()) { setPassChangeMsg("❌ Password cannot be empty."); return; }
    if (newAdminPass.length < 4) { setPassChangeMsg("❌ Password must be at least 4 characters."); return; }
    if (newAdminPass !== confirmAdminPass) { setPassChangeMsg("❌ Passwords do not match."); return; }
    await storeSet("hub-admin-pass", newAdminPass, true);
    setNewAdminPass(""); setConfirmAdminPass("");
    setPassChangeMsg("✅ Admin password updated successfully!");
    setTimeout(() => setPassChangeMsg(""), 3000);
  }

  async function handleGateThreshold() {
    const n = parseInt(gateThreshold);
    if (isNaN(n) || n < 1 || n > 40) { setGateMsg("❌ Must be a number between 1 and 40."); return; }
    await storeSet("hub-gate-threshold", n, true);
    setGateMsg(`✅ Pass score updated to ${n}/40 (${Math.round(n/40*100)}%).`);
    setTimeout(() => setGateMsg(""), 3000);
  }

  async function loadStudents() {
    const users = await storeGet("hub-users",true) || {};
    setStudents(users);
  }

  async function sendMessage() {
    if (!msgText.trim()||!selStudent) return;
    const users = await storeGet("hub-users",true) || {};
    if (!users[selStudent]) return;
    const msgs = users[selStudent].messages || [];
    msgs.push({from:"Admin",text:msgText.trim(),ts:Date.now(),read:false});
    users[selStudent].messages = msgs;
    await storeSet("hub-users",users,true);
    setMsgText("");setMsgSent(true);
    setTimeout(()=>setMsgSent(false),2000);
    loadStudents();
  }

  const totalLessons = Object.values(LESSONS).reduce((a,s)=>a+Object.values(s).reduce((b,l)=>b+l.length,0),0);

  const ATABS = [{id:"students",lbl:"👥 Students"},{id:"analytics",lbl:"📊 Analytics"},{id:"reports",lbl:"📋 Reports"},{id:"leaderboard",lbl:"🏆 Leaderboard"},{id:"schedule",lbl:"📅 Schedule"},{id:"scoutdata",lbl:"🔭 Scout Data"},{id:"teams",lbl:"🏷 Teams"},{id:"messages",lbl:"💌 Messages"},{id:"chat",lbl:"💬 Chat"},{id:"media",lbl:"🎬 Media"},{id:"forum",lbl:"📋 Forum"},{id:"announcements",lbl:"📣 Announcements"},{id:"settings",lbl:"⚙️ Settings"}];

  return (
    <div style={{fontFamily:"'Segoe UI',system-ui,sans-serif",minHeight:"100vh",background:"#0f172a",color:"#e2e8f0"}}>
      {/* ADMIN HEADER */}
      <div style={{background:"linear-gradient(135deg,#7f1d1d,#b91c1c)",padding:"0 20px",display:"flex",alignItems:"center",gap:12,flexWrap:"wrap",boxShadow:"0 2px 16px rgba(0,0,0,0.4)"}}>
        <div style={{padding:"14px 0"}}>
          <div style={{fontSize:18,fontWeight:900,letterSpacing:0.5}}>⚡ FIRST Hub — Admin</div>
          <div style={{fontSize:11,opacity:0.7,letterSpacing:1,textTransform:"uppercase"}}>Administrator Dashboard</div>
        </div>
