      </div>
    </div>
  );

  if (phase === "quiz" && quizzes.length > 0) {
    const q = quizzes[quizIdx];
    const answered = quizAns !== null;
    return (
      <div>
        <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:16}}>
          <div style={{fontWeight:800,fontSize:15}}>🧩 Blocks Quiz — Question {quizIdx+1}/{quizzes.length}</div>
          <div style={{fontSize:13,color:"#7c3aed",fontWeight:700}}>Score: {quizScore}/{quizIdx}</div>
