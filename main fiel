          </div>
        </div>
        <div style={{display:"flex",gap:16,flexWrap:"wrap"}}>
          {[["📚","Lessons Done",doneCount+"/"+totalLessons],["📊","Progress",pct+"%"],["⏱","Learning Time",fmtTime(learningTime)],["🧪","Placement",placementResult?.role?.name||"Not placed"]].map(([ic,lb,val])=>(
