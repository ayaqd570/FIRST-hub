    try { return JSON.parse(localStorage.getItem("hub-cycles")||"[]"); } catch(e) { return []; }
  });

  function startCycle() {
    if (!cycleRunning) {
      setCycleRunning(true);
      setCycleStart(Date.now());
      setCycleElapsed(0);
      cycleIntervalRef.current = setInterval(() => {
        setCycleElapsed(e => e + 0.1);
      }, 100);
    }
  }
  function recordCycle() {
    if (!cycleRunning) return;
    clearInterval(cycleIntervalRef.current);
    const t = (Date.now() - cycleStart) / 1000;
    setCycles(prev => [...prev, Math.round(t*10)/10]);
    setCycleRunning(false);
    setCycleElapsed(0);
  }
  function saveCycleSession() {
    if (!cycles.length) return;
    const session = {
      team: cycleTeam, match: cycleMatchNum,
      cycles, avg: (cycles.reduce((a,b)=>a+b,0)/cycles.length).toFixed(1),
      ts: Date.now()
    };
    const updated = [session, ...savedCycleData];
    setSavedCycleData(updated);
    localStorage.setItem("hub-cycles", JSON.stringify(updated));
    setCycles([]); setCycleTeam(""); setCycleMatchNum("");
  }

  // ── Auto Route Builder state ──
  const [autoWaypoints, setAutoWaypoints] = useState([]);
  const [autoActions, setAutoActions] = useState({});
  const [autoName, setAutoName] = useState("Auto Routine 1");
  const [savedRoutes, setSavedRoutes] = useState(() => {
    try { return JSON.parse(localStorage.getItem("hub-auto-routes")||"[]"); } catch(e) { return []; }
  });
