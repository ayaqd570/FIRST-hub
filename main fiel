                  <div style={{fontSize:13,opacity:0.7}}>Rate teams on offense, defense, reliability & more — automatic overall score</div>
                </div>
                <div style={{display:"flex",gap:6}}>
                  {[["form","📝 Form"],["list","📊 Entries"],["analysis","🔬 Analysis"]].map(([v,l])=>(
                    <button key={v} onClick={()=>setScoutView(v)}
