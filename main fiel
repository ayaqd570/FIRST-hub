public class SpinUpAndShoot extends SequentialCommandGroup {
    public SpinUpAndShoot(Shooter shooter, Indexer indexer) {
        addCommands(
            new RunCommand(() -> shooter.setRPM(3000), shooter)
                .until(shooter::atSpeed),
            new InstantCommand(() -> indexer.feed()),
            new WaitCommand(0.5),
            new InstantCommand(() -> {
                shooter.setRPM(0);
                indexer.stop();
            })
        );
    }
}
