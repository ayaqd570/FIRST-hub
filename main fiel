    const data = await storeGet("chat-messages", true);
    if (data) setMessages(data);
    setLoading(false);
  }
  async function deleteMsg(channelId, msgId) {
    const current = await storeGet("chat-messages", true) || {};
    if (current[channelId]) current[channelId] = current[channelId].filter(m => m.id !== msgId);
    await storeSet("chat-messages", current, true);
    setMessages({ ...current });
  }
  const channelMsgs = messages[channel] || [];
  return (
    <div>
      <div style={{ display: "flex", gap: 8, marginBottom: 14, flexWrap: "wrap" }}>
        {CHAT_CHANNELS.map(c => (
          <button key={c.id} onClick={() => setChannel(c.id)}
