            <div style={{display:"flex",alignItems:"stretch",borderRadius:10,overflow:"hidden",border:`2px solid ${c.border}`,boxShadow:`0 2px 8px ${c.border}30`}}>
              {/* Left notch connector */}
              <div style={{width:14,background:c.border,flexShrink:0,position:"relative"}}>
                {i>0 && <div style={{position:"absolute",top:-2,left:"50%",transform:"translateX(-50%)",width:10,height:10,borderRadius:"50%",background:"#fff",border:`2px solid ${c.border}`}}/>}
                {i<blocks.length-1 && <div style={{position:"absolute",bottom:-2,left:"50%",transform:"translateX(-50%)",width:10,height:10,borderRadius:"50%",background:"#fff",border:`2px solid ${c.border}`}}/>}
              </div>
              <div style={{flex:1,background:c.bg,padding:"12px 16px"}}>
                <div style={{display:"flex",alignItems:"center",gap:8,marginBottom:8}}>
                  <span style={{fontSize:18}}>{c.icon}</span>
                  <span style={{fontSize:11,fontWeight:800,textTransform:"uppercase",letterSpacing:1,color:c.text,background:c.border+"25",padding:"2px 8px",borderRadius:20}}>{block.type}</span>
                  <span style={{fontWeight:800,fontSize:14,color:c.text,marginLeft:4}}>{block.label}</span>
                </div>
                {/* Visual block body */}
                <div style={{background:"#0f172a",borderRadius:8,padding:"10px 14px",marginBottom:10,fontFamily:"'Fira Code','Courier New',monospace",fontSize:13,color:"#e2e8f0",lineHeight:1.7,border:`1px solid ${c.border}40`}}>
                  {block.code.split('\n').map((line, li) => (
                    <div key={li} style={{display:"flex"}}>
                      <span style={{color:"#475569",fontSize:11,minWidth:24,userSelect:"none",marginRight:8}}>{li+1}</span>
