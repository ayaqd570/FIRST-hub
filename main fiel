  if (phase === "learn") return (
    <div>
      <div style={{background:"linear-gradient(135deg,#7c3aed,#4f46e5)",borderRadius:14,padding:20,color:"#fff",marginBottom:18}}>
        <div style={{fontSize:26,marginBottom:6}}>🧩 Block Programming</div>
        <div style={{fontSize:14,opacity:0.9,lineHeight:1.6}}>{lesson.intro || "Learn Java concepts through visual blocks — then write the real code."}</div>
        <div style={{fontSize:12,opacity:0.7,marginTop:8}}>{blocks.length} code blocks · Visual + Text learning</div>
      </div>
