          </div>
        </div>

        {/* Teacher Notes */}
        <div style={{...S.card,borderColor:"#1d4ed8"}}>
          <div style={{fontWeight:700,color:"#93c5fd",fontSize:15,marginBottom:12}}>🎓 Admin Recommendations for this Student</div>
          {getTeacherNotes().map((note,i)=>(
            <div key={i} style={{background:"rgba(0,0,0,0.3)",borderRadius:8,padding:"10px 14px",fontSize:13,color:"#e2e8f0",marginBottom:8,lineHeight:1.5}}>
