                <div key={i} style={{padding:"12px 16px",borderBottom:i<MATCH_TIMELINE.length-1?"1px solid #e2e8f0":"none",display:"flex",alignItems:"center",gap:12,background:isCurrent?"#eff6ff":"transparent"}}>
