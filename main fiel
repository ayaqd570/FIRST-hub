// Apply jerk limiting (limit rate of change of acceleration)
double maxJerk         = 0.002; // acceleration change per loop
double targetAccel;
if (distanceToTarget < decelDistance) {
    targetAccel = -acceleration; // Slowing
} else if (currentVelocity < maxVelocity) {
    targetAccel = acceleration;  // Speeding up
} else {
    targetAccel = 0;             // Cruising
}

// Limit how fast acceleration can change (S-curve smoothing)
currentAcceleration = Math.max(currentAcceleration - maxJerk,
                      Math.min(currentAcceleration + maxJerk, targetAccel));
currentVelocity += currentAcceleration;`,explanation:"S-curves go one step further than trapezoids — they also smooth the acceleration transitions, producing a true S-shaped velocity curve. This reduces mechanical stress and wheel slip even further. Road Runner uses S-curve motion profiles internally."},
