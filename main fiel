from enum import Enum, auto
import wpilib

class RobotState(Enum):
    IDLE     = auto()
    INTAKING = auto()
    LIFTING  = auto()
    SCORING  = auto()
    RESET    = auto()

class Robot(wpilib.TimedRobot):
    def robotInit(self):
        self.state  = RobotState.IDLE
        self.intake = wpilib.PWMSparkMax(2)
        self.pad    = wpilib.Joystick(0)

    def teleopPeriodic(self):
        if self.state == RobotState.IDLE:
            if self.pad.getRawButton(1):
                self.state = RobotState.INTAKING

        elif self.state == RobotState.INTAKING:
            self.intake.set(1.0)
            if self.color_sensor.proximity > 500:
                self.intake.set(0)
                self.state = RobotState.LIFTING

        elif self.state == RobotState.LIFTING:
            self.lift.setTarget(self.LIFT_HIGH)
            if self.lift.at_target:
                self.state = RobotState.SCORING

        elif self.state == RobotState.SCORING:
            self.claw.set(0.0)
            self.state = RobotState.RESET

        elif self.state == RobotState.RESET:
            self.lift.setTarget(0)
            if self.lift.at_target:
                self.state = RobotState.IDLE

        wpilib.SmartDashboard.putString("State", self.state.name)
