          {/* Strengths */}
          <div style={{...S.card}}>
            <div style={{fontWeight:700,color:"#34d399",fontSize:14,marginBottom:10}}>💪 Strengths</div>
            {strengths.length?strengths.map(s=><div key={s.id} style={{color:"#94a3b8",fontSize:13,marginBottom:6}}>{s.icon} {s.name}</div>):<div style={{color:"#6b7280",fontSize:13}}>Complete more lessons to identify.</div>}
