import pandas as pd
import numpy as np
import requests
import matplotlib.pyplot as plt

class ScoutingPipeline:
    def __init__(self, tba_key, event_key):
        self.headers   = {"X-TBA-Auth-Key": tba_key}
        self.event_key = event_key
        self.base      = "https://www.thebluealliance.com/api/v3"

    def fetch(self, endpoint):
        return requests.get(self.base + endpoint, headers=self.headers).json()

    def get_team_stats(self):
        oprs    = self.fetch(f"/event/{self.event_key}/oprs")
        matches = self.fetch(f"/event/{self.event_key}/matches")
        teams   = self.fetch(f"/event/{self.event_key}/teams/simple")

        data = []
        for team in teams:
            key = team["key"]
            opr = oprs["oprs"].get(key, 0)
            scores = []
            for m in matches:
                if m["comp_level"] != "qm": continue
                for color in ["red", "blue"]:
                    if key in m["alliances"][color]["team_keys"]:
                        scores.append(m["alliances"][color]["score"])
            data.append({
                "number": team["team_number"],
                "name":   team["nickname"],
                "opr":    round(opr, 1),
                "ccwm":   round(opr - oprs["dprs"].get(key, 0), 1),
                "avg":    round(np.mean(scores) if scores else 0, 1),
                "std":    round(np.std(scores)  if scores else 0, 1),
            })
        return pd.DataFrame(data).sort_values("opr", ascending=False)

    def generate_picklist(self, my_team):
        df = self.get_team_stats()
        df = df[df["number"] != my_team]
        df["pick_score"] = df["opr"]*0.6 + (-df["std"])*0.2 + df["ccwm"]*0.2
        return df.sort_values("pick_score", ascending=False)

