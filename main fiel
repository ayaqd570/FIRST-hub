const JSONBIN_KEY = "$2a$10$Cw49V21qOMsbpNh4yD1wa.rNqIVQz1FH4FG..jF2FsG7XeYgFLU4W "; // paste your Master Key here e.g. "$2b$10$abc..."
const JSONBIN_BIN = "69a82a71d0ea881f40ee16bf"; // paste your Bin ID here e.g. "65abc123def456"
const JSONBIN_URL = `https://api.jsonbin.io/v3/b/${JSONBIN_BIN}`;

// In-memory cache so we don't hammer the API on every read
let _sharedCache = null;
let _cacheTs = 0;
const CACHE_TTL = 4000; // 4 seconds

async function _getRemote() {
  try {
    const r = await fetch(JSONBIN_URL + "/latest", {
      headers: { "X-Master-Key": JSONBIN_KEY }
    });
    if (!r.ok) throw new Error("HTTP " + r.status);
    const d = await r.json();
    _sharedCache = d.record || {};
    _cacheTs = Date.now();
    return _sharedCache;
  } catch(e) {
    console.warn("JSONBin read failed, using localStorage fallback:", e.message);
    return null;
  }
}

async function _setRemote(data) {
  _sharedCache = data;
  _cacheTs = Date.now();
  try {
    const r = await fetch(JSONBIN_URL, {
      method: "PUT",
      headers: { "Content-Type": "application/json", "X-Master-Key": JSONBIN_KEY },
      body: JSON.stringify(data)
    });
    if (!r.ok) throw new Error("HTTP " + r.status);
  } catch(e) {
    console.warn("JSONBin write failed, using localStorage fallback:", e.message);
    // Fall back to localStorage
    localStorage.setItem("shared:__jsonbin__", JSON.stringify(data));
  }
}

function _useRemote() {
  return JSONBIN_KEY && JSONBIN_BIN && JSONBIN_KEY.length > 10;
}

// storeGet / storeSet — drop-in replacements that work both locally and multi-computer
async function storeGet(key, shared=false) {
  try {
    if (shared && _useRemote()) {
      // Use cache if fresh enough
      let db = (_sharedCache && (Date.now() - _cacheTs) < CACHE_TTL) ? _sharedCache : await _getRemote();
      if (!db) db = JSON.parse(localStorage.getItem("shared:__jsonbin__") || "{}");
      return db[key] !== undefined ? db[key] : null;
    }
    const storageKey = shared ? "shared:" + key : "user:" + key;
    const raw = localStorage.getItem(storageKey);
    return raw ? JSON.parse(raw) : null;
  } catch(e) { return null; }
}

async function storeSet(key, val, shared=false) {
  try {
    if (shared && _useRemote()) {
      let db = (_sharedCache && (Date.now() - _cacheTs) < CACHE_TTL) ? _sharedCache : await _getRemote();
      if (!db) db = JSON.parse(localStorage.getItem("shared:__jsonbin__") || "{}");
      db[key] = val;
      await _setRemote(db);
      return;
    }
    const storageKey = shared ? "shared:" + key : "user:" + key;
    localStorage.setItem(storageKey, JSON.stringify(val));
  } catch(e) { console.warn("storeSet failed:", e); }
}

// Helper: clear all hub data
function clearAllHubData() {
  const toRemove = [];
  for (let i = 0; i < localStorage.length; i++) {
    const k = localStorage.key(i);
    if (k && (k.startsWith("shared:") || k.startsWith("user:"))) toRemove.push(k);
  }
  toRemove.forEach(k => localStorage.removeItem(k));
  _sharedCache = null;
  window.location.reload();
}

