// ─── FLASHCARD PAGE ───────────────────────────────────────
function FlashcardsPage({ user }) {
  const [deck, setDeck] = useState(null);
  const [cardIdx, setCardIdx] = useState(0);
  const [flipped, setFlipped] = useState(false);
  const [ratings, setRatings] = useState({});
  const [shuffled, setShuffled] = useState([]);
  const [sessionDone, setSessionDone] = useState(false);
  const [progress, setProgress] = useState({});
  const [loading, setLoading] = useState(false);

  useEffect(()=>{
    if (user) storeGet("hub-flashcards-"+user.username, false).then(d=>{ if(d) setProgress(typeof d==="object"?d:{}); });
  },[user]);

  function startDeck(deckId) {
    const cards = FLASHCARD_DECKS[deckId].cards;
    const saved = progress[deckId] || {};
    const unknowns = cards.filter((c,i)=>saved[i]!=="know");
    const order = shuffleArr(unknowns.length>0?unknowns.map(c=>cards.indexOf(c)):cards.map((_,i)=>i));
    setDeck(deckId); setShuffled(order.length?order:cards.map((_,i)=>i));
    setCardIdx(0); setFlipped(false); setRatings({}); setSessionDone(false);
  }

  async function rateCard(rating) {
    const realIdx = shuffled[cardIdx];
    const nr = {...ratings, [realIdx]: rating};
    setRatings(nr);
    const newProg = {...(progress[deck]||{})};
    if (rating==="know") newProg[realIdx]="know";
    else delete newProg[realIdx];
    const newAllProg = {...progress, [deck]: newProg};
    setProgress(newAllProg);
    if (user) await storeSet("hub-flashcards-"+user.username, newAllProg, false);
    if (cardIdx+1 >= shuffled.length) setSessionDone(true);
    else { setCardIdx(cardIdx+1); setFlipped(false); }
  }

  function restart() { startDeck(deck); }
  function backToDecks() { setDeck(null); setSessionDone(false); }

  const deckKeys = Object.keys(FLASHCARD_DECKS);
  const totalCards = deck ? FLASHCARD_DECKS[deck].cards.length : 0;
  const knownCount = deck ? Object.values(progress[deck]||{}).filter(v=>v==="know").length : 0;

  if (!deck) {
    return (
      <div style={{maxWidth:800,margin:"0 auto",padding:"24px 16px"}}>
        <div style={{marginBottom:24}}>
          <div style={{fontWeight:900,fontSize:24,color:"#1e293b",marginBottom:6}}>🃏 Flashcard Decks</div>
          <div style={{color:"#64748b",fontSize:14}}>Memorize key concepts with spaced repetition. Cards you mark "Still Learning" come back more often.</div>
        </div>
        <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(240px,1fr))",gap:16}}>
          {deckKeys.map(dk=>{
            const d = FLASHCARD_DECKS[dk];
            const total = d.cards.length;
            const known = Object.values(progress[dk]||{}).filter(v=>v==="know").length;
            const pct = Math.round(known/total*100);
            return (
              <div key={dk} onClick={()=>startDeck(dk)} style={{background:"#fff",borderRadius:16,padding:22,border:"1px solid #e2e8f0",cursor:"pointer",transition:"all 0.2s",boxShadow:"0 1px 4px rgba(0,0,0,0.04)"}}
