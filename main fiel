  return (
    <div>
      <div style={{fontWeight:900,fontSize:24,marginBottom:4}}>🛠️ FIRST Tools</div>
      <div style={{color:"#6b7280",fontSize:13,marginBottom:20}}>Practical tools for competition day, build season, and practice.</div>

      <div style={{display:"flex",gap:8,flexWrap:"wrap",marginBottom:22}}>
        {TOOLS.map(t => (
          <button key={t.id} onClick={()=>setTool(t.id)}
            style={{background:tool===t.id?"#1d4ed8":"#fff",border:`2px solid ${tool===t.id?"#1d4ed8":"#e2e8f0"}`,color:tool===t.id?"#fff":"#374151",padding:"10px 16px",borderRadius:10,cursor:"pointer",fontWeight:700,fontSize:13,fontFamily:"inherit",transition:"all 0.15s"}}>
            <div>{t.label}</div>
            <div style={{fontSize:11,fontWeight:400,opacity:0.8,marginTop:2}}>{t.desc}</div>
          </button>
        ))}
      </div>

      {/* ── ROBOT INSPECTION ── */}
      {tool==="inspection" && (
        <div>
